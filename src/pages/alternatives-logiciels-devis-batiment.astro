---
import PagePhotoShowcase from '../components/visuals/PagePhotoShowcase.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { competitorAlternatives } from '../data/competitorAlternatives';
import { useCaseAlternatives } from '../data/useCaseAlternatives';

const title = 'Alternatives logiciels devis bâtiment | Comparatif artisans énergie';
const description =
  'Comparez Obat, Tolteck, Costructor, Batappli, ProGBat, Sage Batigest, EBP et autres logiciels avec Chiffr, l’alternative spécialisée artisans énergie.';

const mainCompetitors = competitorAlternatives.slice(0, 6);
const otherCompetitors = competitorAlternatives.slice(6);

const mainUseCases = useCaseAlternatives.slice(0, 6);
const otherUseCases = useCaseAlternatives.slice(6);

const allAlternativePages = [
  ...competitorAlternatives.map((page) => ({
    name: page.h1,
    url: `/${page.slug}`,
  })),
  ...useCaseAlternatives.map((page) => ({
    name: page.h1,
    url: `/${page.slug}`,
  })),
];

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Alternatives logiciels devis bâtiment',
  itemListElement: allAlternativePages.map((page, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: page.name,
    url: page.url,
  })),
};

const faqs = [
  {
    question: 'Pourquoi comparer les logiciels de devis bâtiment ?',
    answer:
      'Tous les logiciels ne répondent pas au même besoin. Certains couvrent le bâtiment complet, d’autres la gestion commerciale ou la facturation généraliste. Chiffr se concentre sur les devis et factures des artisans énergie : PAC, clim, chauffage, CVC, VMC, IRVE et solaire.',
  },
  {
    question: 'Chiffr est-il une alternative à Obat, Tolteck ou Costructor ?',
    answer:
      'Oui, Chiffr peut être une alternative si vous cherchez un outil plus spécialisé pour les artisans PAC, climatisation, chauffage, CVC, VMC, IRVE ou solaire. Les logiciels généralistes peuvent rester adaptés pour une gestion BTP plus large.',
  },
  {
    question: 'Faut-il choisir un logiciel généraliste ou spécialisé ?',
    answer:
      'Un logiciel généraliste peut convenir si vous voulez gérer beaucoup d’aspects de l’entreprise. Un outil spécialisé comme Chiffr est plus adapté si votre priorité est de produire vite des devis énergie clairs, guidés, signables et faciles à facturer.',
  },
  {
    question: 'Les pages alternatives sont-elles des classements ?',
    answer:
      'Non. Ces pages ne sont pas des classements et ne prétendent pas qu’un outil est meilleur dans tous les cas. Elles servent à comparer les positionnements, les usages et la pertinence pour un artisan énergie.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath="/alternatives-logiciels-devis-batiment"
  schema={[itemListSchema, faqSchema]}
>
  <style is:global>
    .alternatives-page,
    .alternatives-page * {
      box-sizing: border-box;
    }

    .alternatives-page {
      color: var(--ink);
      overflow: hidden;
    }

    .alt-hub-shell {
      width: 100%;
      max-width: 1280px;
      margin: 0 auto;
    }

    .alt-hub-narrow {
      max-width: 920px;
    }

    .alt-hub-hero,
    .alt-hub-section,
    .alt-hub-cta {
      position: relative;
      padding: 72px 20px;
    }

    .alt-hub-hero {
      padding-top: 88px;
      padding-bottom: 76px;
    }

    .alt-hub-hero::before {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      background:
        radial-gradient(circle at 88% 18%, rgba(12, 20, 32, 0.12), transparent 32%);
    }

    .alt-hub-grid {
      position: relative;
      z-index: 1;
      display: grid;
      gap: 46px;
      align-items: center;
    }

    .alt-hub-pill,
    .alt-hub-kicker {
      display: inline-flex;
      width: fit-content;
      margin: 0;
      padding: 8px 14px;
      border-radius: 999px;
      border: 1px solid rgba(12, 20, 32, 0.12);
      background: rgba(255, 255, 255, 0.78);
      color: var(--teal);
      font-size: 14px;
      line-height: 1.3;
      font-weight: 600;
    }

    .alt-hub-kicker {
      padding: 0;
      border: 0;
      background: transparent;
      color: var(--copper);
      font-size: 15px;
    }

    .alternatives-page h1 {
      margin: 26px 0 0;
      max-width: 940px;
      color: var(--teal);
      font-size: clamp(42px, 5.4vw, 78px);
      line-height: 1;
      letter-spacing: -0.02em;
      font-weight: 650;
    }

    .alt-hub-lead {
      margin: 22px 0 0;
      max-width: 780px;
      color: #5F6673;
      font-size: 20px;
      line-height: 1.7;
    }

    .alt-hub-soon {
      display: block;
      max-width: 780px;
      margin: 18px 0 0;
      padding: 14px 16px;
      border-radius: 14px;
      background: var(--chiffr-copper-soft);
      border: 1px solid color-mix(in srgb, var(--chiffr-copper) 22%, transparent);
      color: var(--chiffr-text);
      font-size: 15px;
      line-height: 1.55;
      font-weight: 500;
    }

    .alt-hub-soon-tag {
      display: inline-block;
      margin-right: 8px;
      padding: 3px 9px;
      border-radius: 999px;
      background: var(--chiffr-copper);
      color: #FFFFFF;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      vertical-align: middle;
    }

    .alt-hub-soon a {
      color: var(--chiffr-copper-dark);
      font-weight: 700;
      white-space: nowrap;
    }

    .alt-hub-actions {
      margin-top: 30px;
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
    }

    .alt-hub-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 52px;
      border-radius: 999px;
      padding: 16px 24px;
      font-weight: 650;
      line-height: 1;
      transition: transform 180ms ease, box-shadow 180ms ease, background 180ms ease;
    }

    .alt-hub-btn.primary {
      color: white;
      background: var(--teal);
      box-shadow: 0 18px 38px rgba(12, 20, 32, 0.18);
    }

    .alt-hub-btn.primary:hover {
      transform: translateY(-2px);
      background: #043840;
      box-shadow: 0 24px 48px rgba(12, 20, 32, 0.22);
    }

    .alt-hub-btn.secondary {
      color: var(--teal);
      background: rgba(255, 255, 255, 0.82);
      border: 1px solid rgba(12, 20, 32, 0.14);
    }

    .alt-hub-btn.secondary:hover {
      transform: translateY(-2px);
      background: white;
      box-shadow: 0 18px 38px rgba(12, 20, 32, 0.08);
    }

    .alt-hub-proof {
      margin-top: 22px;
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      color: #5F6673;
      font-size: 13px;
      font-weight: 600;
    }

    .alt-hub-proof span::before {
      content: "✓";
      margin-right: 6px;
      color: var(--success);
    }

    .alt-hub-card,
    .alt-card,
    .alt-hub-panel,
    .alt-hub-step,
    .alt-hub-faq-card {
      border: 1px solid rgba(12, 20, 32, 0.12);
      background:
        linear-gradient(145deg, rgba(255, 252, 247, 0.96), rgba(255, 255, 255, 0.86));
      box-shadow:
        0 26px 74px rgba(12, 20, 32, 0.1),
        inset 0 1px 0 rgba(255, 255, 255, 0.9);
    }

    .alt-hub-card {
      overflow: hidden;
      border-radius: 24px;
      padding: 22px;
    }

    .alt-hub-card-top {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 18px;
      margin-bottom: 14px;
    }

    .alt-hub-dots {
      display: flex;
      gap: 7px;
    }

    .alt-hub-dots span {
      width: 10px;
      height: 10px;
      border-radius: 999px;
      background: rgba(12, 20, 32, 0.18);
    }

    .alt-hub-dots span:nth-child(1) {
      background: #F6E7DB;
    }

    .alt-hub-dots span:nth-child(2) {
      background: #E6F1F0;
    }

    .alt-hub-dots span:nth-child(3) {
      background: rgba(47, 125, 70, 0.45);
    }

    .alt-hub-status {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(12, 20, 32, 0.08);
      color: var(--teal);
      font-size: 13px;
      font-weight: 650;
    }

    .alt-hub-status span {
      width: 8px;
      height: 8px;
      border-radius: 999px;
      background: var(--success);
      box-shadow: 0 0 0 6px rgba(47, 125, 70, 0.12);
    }

    .alt-hub-card-head {
      padding: 24px;
      border-radius: 18px;
      color: white;
      background:
        radial-gradient(circle at 80% 0%, rgba(255, 255, 255, 0.12), transparent 34%),
        linear-gradient(135deg, #0C1420, #043840);
    }

    .alt-hub-card-head p {
      margin: 0;
      color: rgba(255, 255, 255, 0.66);
      font-size: 14px;
      font-weight: 600;
    }

    .alt-hub-card-head h2 {
      margin: 8px 0 0;
      color: white;
      font-size: 34px;
      line-height: 1.04;
      letter-spacing: -0.02em;
      font-weight: 650;
    }

    .alt-hub-card-list {
      margin-top: 16px;
      display: grid;
      gap: 10px;
    }

    .alt-hub-card-row {
      display: grid;
      grid-template-columns: 36px 1fr auto;
      gap: 12px;
      align-items: center;
      padding: 13px;
      border-radius: 20px;
      background: rgba(255, 255, 255, 0.78);
      border: 1px solid rgba(12, 20, 32, 0.08);
    }

    .alt-hub-card-row b {
      width: 36px;
      height: 36px;
      display: grid;
      place-items: center;
      border-radius: 14px;
      background: var(--teal);
      color: white;
      font-size: 13px;
      font-weight: 650;
    }

    .alt-hub-card-row strong {
      color: var(--teal);
      font-size: 15px;
      font-weight: 650;
    }

    .alt-hub-card-row small {
      color: #5F6673;
      font-size: 12px;
      font-weight: 600;
      white-space: nowrap;
    }

    .alt-hub-section-head {
      max-width: 880px;
      margin-bottom: 30px;
    }

    .alt-hub-section-head h2,
    .alt-hub-panel h2,
    .alt-hub-cta h2 {
      margin: 14px 0 0;
      color: var(--teal);
      font-size: clamp(34px, 3.8vw, 56px);
      line-height: 1.06;
      letter-spacing: -0.02em;
      font-weight: 650;
    }

    .alt-hub-section-head p,
    .alt-hub-panel p,
    .alt-hub-cta p {
      margin: 14px 0 0;
      color: #5F6673;
      font-size: 18px;
      line-height: 1.65;
    }

    .alt-grid-list,
    .alt-step-grid,
    .faq-list {
      display: grid;
      gap: 14px;
    }

    .alt-card {
      display: grid;
      gap: 13px;
      min-height: 250px;
      border-radius: 18px;
      padding: 22px;
      color: inherit;
      transition: transform 180ms ease, background 180ms ease, box-shadow 180ms ease;
    }

    .alt-card:hover {
      transform: translateY(-4px);
      background: white;
      box-shadow: 0 26px 70px rgba(12, 20, 32, 0.12);
    }

    .alt-card-top {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 14px;
    }

    .alt-card small {
      display: inline-flex;
      width: fit-content;
      padding: 7px 10px;
      border-radius: 999px;
      background: rgba(12, 20, 32, 0.07);
      color: var(--teal);
      font-size: 12px;
      line-height: 1;
      font-weight: 650;
    }

    .alt-card h3 {
      margin: 12px 0 0;
      color: var(--teal);
      font-size: 24px;
      line-height: 1.1;
      letter-spacing: -0.02em;
      font-weight: 650;
    }

    .alt-card p {
      margin: 0;
      color: #5F6673;
      font-size: 15px;
      line-height: 1.55;
    }

    .alt-card-arrow {
      width: 38px;
      height: 38px;
      flex: none;
      display: grid;
      place-items: center;
      border-radius: 999px;
      background: var(--teal);
      color: white;
      font-weight: 650;
      transition: transform 180ms ease;
    }

    .alt-card:hover .alt-card-arrow {
      transform: translateX(3px);
    }

    .alt-card-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: auto;
    }

    .alt-card-tags span {
      display: inline-flex;
      padding: 7px 9px;
      border-radius: 999px;
      background: rgba(230, 241, 240, 0.72);
      color: var(--teal);
      font-size: 12px;
      font-weight: 600;
    }

    .alt-hub-split {
      display: grid;
      gap: 22px;
    }

    .alt-hub-panel {
      border-radius: 24px;
      padding: 34px;
    }

    .alt-hub-panel.dark {
      background: var(--teal);
      color: white;
    }

    .alt-hub-panel.dark h2 {
      color: white;
    }

    .alt-hub-panel.dark p {
      color: rgba(255, 255, 255, 0.74);
    }

    .alt-hub-step {
      border-radius: 16px;
      padding: 20px;
    }

    .alt-hub-step b {
      display: inline-grid;
      width: 38px;
      height: 38px;
      place-items: center;
      border-radius: 14px;
      background: var(--teal);
      color: white;
      font-size: 13px;
      font-weight: 650;
    }

    .alt-hub-step h3 {
      margin: 14px 0 0;
      color: var(--teal);
      font-size: 20px;
      line-height: 1.15;
      font-weight: 650;
    }

    .alt-hub-step p {
      margin: 8px 0 0;
      color: #5F6673;
      font-size: 14px;
      line-height: 1.5;
    }

    .alt-hub-faq-card {
      border-radius: 18px;
      padding: 22px 24px;
    }

    .alt-hub-faq-card summary {
      cursor: pointer;
      color: var(--teal);
      font-size: 18px;
      line-height: 1.4;
      letter-spacing: -0.015em;
      font-weight: 650;
    }

    .alt-hub-faq-card p {
      margin: 14px 0 0;
      color: #5F6673;
      font-size: 16px;
      line-height: 1.7;
    }

    .alt-hub-cta {
      text-align: center;
    }

    .alt-hub-cta .alt-hub-shell {
      padding: 50px 28px;
      border-radius: 24px;
      border: 1px solid rgba(12, 20, 32, 0.1);
      background:
        linear-gradient(145deg, rgba(255, 255, 255, 0.78), rgba(255, 252, 247, 0.86));
      box-shadow: 0 26px 78px rgba(12, 20, 32, 0.1);
    }

    .alt-hub-cta .alt-hub-btn {
      margin-top: 24px;
    }

    @media (min-width: 760px) {
      .alt-grid-list,
      .alt-step-grid,
      .faq-list {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (min-width: 1020px) {
      .alt-hub-grid {
        grid-template-columns: 1.05fr 0.95fr;
      }

      .alt-grid-list {
        grid-template-columns: repeat(3, 1fr);
      }

      .alt-hub-split {
        grid-template-columns: 1fr 1fr;
      }

      .alt-step-grid {
        grid-template-columns: repeat(4, 1fr);
      }
    }

    @media (max-width: 720px) {
      .alt-hub-hero,
      .alt-hub-section,
      .alt-hub-cta {
        padding: 52px 18px;
      }

      .alt-hub-hero {
        padding-top: 58px;
      }

      .alternatives-page h1 {
        font-size: clamp(40px, 14vw, 58px);
      }

      .alt-hub-lead {
        font-size: 18px;
      }

      .alt-hub-actions {
        display: grid;
      }

      .alt-hub-btn {
        width: 100%;
      }

      .alt-hub-card-row {
        grid-template-columns: 36px 1fr;
      }

      .alt-hub-card-row small {
        grid-column: 2;
      }

      .alt-hub-panel {
        padding: 24px;
        border-radius: 18px;
      }
    }
  </style>

  <div class="alternatives-page">
    <section class="alt-hub-hero">
      <div class="alt-hub-shell alt-hub-grid">
        <div>
          <p class="alt-hub-pill">Alternatives logiciels devis bâtiment</p>

          <h1>Comparer les logiciels de devis bâtiment avec un angle artisans énergie</h1>

          <p class="alt-hub-lead">
            Obat, Tolteck, Costructor, Batappli, ProGBat, Sage Batigest, EBP, Axonaut, Abby, Evoliz,
            Artinove ou Henrri ne répondent pas tous au même besoin. Chiffr prend un angle plus spécialisé :
            devis, signature, acompte, factures, relances et suivi client pour artisans énergie.
          </p>

          <p class="alt-hub-soon">
            <span class="alt-hub-soon-tag">Bientôt</span>
            Une version <strong>Chiffr Bâtiment</strong> élargie (rénovation, multi‑corps d’état) est en
            préparation. <a href="/contact">Être prévenu au lancement →</a>
          </p>

          <div class="alt-hub-actions">
            <a href="#alternatives" class="alt-hub-btn primary">Voir les alternatives</a>
            <a href="/modeles-devis" class="alt-hub-btn secondary">Voir les modèles de devis</a>
          </div>

          <div class="alt-hub-proof">
            <span>Comparatifs propres</span>
            <span>Pas de classement inventé</span>
            <span>Sources publiques</span>
            <span>Angle artisans énergie</span>
            <span>Maillage SEO</span>
          </div>
        </div>

        <aside class="alt-hub-card" aria-label="Aperçu stratégie alternatives Chiffr">
          <div class="alt-hub-card-top">
            <div class="alt-hub-dots" aria-hidden="true">
              <span></span><span></span><span></span>
            </div>
            <div class="alt-hub-status"><span></span> Comparaison guidée</div>
          </div>

          <div class="alt-hub-card-head">
            <p>Choisir le bon logiciel</p>
            <h2>Généraliste ou spécialisé énergie ?</h2>
          </div>

          <div class="alt-hub-card-list">
            <div class="alt-hub-card-row">
              <b>01</b>
              <strong>Comparer les usages</strong>
              <small>besoin réel</small>
            </div>
            <div class="alt-hub-card-row">
              <b>02</b>
              <strong>Regarder le métier couvert</strong>
              <small>PAC · Clim · IRVE</small>
            </div>
            <div class="alt-hub-card-row">
              <b>03</b>
              <strong>Tester les modèles concrets</strong>
              <small>devis</small>
            </div>
            <div class="alt-hub-card-row">
              <b>04</b>
              <strong>Choisir l’outil adapté</strong>
              <small>terrain</small>
            </div>
          </div>
        </aside>
      </div>
    </section>

    <section class="alt-hub-section">
      <div class="alt-hub-shell">
        <PagePhotoShowcase
          variant="alternatives"
          eyebrow="Comparatif visuel"
          title="Le bon logiciel est celui qui colle à votre chantier, pas seulement à votre bureau"
          text="Un installateur PAC, clim, VMC ou IRVE doit retrouver vite son client, ses photos, ses lignes de devis, sa signature, son acompte, ses factures et ses relances."
          ctaLabel="Voir les alternatives"
          ctaHref="#alternatives"
        />
      </div>
    </section>


    <section class="alt-hub-section" id="alternatives">
      <div class="alt-hub-shell">
        <div class="alt-hub-section-head">
          <p class="alt-hub-kicker">Alternatives principales</p>
          <h2>Les alternatives les plus recherchées par les artisans bâtiment</h2>
          <p>
            Chaque page compare le positionnement public du logiciel avec Chiffr, sans dénigrement ni faux classement :
            l’objectif est d’aider un artisan énergie à comprendre quel outil colle le mieux à sa façon de travailler.
          </p>
        </div>

        <div class="alt-grid-list">
          {mainCompetitors.map((alternative) => (
            <a href={`/${alternative.slug}`} class="alt-card">
              <div class="alt-card-top">
                <div>
                  <small>Alternative</small>
                  <h3>{alternative.competitorName}</h3>
                </div>

                <span class="alt-card-arrow">→</span>
              </div>

              <p>{alternative.metaDescription}</p>

              <div class="alt-card-tags">
                <span>Devis</span>
                <span>Factures</span>
                <span>Artisans énergie</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="alt-hub-section">
      <div class="alt-hub-shell alt-hub-split">
        <article class="alt-hub-panel dark">
          <p class="alt-hub-kicker">Notre angle</p>
          <h2>Chiffr n’essaie pas de devenir un logiciel BTP généraliste.</h2>
          <p>
            Chiffr se concentre sur le devis/facture des artisans énergie : modèles métier,
            lignes préparées, photos chantier, PDF premium, signature, acompte, factures et suivi client.
          </p>
        </article>

        <article class="alt-hub-panel">
          <p class="alt-hub-kicker">Pourquoi comparer ?</p>
          <h2>Le meilleur logiciel dépend du métier et du niveau de complexité.</h2>
          <p>
            Un outil généraliste peut être parfait pour une entreprise BTP large. Pour un artisan PAC,
            climatisation, VMC, IRVE ou solaire, un outil plus guidé métier peut être plus direct.
          </p>
        </article>
      </div>
    </section>

    <section class="alt-hub-section">
      <div class="alt-hub-shell">
        <div class="alt-hub-section-head">
          <p class="alt-hub-kicker">Autres alternatives</p>
          <h2>D’autres logiciels à comparer selon votre profil</h2>
          <p>
            Ces pages couvrent aussi les recherches autour de la facturation en ligne, de la gestion commerciale,
            des indépendants et des outils moins spécialisés bâtiment.
          </p>
        </div>

        <div class="alt-grid-list">
          {otherCompetitors.map((alternative) => (
