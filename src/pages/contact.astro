---
import PagePhotoShowcase from '../components/visuals/PagePhotoShowcase.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const contactEmail = 'melan@livdapps.com';

const title = 'Contact Chiffr | Logiciel devis facture artisans énergie';
const description =
  'Contactez Chiffr ou démarrez l’essai : logiciel de devis, factures, modèles métier, signature, acompte et suivi client pour artisans énergie.';

const trades = [
  'Pompe à chaleur',
  'Climatisation',
  'Chauffage',
  'Frigoriste / CVC',
  'VMC',
  'IRVE',
  'Photovoltaïque',
  'Chauffe-eau thermodynamique',
  'Autre métier énergie',
];

const targetProfiles = [
  'Artisans pompe à chaleur et PAC air/eau',
  'Installateurs climatisation monosplit et multisplit',
  'Chauffagistes, frigoristes et CVC',
  'Artisans VMC, IRVE et photovoltaïque',
  'Entreprises qui veulent des devis plus rapides, plus propres et mieux suivis',
];

const quickLinks = [
  { label: 'Modèles de devis', href: '/modeles-devis' },
  { label: 'Fonctionnalités', href: '/fonctionnalites' },
  { label: 'Tarifs', href: '/tarifs' },
  { label: 'Pompe à chaleur', href: '/logiciel-devis-pompe-a-chaleur' },
  { label: 'Climatisation', href: '/logiciel-devis-climatisation' },
  { label: 'IRVE', href: '/logiciel-devis-irve' },
];

const faqs = [
  {
    question: 'Comment contacter Chiffr ?',
    answer:
      `Vous pouvez envoyer un message depuis cette page ou écrire directement à ${contactEmail}.`,
  },
  {
    question: 'Chiffr est-il adapté à mon métier ?',
    answer:
      'Chiffr est pensé pour les artisans énergie : pompe à chaleur, climatisation, chauffage, CVC, VMC, IRVE, photovoltaïque et chauffe-eau thermodynamique.',
  },
  {
    question: 'Puis-je tester Chiffr ?',
    answer:
      'Oui. Le site renvoie vers l’app Chiffr pour démarrer l’essai quand elle est disponible.',
  },
  {
    question: 'Les modèles de devis sont-ils modifiables ?',
    answer:
      'Oui. Chiffr prépare une structure métier, mais l’artisan garde la main sur les lignes, les prix, les quantités, les options, les conditions et les remarques.',
  },
  {
    question: 'Chiffr remplace-t-il Word ou Excel ?',
    answer:
      'Oui, l’objectif est de remplacer les devis bricolés dans Word ou Excel par un outil métier plus guidé : modèles, PDF premium, signature, acompte, factures et suivi client.',
  },
];

const contactSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Contact Chiffr',
  description,
  url: 'https://chiffr-devis.fr/contact',
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath="/contact"
  schema={[contactSchema, faqSchema]}
>
  <style is:inline>
    .contact-page,
    .contact-page * {
      box-sizing: border-box;
    }

    .contact-page {
      color: var(--ink);
      overflow: hidden;
    }

    .contact-shell {
      width: 100%;
      max-width: 1280px;
      margin: 0 auto;
    }

    .contact-narrow {
      max-width: 900px;
    }

    .contact-hero,
    .contact-section,
    .contact-cta {
      position: relative;
      padding: 72px 20px;
    }

    .contact-hero {
      padding-top: 88px;
      padding-bottom: 76px;
    }

    .contact-hero::before {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      background:
        radial-gradient(circle at 12% 12%, rgba(183, 110, 60, 0.14), transparent 30%),
        radial-gradient(circle at 88% 18%, rgba(18, 63, 61, 0.12), transparent 32%);
    }

    .contact-grid {
      position: relative;
      z-index: 1;
      display: grid;
      gap: 46px;
      align-items: center;
    }

    .contact-pill,
    .contact-kicker {
      display: inline-flex;
      width: fit-content;
      margin: 0;
      padding: 8px 14px;
      border-radius: 999px;
      border: 1px solid rgba(18, 63, 61, 0.12);
      background: rgba(255, 255, 255, 0.78);
      color: var(--teal);
      font-size: 14px;
      line-height: 1.3;
      font-weight: 850;
    }

    .contact-kicker {
      padding: 0;
      border: 0;
      background: transparent;
      color: var(--copper);
      font-size: 15px;
    }

    .contact-page h1 {
      margin: 26px 0 0;
      max-width: 820px;
      color: var(--teal);
      font-size: clamp(42px, 5.4vw, 76px);
      line-height: 1;
      letter-spacing: -0.055em;
      font-weight: 950;
    }

    .contact-lead {
      margin: 22px 0 0;
      max-width: 720px;
      color: #536866;
      font-size: 20px;
      line-height: 1.7;
    }

    .contact-actions {
      margin-top: 30px;
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
    }

    .contact-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 52px;
      border-radius: 999px;
      padding: 16px 24px;
      border: 0;
      font: inherit;
      font-weight: 950;
      line-height: 1;
      cursor: pointer;
      transition: transform 180ms ease, box-shadow 180ms ease, background 180ms ease;
    }

    .contact-btn.primary {
      color: white;
      background: var(--teal);
      box-shadow: 0 18px 38px rgba(18, 63, 61, 0.18);
    }

    .contact-btn.primary:hover {
      transform: translateY(-2px);
      background: #0d302e;
      box-shadow: 0 24px 48px rgba(18, 63, 61, 0.22);
    }

    .contact-btn.secondary {
      color: var(--teal);
      background: rgba(255, 255, 255, 0.82);
      border: 1px solid rgba(18, 63, 61, 0.14);
    }

    .contact-btn.secondary:hover {
      transform: translateY(-2px);
      background: white;
      box-shadow: 0 18px 38px rgba(18, 63, 61, 0.08);
    }

    .contact-card,
    .contact-panel,
    .contact-form-card,
    .contact-link-card,
    .contact-faq-card {
      border: 1px solid rgba(18, 63, 61, 0.12);
      background:
        linear-gradient(145deg, rgba(255, 253, 249, 0.96), rgba(255, 255, 255, 0.86)),
        radial-gradient(circle at top right, rgba(183, 110, 60, 0.1), transparent 44%);
      box-shadow:
        0 26px 74px rgba(18, 63, 61, 0.1),
        inset 0 1px 0 rgba(255, 255, 255, 0.9);
    }

    .contact-form-card {
      border-radius: 36px;
      padding: 34px;
    }

    .contact-form-card h2 {
      margin: 0;
      color: var(--teal);
      font-size: clamp(32px, 3vw, 46px);
      line-height: 1.06;
      letter-spacing: -0.045em;
      font-weight: 950;
    }

    .contact-form-card > p {
      margin: 14px 0 0;
      color: #536866;
      font-size: 16px;
      line-height: 1.6;
    }

    .contact-form {
      margin-top: 24px;
      display: grid;
      gap: 16px;
    }

    .form-field {
      display: grid;
      gap: 7px;
    }

    .form-field label {
      color: var(--teal);
      font-size: 13px;
      font-weight: 950;
    }

    .form-field input,
    .form-field select,
    .form-field textarea {
      width: 100%;
      border: 1px solid rgba(18, 63, 61, 0.13);
      border-radius: 18px;
      background: rgba(255, 253, 249, 0.78);
      color: var(--ink);
      font: inherit;
      font-size: 15px;
      line-height: 1.4;
      outline: none;
      transition: border-color 180ms ease, box-shadow 180ms ease, background 180ms ease;
    }

    .form-field input,
    .form-field select {
      height: 54px;
      padding: 0 16px;
    }

    .form-field textarea {
      min-height: 150px;
      resize: vertical;
      padding: 15px 16px;
    }

    .form-field input::placeholder,
    .form-field textarea::placeholder {
      color: rgba(83, 104, 102, 0.58);
    }

    .form-field input:focus,
    .form-field select:focus,
    .form-field textarea:focus {
      border-color: rgba(183, 110, 60, 0.78);
      background: white;
      box-shadow: 0 0 0 4px rgba(183, 110, 60, 0.12);
    }

    .form-help {
      margin: 2px 0 0;
      color: #667977;
      font-size: 13px;
      line-height: 1.45;
      text-align: center;
      font-weight: 700;
    }

    .contact-target-card {
      margin-top: 28px;
      padding: 28px;
      border-radius: 30px;
      background: rgba(255, 255, 255, 0.72);
      border: 1px solid rgba(18, 63, 61, 0.1);
      box-shadow: 0 22px 60px rgba(18, 63, 61, 0.08);
    }

    .contact-target-card h2 {
      margin: 0;
      color: var(--teal);
      font-size: 34px;
      line-height: 1.05;
      letter-spacing: -0.04em;
      font-weight: 950;
    }

    .target-list {
      margin: 20px 0 0;
      padding: 0;
      list-style: none;
      display: grid;
      gap: 12px;
    }

    .target-list li {
      display: flex;
      gap: 10px;
      align-items: flex-start;
      color: #536866;
      font-size: 15px;
      line-height: 1.45;
      font-weight: 750;
    }

    .target-list li::before {
      content: "✓";
      display: grid;
      place-items: center;
      width: 22px;
      height: 22px;
      flex: none;
      border-radius: 999px;
      background: rgba(47, 143, 107, 0.13);
      color: var(--success);
      font-size: 12px;
      font-weight: 950;
    }

    .section-head {
      max-width: 860px;
      margin-bottom: 30px;
    }

    .section-head h2,
    .contact-panel h2,
    .contact-cta h2 {
      margin: 14px 0 0;
      color: var(--teal);
      font-size: clamp(34px, 3.8vw, 56px);
      line-height: 1.06;
      letter-spacing: -0.048em;
      font-weight: 950;
    }

    .section-head p,
    .contact-panel p,
    .contact-cta p {
      margin: 14px 0 0;
      color: #536866;
      font-size: 18px;
      line-height: 1.65;
    }

    .contact-split {
      display: grid;
      gap: 22px;
    }

    .contact-panel {
      border-radius: 34px;
      padding: 34px;
    }

    .contact-panel.dark {
      background: var(--teal);
      color: white;
    }

    .contact-panel.dark h2 {
      color: white;
    }

    .contact-panel.dark p {
      color: rgba(255, 255, 255, 0.74);
    }

    .contact-panel-list {
      margin-top: 20px;
      display: grid;
      gap: 10px;
    }

    .contact-panel-card {
      padding: 15px 16px;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.72);
      border: 1px solid rgba(18, 63, 61, 0.08);
    }

    .contact-panel.dark .contact-panel-card {
      background: rgba(255, 255, 255, 0.1);
      border-color: rgba(255, 255, 255, 0.14);
    }

    .contact-panel-card strong {
      display: block;
      color: var(--teal);
      font-size: 14px;
      font-weight: 950;
    }

    .contact-panel.dark .contact-panel-card strong {
      color: white;
    }

    .contact-panel-card p {
      margin-top: 5px;
      font-size: 14px;
      line-height: 1.5;
    }

    .contact-links-grid {
      display: grid;
      gap: 14px;
    }

    .contact-link-card {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 14px;
      border-radius: 22px;
      padding: 17px 18px;
      color: var(--teal);
      font-weight: 950;
      transition: transform 180ms ease, background 180ms ease, box-shadow 180ms ease;
    }

    .contact-link-card:hover {
      transform: translateY(-3px);
      background: white;
      box-shadow: 0 18px 46px rgba(18, 63, 61, 0.09);
    }

    .contact-link-card span {
      color: var(--copper);
      font-weight: 950;
    }

    .faq-list {
      display: grid;
      gap: 14px;
    }

    .contact-faq-card {
      border-radius: 26px;
      padding: 22px 24px;
      transition: transform 180ms ease, background 180ms ease, box-shadow 180ms ease;
    }

    .contact-faq-card:hover {
      transform: translateY(-2px);
      background: white;
      box-shadow: 0 18px 46px rgba(18, 63, 61, 0.08);
    }

    .contact-faq-card summary {
      cursor: pointer;
      color: var(--teal);
      font-size: 18px;
      line-height: 1.4;
      letter-spacing: -0.015em;
      font-weight: 900;
    }

    .contact-faq-card p {
      margin: 14px 0 0;
      color: #536866;
      font-size: 16px;
      line-height: 1.7;
    }

    .contact-cta {
      text-align: center;
    }

    .contact-cta .contact-shell {
      padding: 50px 28px;
      border-radius: 38px;
      border: 1px solid rgba(18, 63, 61, 0.1);
      background:
        radial-gradient(circle at 20% 0%, rgba(183, 110, 60, 0.13), transparent 36%),
        linear-gradient(145deg, rgba(255, 255, 255, 0.78), rgba(255, 253, 249, 0.86));
      box-shadow: 0 26px 78px rgba(18, 63, 61, 0.1);
    }

    .contact-cta .contact-btn {
      margin-top: 24px;
    }

    .direct-email {
      margin-top: 14px;
      color: #536866;
      font-size: 14px;
      line-height: 1.55;
      font-weight: 750;
    }

    .direct-email a {
      color: var(--teal);
      font-weight: 950;
      text-decoration: underline;
      text-decoration-color: rgba(18, 63, 61, 0.22);
      text-underline-offset: 3px;
    }

    .reveal,
    .reveal-card {
      opacity: 0;
      transform: translateY(18px);
      transition: opacity 620ms ease, transform 620ms cubic-bezier(0.16, 1, 0.3, 1);
    }

    .reveal.visible,
    .reveal-card.visible {
      opacity: 1;
      transform: translateY(0);
    }

    @media (min-width: 760px) {
      .contact-links-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (min-width: 1020px) {
      .contact-grid {
        grid-template-columns: 0.95fr 1.05fr;
      }

      .contact-split {
        grid-template-columns: 1fr 1fr;
      }

      .contact-links-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    @media (max-width: 720px) {
      .contact-hero,
      .contact-section,
      .contact-cta {
        padding: 52px 18px;
      }

      .contact-hero {
        padding-top: 58px;
      }

      .contact-page h1 {
        font-size: clamp(40px, 14vw, 58px);
      }

      .contact-lead {
        font-size: 18px;
      }

      .contact-actions {
        display: grid;
      }

      .contact-btn {
        width: 100%;
      }

      .contact-form-card,
      .contact-panel {
        padding: 24px;
        border-radius: 28px;
      }

      .contact-target-card {
        padding: 22px;
        border-radius: 26px;
      }

      .contact-target-card h2 {
        font-size: 28px;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .contact-page *,
      .contact-page *::before,
      .contact-page *::after {
        transition-duration: 0.001ms !important;
        animation-duration: 0.001ms !important;
        animation-iteration-count: 1 !important;
      }

      .reveal,
      .reveal-card {
        opacity: 1;
        transform: none;
      }
    }
  </style>

  <div class="contact-page">
    <section class="contact-hero">
      <div class="contact-shell contact-grid">
        <div class="reveal">
          <p class="contact-pill">Contact Chiffr</p>

          <h1>Une question sur Chiffr ?</h1>

          <p class="contact-lead">
            Vous êtes artisan PAC, clim, chauffage, CVC, VMC, IRVE ou solaire ?
            Écrivez-nous pour poser une question, signaler un besoin métier ou préparer
            votre arrivée sur Chiffr.
          </p>

          <div class="contact-target-card">
            <h2>Chiffr est pensé pour</h2>

            <ul class="target-list">
              {targetProfiles.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>

          <div class="contact-actions">
            <a href="mailto:melan@livdapps.com" class="contact-btn primary">
              Écrire à Chiffr
            </a>

            <a href={`mailto:${contactEmail}?subject=Question%20sur%20Chiffr`} class="contact-btn secondary">
              Écrire directement
            </a>
          </div>
        </div>

        <aside class="contact-form-card reveal" aria-label="Formulaire de contact Chiffr">
          <h2>Nous écrire</h2>

          <p>
            Indiquez votre métier et ce que vous voulez améliorer dans vos devis,
            factures ou suivis client.
          </p>

          <form class="contact-form" data-contact-form>
            <div class="form-field">
              <label for="name">Nom</label>
              <input
                id="name"
                name="name"
                type="text"
                placeholder="Votre nom"
                autocomplete="name"
              />
            </div>

            <div class="form-field">
              <label for="email">Email</label>
              <input
                id="email"
                name="email"
                type="email"
                placeholder="vous@entreprise.fr"
                autocomplete="email"
              />
            </div>

            <div class="form-field">
              <label for="trade">Métier principal</label>
              <select id="trade" name="trade">
                {trades.map((trade) => (
                  <option value={trade}>{trade}</option>
                ))}
              </select>
            </div>

            <div class="form-field">
              <label for="message">Message</label>
              <textarea
                id="message"
                name="message"
                placeholder="Ex : devis PAC plus rapides, PDF plus propres, factures d’acompte, relances client..."
              ></textarea>
            </div>

            <button type="submit" class="contact-btn primary">
              Envoyer le message
            </button>

            <p class="form-help">
              Pas de spam. Votre message ouvrira votre application mail avec un email prérempli.
            </p>
          </form>

          <p class="direct-email">
            Email direct :
            <a href={`mailto:${contactEmail}?subject=Question%20sur%20Chiffr`}>
              {contactEmail}
            </a>
          </p>
        </aside>
      </div>
    </section>

    <section class="contact-section">
      <div class="contact-shell">
        <PagePhotoShowcase
          variant="contact"
          eyebrow="Contact terrain"
          title="Parlez-nous de votre métier, pas d’un logiciel abstrait"
          text="PAC, climatisation, chauffage, CVC, VMC, IRVE ou solaire : expliquez ce que vous voulez améliorer dans vos devis, factures ou suivis client."
          ctaLabel="Écrire à Chiffr"
          ctaHref="mailto:melan@livdapps.com"
        />
      </div>
    </section>


    <section class="contact-section">
      <div class="contact-shell contact-split">
        <article class="contact-panel dark reveal">
          <p class="contact-kicker">Pour qui ?</p>
          <h2>Chiffr n’est pas un logiciel générique déguisé.</h2>
          <p>
            Le site, les modèles et l’app sont pensés autour des artisans énergie :
            devis terrain, photos chantier, PDF clair, signature, acompte et facturation.
          </p>

          <div class="contact-panel-list">
            <div class="contact-panel-card">
              <strong>PAC, clim, chauffage</strong>
              <p>Des devis avec matériel, pose, raccordements, mise en service et options.</p>
            </div>

            <div class="contact-panel-card">
              <strong>VMC, IRVE, solaire</strong>
              <p>Des modèles concrets avec les points à vérifier avant envoi au client.</p>
            </div>
          </div>
        </article>

        <article class="contact-panel reveal">
          <p class="contact-kicker">À retenir</p>
          <h2>Chiffr propose la structure, l’artisan garde le contrôle.</h2>
          <p>
            Les modèles ne remplacent pas votre expertise. Ils vous aident à aller plus vite,
            éviter les oublis et présenter un devis plus professionnel.
          </p>

          <div class="contact-panel-list">
            <div class="contact-panel-card">
              <strong>Prix à adapter</strong>
              <p>Vous gardez vos tarifs, vos marges, vos conditions et vos habitudes.</p>
            </div>

            <div class="contact-panel-card">
              <strong>Actions guidées</strong>
              <p>Après le devis : signature, acompte, facture, relance et suivi client.</p>
            </div>
          </div>
        </article>
      </div>
    </section>

    <section class="contact-section">
      <div class="contact-shell">
        <div class="section-head reveal">
          <p class="contact-kicker">Pages utiles</p>
          <h2>Retrouvez les ressources avant de nous écrire</h2>
          <p>
            Ces pages répondent déjà aux questions fréquentes sur les métiers,
            les modèles, les fonctions et les tarifs.
          </p>
        </div>

        <div class="contact-links-grid">
          {quickLinks.map((link) => (
            <a href={link.href} class="contact-link-card reveal-card">
              {link.label}
              <span>→</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="contact-cta">
      <div class="contact-shell contact-narrow reveal">
        <p class="contact-kicker">Accéder à Chiffr</p>
        <h2>Le plus simple est de commencer avec un modèle métier.</h2>
        <p>
          Choisissez votre métier, partez d’un devis adapté, ajoutez vos lignes,
          vos photos, puis envoyez un PDF clair à votre client.
        </p>

        <a href="mailto:melan@livdapps.com" class="contact-btn primary">
          Écrire à Chiffr
        </a>
      </div>
    </section>

    <section class="contact-section">
      <div class="contact-shell contact-narrow">
        <div class="section-head reveal">
          <p class="contact-kicker">Questions fréquentes</p>
          <h2>Contact Chiffr : les réponses utiles</h2>
        </div>

        <div class="faq-list">
          {faqs.map((item) => (
            <details class="contact-faq-card reveal-card">
              <summary>{item.question}</summary>
              <p>{item.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  </div>

  <script is:inline>
    const contactForm = document.querySelector('[data-contact-form]');

    contactForm?.addEventListener('submit', (event) => {
      event.preventDefault();

      const formData = new FormData(contactForm);
      const name = String(formData.get('name') || '').trim();
      const email = String(formData.get('email') || '').trim();
      const trade = String(formData.get('trade') || '').trim();
      const message = String(formData.get('message') || '').trim();

      const subject = `Question sur Chiffr - ${trade || 'Contact site'}`;

      const body = [
        'Bonjour,',
        '',
        'Je vous contacte depuis le site Chiffr.',
        '',
        `Nom : ${name || 'Non renseigné'}`,
        `Email : ${email || 'Non renseigné'}`,
        `Métier principal : ${trade || 'Non renseigné'}`,
        '',
        'Message :',
        message || 'Non renseigné',
        '',
        '---',
        'Envoyé depuis chiffr-devis.fr/contact',
      ].join('\n');

      const mailtoUrl = `mailto:melan@livdapps.com?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;

      window.location.href = mailtoUrl;
    });

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const items = document.querySelectorAll('.reveal, .reveal-card');

    if (reduce) {
      items.forEach((item) => item.classList.add('visible'));
    } else {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          });
        },
        { threshold: 0.12, rootMargin: '0px 0px -30px 0px' }
      );

      items.forEach((item) => observer.observe(item));
    }
  </script>
</BaseLayout>