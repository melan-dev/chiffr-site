---
import PagePhotoShowcase from '../components/visuals/PagePhotoShowcase.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { APP_URL } from '../config';

const contactEmail = 'melan@livdapps.com';

const title = 'Contact Chiffr | Parler à un expert du devis énergie';
const description =
  'Une question, une démo, un cas particulier ? Parlez à quelqu’un qui connaît le devis énergie (PAC, clim, chauffage, CVC, VMC, IRVE, solaire). Réponse sous 24 h, sans spam.';

const trades = [
  'Pompe à chaleur / PAC',
  'Climatisation',
  'Chauffage',
  'Frigoriste / CVC',
  'VMC',
  'IRVE / borne de recharge',
  'Photovoltaïque / solaire',
  'Chauffe-eau thermodynamique',
  'Plomberie chauffage',
  'Autre métier énergie',
];

const priorities = [
  'Créer des devis plus vite',
  'Avoir des modèles métier plus adaptés',
  'Faire des PDF plus professionnels',
  'Joindre des photos chantier au devis',
  'Faire signer les devis',
  'Demander un acompte',
  'Créer facture d’acompte / solde / finale',
  'Relancer les devis et suivre les clients',
];

const accessReasons = [
  {
    title: 'Vous faites des devis techniques',
    text: 'PAC, clim, chauffage, CVC, VMC, IRVE ou solaire : Chiffr part de vos vrais postes métier, pas d’une page blanche.',
  },
  {
    title: 'Vous voulez gagner du temps sans perdre le contrôle',
    text: 'Les modèles préparent les lignes, mais vous gardez vos prix, vos marges, vos marques, vos conditions et vos habitudes.',
  },
  {
    title: 'Vous voulez mieux suivre après l’envoi',
    text: 'Signature, acompte, facture d’acompte, facture de solde, relance et dossier client restent au même endroit.',
  },
];

const processSteps = [
  {
    label: '1',
    title: 'Vous expliquez votre métier',
    text: 'Métier principal, types de devis, blocages actuels et fonctions les plus importantes pour vous.',
  },
  {
    label: '2',
    title: 'On qualifie votre besoin',
    text: 'On regarde si Chiffr correspond à votre usage : terrain, bureau, modèles, photos, factures et suivi client.',
  },
  {
    label: '3',
    title: 'On prépare l’accès',
    text: 'L’objectif est de vous orienter vers une base métier cohérente plutôt qu’un logiciel générique à configurer seul.',
  },
];

const targetProfiles = [
  'Artisans PAC air/eau, PAC air/air et remplacement chaudière',
  'Installateurs climatisation monosplit et multisplit',
  'Chauffagistes, frigoristes et professionnels CVC',
  'Artisans VMC, IRVE, photovoltaïque et chauffe-eau thermodynamique',
  'Entreprises qui veulent des devis, factures et relances plus propres',
];

const quickLinks = [
  { label: 'Logiciel devis pompe à chaleur', href: '/logiciel-devis-pompe-a-chaleur' },
  { label: 'Logiciel devis climatisation', href: '/logiciel-devis-climatisation' },
  { label: 'Modèles de devis', href: '/modeles-devis' },
  { label: 'Fonctionnalités', href: '/fonctionnalites' },
  { label: 'Tarifs', href: '/tarifs' },
  { label: 'Alternatives logiciels devis', href: '/alternatives-logiciels-devis-batiment' },
];

const reassuranceItems = [
  'Réponse sous 24 h ouvrées — pas de démarchage agressif.',
  'On ne vous piste pas : contact par e-mail direct, zéro tracking.',
  'On parle PAC et acompte, pas « synergies » et « onboarding ».',
];

const faqs = [
  {
    question: 'Comment demander un accès à Chiffr ?',
    answer:
      `Remplissez le formulaire ou écrivez directement à ${contactEmail} en indiquant votre métier, vos types de devis et ce que vous voulez améliorer : modèles, photos, signature, acompte, factures ou relances.`,
  },
  {
    question: 'À qui s’adresse Chiffr ?',
    answer:
      'Chiffr est pensé pour les artisans énergie : pompe à chaleur, climatisation, chauffage, frigoriste / CVC, VMC, IRVE, photovoltaïque et chauffe-eau thermodynamique.',
  },
  {
    question: 'Est-ce que Chiffr est un logiciel généraliste bâtiment ?',
    answer:
      'Non. Chiffr se positionne comme un logiciel de devis et factures spécialisé artisans énergie, avec des modèles et lignes métier plus concrets pour PAC, clim, chauffage, VMC, IRVE et solaire.',
  },
  {
    question: 'Les modèles de devis sont-ils modifiables ?',
    answer:
      'Oui. Chiffr prépare une structure métier, mais l’artisan garde la main sur les lignes, les prix, les quantités, les marques, la TVA, les conditions et les remarques.',
  },
  {
    question: 'Pourquoi demander mon métier dans le formulaire ?',
    answer:
      'Parce que Chiffr ne cherche pas à vous donner une page blanche. Votre métier permet de comprendre les modèles, lignes de devis et actions qui doivent être prioritaires pour votre usage.',
  },
  {
    question: 'Puis-je écrire directement par email ?',
    answer:
      `Oui. Vous pouvez écrire directement à ${contactEmail}. Le formulaire sert simplement à préparer un email plus complet avec les informations utiles.`,
  },
];

const contactSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Demander un accès Chiffr',
  description,
  url: 'https://chiffr-devis.fr/contact',
  mainEntity: {
    '@type': 'Organization',
    name: 'Chiffr',
    url: 'https://chiffr-devis.fr',
    email: contactEmail,
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath="/contact"
  schema={[contactSchema, faqSchema]}
>
  <style is:global>
    .access-page,
    .access-page * {
      box-sizing: border-box;
    }

    .access-page {
      color: var(--ink);
      overflow: hidden;
    }

    .access-shell {
      width: 100%;
      max-width: 1240px;
      margin: 0 auto;
    }

    .access-narrow {
      max-width: 920px;
    }

    .access-hero,
    .access-section,
    .access-cta {
      position: relative;
      padding: 76px 20px;
    }

    .access-hero {
      padding-top: 94px;
      background:
        radial-gradient(circle at 88% 18%, rgba(12, 20, 32, 0.12), transparent 32%);
    }

    .access-grid {
      display: grid;
      gap: 42px;
      align-items: start;
    }

    .access-pill,
    .access-kicker {
      display: inline-flex;
      width: fit-content;
      margin: 0;
      padding: 8px 14px;
      border-radius: 999px;
      border: 1px solid rgba(12, 20, 32, 0.12);
      background: rgba(255, 255, 255, 0.78);
      color: var(--teal);
      font-size: 14px;
      line-height: 1.3;
      font-weight: 650;
    }

    .access-kicker {
      padding: 0;
      border: 0;
      background: transparent;
      color: var(--copper);
      font-size: 15px;
    }

    .access-page h1 {
      margin: 24px 0 0;
      max-width: 860px;
      color: var(--teal);
      font-size: clamp(44px, 6vw, 84px);
      line-height: 0.98;
      letter-spacing: -0.02em;
      font-weight: 650;
    }

    .access-lead {
      margin: 24px 0 0;
      max-width: 760px;
      color: #5F6673;
      font-size: clamp(18px, 2vw, 21px);
      line-height: 1.72;
      font-weight: 500;
    }

    .access-actions {
      margin-top: 32px;
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
    }

    .access-btn {
      min-height: 54px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      border: 0;
      border-radius: 999px;
      padding: 0 22px;
      font: inherit;
      font-size: 15px;
      line-height: 1;
      font-weight: 650;
      cursor: pointer;
      transition: transform 180ms ease, box-shadow 180ms ease, background 180ms ease;
    }

    .access-btn.primary {
      background: var(--teal);
      color: white;
      box-shadow: 0 18px 46px rgba(12, 20, 32, 0.2);
    }

    .access-btn.secondary {
      background: rgba(255, 255, 255, 0.76);
      color: var(--teal);
      border: 1px solid rgba(12, 20, 32, 0.12);
    }

    .access-btn:hover {
      transform: translateY(-2px);
    }

    .access-self-serve {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      margin-top: 16px;
      color: var(--teal);
      font-size: 15px;
      font-weight: 650;
    }

    .access-self-serve:hover {
      gap: 11px;
    }

    .access-proof {
      margin-top: 26px;
      display: grid;
      gap: 10px;
    }

    .access-proof span {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      color: #5F6673;
      font-size: 14px;
      line-height: 1.45;
      font-weight: 600;
    }

    .access-proof span::before {
      content: "✓";
      width: 22px;
      height: 22px;
      display: grid;
      place-items: center;
      flex: none;
      border-radius: 999px;
      background: rgba(47, 125, 70, 0.13);
      color: var(--success);
      font-size: 12px;
      font-weight: 650;
    }

    .access-form-card {
      position: relative;
      border-radius: 24px;
      padding: clamp(24px, 4vw, 34px);
      background:
        linear-gradient(145deg, rgba(255, 255, 255, 0.92), rgba(255, 252, 247, 0.82));
      border: 1px solid rgba(12, 20, 32, 0.12);
      box-shadow:
        0 30px 90px rgba(12, 20, 32, 0.13),
        inset 0 1px 0 rgba(255, 255, 255, 0.9);
    }

    .form-badge {
      width: fit-content;
      display: inline-flex;
      margin: 0 0 18px;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(230, 241, 240, 0.72);
      color: var(--teal);
      font-size: 12px;
      line-height: 1;
      font-weight: 650;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    .access-form-card h2,
    .access-section-head h2,
    .access-panel h2,
    .access-cta h2 {
      margin: 0;
      color: var(--teal);
      font-size: clamp(32px, 3.7vw, 54px);
      line-height: 1.06;
      letter-spacing: -0.02em;
      font-weight: 650;
    }

    .access-form-card > p,
    .access-section-head p,
    .access-panel p,
    .access-cta p {
      margin: 14px 0 0;
      color: #5F6673;
      font-size: 17px;
      line-height: 1.64;
      font-weight: 500;
    }

    .access-form {
      margin-top: 24px;
      display: grid;
      gap: 16px;
    }

    /* Formulaire progressif (audit conversion) : 2 champs visibles, le reste
       se déplie à la 1re interaction. Sans JS, tout reste visible. */
    .form-step-hint {
      margin: 0;
      color: var(--teal);
      font-size: 13px;
      font-weight: 650;
    }

    .access-form.is-expanded .form-step-hint {
      display: none;
    }

    .form-rest {
      display: grid;
      gap: 16px;
    }

    .access-form.is-progressive:not(.is-expanded) .form-rest {
      display: none;
    }

    .form-row {
      display: grid;
      gap: 14px;
    }

    .form-field {
      display: grid;
      gap: 8px;
    }

    .form-field label,
    .need-label {
      color: var(--teal);
      font-size: 14px;
      line-height: 1.2;
      font-weight: 650;
    }

    .form-field input,
    .form-field select,
    .form-field textarea {
      width: 100%;
      border: 1px solid rgba(12, 20, 32, 0.13);
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.84);
      color: var(--ink);
      font: inherit;
      font-size: 15px;
      line-height: 1.4;
      outline: none;
      transition: border-color 180ms ease, box-shadow 180ms ease, background 180ms ease;
    }

    .form-field input,
    .form-field select {
      height: 54px;
      padding: 0 16px;
    }

    .form-field textarea {
      min-height: 142px;
      resize: vertical;
      padding: 15px 16px;
    }

    .form-field input::placeholder,
    .form-field textarea::placeholder {
      color: rgba(83, 104, 102, 0.58);
    }

    .form-field input:focus,
    .form-field select:focus,
    .form-field textarea:focus {
      border-color: rgba(185, 97, 52, 0.78);
      background: white;
      box-shadow: 0 0 0 4px rgba(185, 97, 52, 0.12);
    }

    .need-grid {
      display: grid;
      gap: 9px;
      margin-top: 8px;
    }

    .need-chip {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 12px 13px;
      border-radius: 17px;
      border: 1px solid rgba(12, 20, 32, 0.1);
      background: rgba(255, 255, 255, 0.72);
      color: #5F6673;
      font-size: 13px;
      line-height: 1.28;
      font-weight: 600;
      cursor: pointer;
    }

    .need-chip input {
      width: 17px;
      height: 17px;
      accent-color: var(--teal);
      flex: none;
    }

    .form-help {
      margin: 0;
      color: #5F6673;
      font-size: 13px;
      line-height: 1.48;
      font-weight: 550;
    }

    .form-feedback {
      display: none;
      margin: 0;
      padding: 13px 14px;
      border-radius: 16px;
      background: rgba(47, 125, 70, 0.1);
      color: var(--teal);
      font-size: 13px;
      line-height: 1.42;
      font-weight: 600;
      border: 1px solid rgba(47, 125, 70, 0.16);
    }

    .form-feedback.visible {
      display: block;
    }

    .direct-card {
      margin-top: 20px;
      padding: 18px;
      border-radius: 16px;
      background: rgba(230, 241, 240, 0.58);
      border: 1px solid rgba(12, 20, 32, 0.1);
    }

    .direct-card strong {
      display: block;
      color: var(--teal);
      font-size: 14px;
      font-weight: 650;
    }

    .direct-card a {
      display: inline-flex;
      margin-top: 7px;
      color: var(--teal);
      font-weight: 650;
      text-decoration: underline;
      text-underline-offset: 3px;
      text-decoration-color: rgba(12, 20, 32, 0.22);
    }

    .access-section-head {
      max-width: 850px;
      margin-bottom: 30px;
    }

    .reason-grid,
    .process-grid,
    .links-grid,
    .faq-list {
      display: grid;
      gap: 16px;
    }

    .reason-card,
    .process-card,
    .link-card,
    .faq-card {
      border-radius: 18px;
      padding: 24px;
      background: rgba(255, 255, 255, 0.74);
      border: 1px solid rgba(12, 20, 32, 0.1);
      box-shadow: 0 20px 56px rgba(12, 20, 32, 0.07);
    }

    .reason-card strong,
    .process-card strong {
      display: block;
      color: var(--teal);
      font-size: 18px;
      line-height: 1.25;
      font-weight: 650;
      letter-spacing: -0.02em;
    }

    .reason-card p,
    .process-card p {
      margin: 10px 0 0;
      color: #5F6673;
      font-size: 15px;
      line-height: 1.58;
      font-weight: 500;
    }

    .process-card span {
      width: 38px;
      height: 38px;
      display: grid;
      place-items: center;
      margin-bottom: 16px;
      border-radius: 14px;
      background: var(--teal);
      color: white;
      font-weight: 650;
    }

    .access-split {
      display: grid;
      gap: 22px;
    }

    .access-panel {
      border-radius: 24px;
      padding: 34px;
      background: rgba(255, 255, 255, 0.74);
      border: 1px solid rgba(12, 20, 32, 0.1);
    }

    .access-panel.dark {
      background:
        var(--teal);
      color: white;
    }

    .access-panel.dark h2 {
      color: white;
    }

    .access-panel.dark p {
      color: rgba(255, 255, 255, 0.75);
    }

    .target-list {
      margin: 22px 0 0;
      padding: 0;
      list-style: none;
      display: grid;
      gap: 12px;
    }

    .target-list li {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      color: #5F6673;
      font-size: 15px;
      line-height: 1.45;
      font-weight: 550;
    }

    .access-panel.dark .target-list li {
      color: rgba(255, 255, 255, 0.78);
    }

    .target-list li::before {
      content: "✓";
      width: 22px;
      height: 22px;
      display: grid;
      place-items: center;
      flex: none;
      border-radius: 999px;
      background: rgba(47, 125, 70, 0.13);
      color: var(--success);
      font-size: 12px;
      font-weight: 650;
    }

    .access-panel.dark .target-list li::before {
      background: rgba(255, 255, 255, 0.14);
      color: #F6E7DB;
    }

    .link-card {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 14px;
      color: var(--teal);
      font-weight: 650;
      transition: transform 180ms ease, background 180ms ease, box-shadow 180ms ease;
    }

    .link-card:hover {
      transform: translateY(-3px);
      background: white;
      box-shadow: 0 22px 58px rgba(12, 20, 32, 0.1);
    }

    .link-card span {
      color: var(--copper);
      font-weight: 650;
    }

    .access-cta {
      text-align: center;
    }

    .access-cta-box {
      padding: 54px 28px;
      border-radius: 40px;
      background:
        linear-gradient(145deg, rgba(255, 255, 255, 0.78), rgba(255, 252, 247, 0.86));
      border: 1px solid rgba(12, 20, 32, 0.1);
      box-shadow: 0 28px 80px rgba(12, 20, 32, 0.1);
    }

    .access-cta .access-btn {
      margin-top: 24px;
    }

    .faq-card {
      padding: 22px 24px;
    }

    .faq-card summary {
      cursor: pointer;
      color: var(--teal);
      font-size: 18px;
      line-height: 1.4;
      letter-spacing: -0.015em;
      font-weight: 650;
    }

    .faq-card p {
      margin: 14px 0 0;
      color: #5F6673;
      font-size: 16px;
      line-height: 1.7;
    }

    .reveal,
    .reveal-card {
      opacity: 0;
      transform: translateY(18px);
      transition: opacity 620ms ease, transform 620ms cubic-bezier(0.16, 1, 0.3, 1);
    }

    .reveal.visible,
    .reveal-card.visible {
      opacity: 1;
      transform: translateY(0);
    }

    @media (min-width: 760px) {
      .form-row {
        grid-template-columns: repeat(2, 1fr);
      }

      .need-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .reason-grid,
      .process-grid,
      .links-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    @media (min-width: 1040px) {
      .access-grid {
        grid-template-columns: 0.9fr 1.1fr;
      }

      .access-split {
        grid-template-columns: 1fr 1fr;
      }
    }

    @media (max-width: 720px) {
      .access-hero,
      .access-section,
      .access-cta {
        padding: 54px 18px;
      }

      .access-hero {
        padding-top: 62px;
      }

      .access-actions {
        display: grid;
      }

      .access-btn {
        width: 100%;
      }

      .access-form-card,
      .access-panel {
        padding: 24px;
        border-radius: 18px;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .access-page *,
      .access-page *::before,
      .access-page *::after {
        transition-duration: 0.001ms !important;
        animation-duration: 0.001ms !important;
        animation-iteration-count: 1 !important;
      }

      .reveal,
      .reveal-card {
        opacity: 1;
        transform: none;
      }
    }
  </style>

  <div class="access-page">
    <section class="access-hero">
      <div class="access-shell access-grid">
        <div class="reveal">
          <p class="access-pill">Parler à un expert métier</p>

          <h1>Parlez-nous de vos devis. On répond énergie, pas logiciel générique.</h1>

          <p class="access-lead">
            Une question, une démo, un cas particulier (équipe, migration de vos modèles) ?
            Vous êtes artisan PAC, clim, chauffage, CVC, VMC, IRVE ou solaire : dites-nous ce
            que vous voulez améliorer, on vous répond sous 24 h ouvrées, sans spam.
          </p>

          <div class="access-actions">
            <a class="access-btn primary" href="#demande-acces">Poser ma question</a>
            <a class="access-btn secondary" href={`mailto:${contactEmail}?subject=Question%20Chiffr`}>
              Écrire directement
            </a>
          </div>

          <a class="access-self-serve" href={APP_URL}>
            Pressé ? Essayez Chiffr gratuitement tout de suite
            <span aria-hidden="true">→</span>
          </a>

          <div class="access-proof">
            {reassuranceItems.map((item) => <span>{item}</span>)}
          </div>
        </div>

        <aside id="demande-acces" class="access-form-card reveal" aria-label="Formulaire de demande d’accès Chiffr">
          <p class="form-badge">Votre demande</p>
          <h2>Parlez-nous de votre activité</h2>
          <p>
            Le formulaire prépare un email complet. Vous gardez la main avant l’envoi :
            il s’ouvrira dans votre application mail. Aucune donnée n’est envoyée sans vous.
          </p>

          <form class="access-form" data-access-form data-progressive>
            <p class="form-step-hint" data-step-hint>
              2 champs pour commencer — le reste se déplie ensuite.
            </p>

            <div class="form-row">
              <div class="form-field">
                <label for="trade">Votre métier *</label>
                <select id="trade" name="trade" required>
                  <option value="">Choisir un métier</option>
                  {trades.map((trade) => (
                    <option value={trade}>{trade}</option>
                  ))}
                </select>
              </div>

              <div class="form-field">
                <label for="email">Email *</label>
                <input
                  id="email"
                  name="email"
                  type="email"
                  placeholder="vous@entreprise.fr"
                  autocomplete="email"
                  required
                />
              </div>
            </div>

            <div class="form-rest" data-form-rest>
              <div class="form-row">
                <div class="form-field">
                  <label for="name">Nom</label>
                  <input
                    id="name"
                    name="name"
                    type="text"
                    placeholder="Votre nom"
                    autocomplete="name"
                  />
                </div>

                <div class="form-field">
                  <label for="company">Entreprise</label>
                  <input
                    id="company"
                    name="company"
                    type="text"
                    placeholder="Nom de votre entreprise"
                    autocomplete="organization"
                  />
                </div>
              </div>

              <div class="form-row">
                <div class="form-field">
                  <label for="phone">Téléphone</label>
                  <input
                    id="phone"
                    name="phone"
                    type="tel"
                    placeholder="06..."
                    autocomplete="tel"
                  />
                </div>

                <div class="form-field">
                  <label for="priority">Priorité principale</label>
                  <select id="priority" name="priority">
                    <option value="">Choisir une priorité</option>
                    {priorities.map((priority) => (
                      <option value={priority}>{priority}</option>
                    ))}
                  </select>
                </div>
              </div>

              <div>
                <p class="need-label">Ce que vous voulez améliorer</p>
                <div class="need-grid">
                  {priorities.slice(0, 6).map((need) => (
                    <label class="need-chip">
                      <input type="checkbox" name="needs" value={need} />
                      <span>{need}</span>
                    </label>
                  ))}
                </div>
              </div>

              <div class="form-field">
                <label for="message">Votre besoin</label>
                <textarea
                  id="message"
                  name="message"
                  placeholder="Ex : je fais surtout des devis PAC air/eau, je veux des modèles plus rapides, des photos chantier dans le PDF, la facture d’acompte et les relances..."
                ></textarea>
              </div>
            </div>

            <p class="form-feedback" data-form-feedback>
              Email préparé. Votre application mail va s’ouvrir pour que vous puissiez relire et envoyer.
            </p>

            <button type="submit" class="access-btn primary">
              Préparer ma demande d’accès
            </button>

            <p class="form-help">
              Les champs marqués * évitent les demandes incomplètes. Aucune inscription automatique :
              le message est préparé dans votre boîte mail.
            </p>
          </form>

          <div class="direct-card">
            <strong>Email direct</strong>
            <a href={`mailto:${contactEmail}?subject=Demande%20d%27acc%C3%A8s%20Chiffr`}>
              {contactEmail}
            </a>
          </div>
        </aside>
      </div>
    </section>

    <section class="access-section">
      <div class="access-shell">
        <div class="access-section-head reveal">
          <p class="access-kicker">Pourquoi nous écrire ?</p>
          <h2>Une demande utile commence par votre métier.</h2>
          <p>
            Chiffr est construit pour préparer les bons modèles, les bonnes lignes
            et les bonnes actions selon votre activité énergie.
          </p>
        </div>

        <div class="reason-grid">
          {accessReasons.map((item) => (
            <article class="reason-card reveal-card">
              <strong>{item.title}</strong>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="access-section">
      <div class="access-shell">
        <PagePhotoShowcase
          variant="contact"
          eyebrow="Contact terrain"
          title="Expliquez vos devis réels, pas un besoin abstrait"
          text="PAC air/eau, clim multisplit, VMC double flux, borne de recharge, chauffe-eau thermodynamique ou solaire : votre message nous aide à comprendre les modèles et actions qui comptent vraiment."
          ctaLabel="Remplir la demande"
          ctaHref="#demande-acces"
        />
      </div>
    </section>

    <section class="access-section">
      <div class="access-shell access-split">
        <article class="access-panel dark reveal">
          <p class="access-kicker">Pour qui ?</p>
          <h2>Chiffr cible les artisans énergie qui veulent du concret.</h2>
          <p>
            L’objectif n’est pas d’ajouter un outil lourd, mais de rendre les devis,
            factures et suivis client plus simples à produire et plus professionnels.
          </p>

          <ul class="target-list">
            {targetProfiles.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </article>

        <article class="access-panel reveal">
          <p class="access-kicker">Comment ça se passe ?</p>
          <h2>Une demande claire, puis un échange utile.</h2>
          <p>
            Votre message permet de comprendre vos devis actuels, vos priorités
            et les fonctions qui doivent vraiment vous faire gagner du temps.
          </p>

          <div class="process-grid">
            {processSteps.map((item) => (
              <article class="process-card">
                <span>{item.label}</span>
                <strong>{item.title}</strong>
                <p>{item.text}</p>
              </article>
            ))}
          </div>
        </article>
      </div>
    </section>

    <section class="access-section">
      <div class="access-shell">
        <div class="access-section-head reveal">
          <p class="access-kicker">Avant de demander l’accès</p>
          <h2>Les pages les plus utiles si vous voulez comparer.</h2>
          <p>
            Vous pouvez aussi parcourir les pages métier, les modèles de devis,
            les fonctionnalités et les tarifs avant de nous écrire.
          </p>
        </div>

        <div class="links-grid">
          {quickLinks.map((item) => (
            <a class="link-card reveal-card" href={item.href}>
              {item.label}
              <span>→</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="access-cta">
      <div class="access-shell access-narrow access-cta-box reveal">
        <p class="access-kicker">Demander un accès</p>
        <h2>Le plus simple : dites-nous votre métier et vos devis actuels.</h2>
        <p>
          On comprend mieux un besoin quand il part du terrain : type de chantier,
          modèles utilisés, photos, signature, acompte, factures, relances et suivi client.
        </p>

        <a href="#demande-acces" class="access-btn primary">
          Remplir la demande d’accès
        </a>
      </div>
    </section>

    <section class="access-section">
      <div class="access-shell access-narrow">
        <div class="access-section-head reveal">
          <p class="access-kicker">Questions fréquentes</p>
          <h2>Contact Chiffr : les réponses utiles</h2>
        </div>

        <div class="faq-list">
          {faqs.map((item) => (
            <details class="faq-card reveal-card">
              <summary>{item.question}</summary>
              <p>{item.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  </div>

  <script is:inline>
    const accessForm = document.querySelector('[data-access-form]');
    const formFeedback = document.querySelector('[data-form-feedback]');

    // Formulaire progressif : JS actif → on masque le reste jusqu'à la 1re
    // interaction (focus/saisie sur métier ou email). Sans JS, tout reste visible.
    if (accessForm && accessForm.hasAttribute('data-progressive')) {
      accessForm.classList.add('is-progressive');
      const expand = () => accessForm.classList.add('is-expanded');
      ['#trade', '#email'].forEach((sel) => {
        const el = accessForm.querySelector(sel);
        if (!el) return;
        el.addEventListener('focus', expand, { once: true });
        el.addEventListener('input', expand, { once: true });
        el.addEventListener('change', expand, { once: true });
      });
    }

    accessForm?.addEventListener('submit', (event) => {
      event.preventDefault();

      if (!accessForm.checkValidity()) {
        accessForm.reportValidity();
        return;
      }

      const formData = new FormData(accessForm);
      const name = String(formData.get('name') || '').trim();
      const company = String(formData.get('company') || '').trim();
      const email = String(formData.get('email') || '').trim();
      const phone = String(formData.get('phone') || '').trim();
      const trade = String(formData.get('trade') || '').trim();
      const priority = String(formData.get('priority') || '').trim();
      const needs = formData.getAll('needs').map((item) => String(item)).filter(Boolean);
      const message = String(formData.get('message') || '').trim();

      const subject = `Demande d'accès Chiffr - ${trade || 'artisan énergie'}`;

      const body = [
        'Bonjour,',
        '',
        'Je souhaite demander un accès à Chiffr.',
        '',
        `Nom : ${name || 'Non renseigné'}`,
        `Entreprise : ${company || 'Non renseignée'}`,
        `Email : ${email || 'Non renseigné'}`,
        `Téléphone : ${phone || 'Non renseigné'}`,
        `Métier principal : ${trade || 'Non renseigné'}`,
        `Priorité principale : ${priority || 'Non renseignée'}`,
        '',
        'Ce que je veux améliorer :',
        needs.length ? needs.map((need) => `- ${need}`).join('\n') : '- Non renseigné',
        '',
        'Message :',
        message || 'Non renseigné',
        '',
        '---',
        'Envoyé depuis https://chiffr-devis.fr/contact',
      ].join('\n');

      formFeedback?.classList.add('visible');

      const mailtoUrl = `mailto:melan@livdapps.com?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;

      window.setTimeout(() => {
        window.location.href = mailtoUrl;
      }, 250);
    });

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const items = document.querySelectorAll('.reveal, .reveal-card');

    if (reduce) {
      items.forEach((item) => item.classList.add('visible'));
    } else {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          });
        },
        { threshold: 0.12, rootMargin: '0px 0px -30px 0px' }
      );

      items.forEach((item) => observer.observe(item));
    }
  </script>
</BaseLayout>
