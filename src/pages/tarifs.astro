      ['Exports comptables', false, false, 'Limité', true],
      ['Support prioritaire', false, 'Standard', 'Prioritaire', 'Prioritaire +'],
    ],
  },
];

const faqs = [
  {
    question: 'Y a-t-il une offre Découverte ?',
    answer:
      'Oui. L’offre Découverte permet d’évaluer Chiffr avec un volume limité de devis, factures, clients et références catalogue.',
  },
  {
    question: 'Quelle offre choisir pour un artisan seul ?',
    answer:
      'Solo convient à un artisan seul qui veut créer des devis et factures illimités avec des modèles métier, des PDF premium et un suivi simple.',
  },
  {
    question: 'Chiffr aide-t-il à préparer la réforme de la facturation électronique ?',
    answer:
      'Oui. Les offres Pro et Équipe sont pensées pour mieux structurer factures, données client, acomptes et soldes avant la transition 2026–2027. La transmission réglementaire devra passer par une plateforme agréée.',
  },
  {
    question: 'Pourquoi l’offre Pro est-elle recommandée ?',
    answer:
      'Pro correspond à la vraie promesse Chiffr : créer le devis, le faire signer, demander l’acompte, facturer, relancer et suivre le client.',
  },
  {
    question: 'L’offre Équipe est-elle faite pour une petite entreprise ?',
    answer:
      'Oui. Équipe est pensée pour une TPE avec bureau et terrain : plusieurs utilisateurs, rôles simples, chantiers, rentabilité et exports.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

<BaseLayout title={title} description={description} canonicalPath="/tarifs" schema={faqSchema}>
  <style is:inline>
    .pricing-page,
    .pricing-page * {
      box-sizing: border-box;
    }

    .pricing-page {
      color: var(--ink);
      overflow: hidden;
    }

    .pricing-shell {
      width: 100%;
      max-width: 1280px;
      margin: 0 auto;
    }

    .pricing-narrow {
      max-width: 920px;
    }

    .pricing-hero,
    .pricing-plans,
    .pricing-compare,
    .pricing-proof-section,
    .pricing-faq,
    .pricing-cta {
      position: relative;
      padding: 56px 20px;
    }

    .pricing-hero {
      padding-top: 64px;
      padding-bottom: 48px;
    }

    .pricing-compare {
      padding-top: 44px;
      padding-bottom: 44px;
    }

    .pricing-glow {
      position: absolute;
      pointer-events: none;
      border-radius: 999px;
      opacity: 0.55;
      filter: blur(4px);
      animation: pricingGlow 10s ease-in-out infinite alternate;
    }

    .pricing-glow-one {
      top: 60px;
      left: -120px;
      width: 380px;
      height: 380px;
      background: radial-gradient(circle, rgba(185, 97, 52, 0.18), transparent 68%);
    }

    .pricing-glow-two {
      right: -120px;
      bottom: 20px;
      width: 400px;
      height: 400px;
      background: radial-gradient(circle, rgba(12, 20, 32, 0.13), transparent 70%);
      animation-delay: 1s;
    }

    .pricing-grid {
      position: relative;
      z-index: 1;
      display: grid;
      gap: 36px;
      align-items: center;
    }

    .pricing-pill,
    .pricing-kicker {
      display: inline-flex;
      align-items: center;
      margin: 0;
      padding: 8px 14px;
      border-radius: 999px;
      border: 1px solid rgba(12, 20, 32, 0.12);
      background: rgba(255, 255, 255, 0.78);
      color: var(--teal);
      font-size: 14px;
      line-height: 1.3;
      font-weight: 600;
    }

    .pricing-kicker {
      padding: 0;
      border: 0;
      background: transparent;
      color: var(--copper);
      font-size: 15px;
    }

    .pricing-kicker-light {
      color: #F6E7DB;
    }

    .pricing-page h1 {
      margin: 22px 0 0;
      max-width: 880px;
      color: var(--teal);
      font-size: clamp(42px, 5vw, 72px);
      line-height: 1;
      letter-spacing: -0.02em;
      font-weight: 650;
    }

    .pricing-lead {
      margin: 20px 0 0;
      max-width: 700px;
      color: #5F6673;
      font-size: 18px;
      line-height: 1.62;
    }

    .pricing-proof {
      margin-top: 18px;
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      color: #5F6673;
      font-size: 13px;
      font-weight: 600;
    }

    .pricing-proof span::before {
      content: "✓";
      margin-right: 6px;
      color: var(--success);
    }

    .pricing-badge-row {
      display: flex;
      flex-wrap: wrap;
      align-items: stretch;
      gap: 12px;
      margin-top: 24px;
    }

    .pricing-reform-pill {
      display: inline-grid;
      align-content: center;
      gap: 3px;
      padding: 10px 18px;
      border-radius: 999px;
      background: var(--chiffr-surface);
      border: 1px solid var(--chiffr-border);
      box-shadow: 0 8px 20px -10px rgba(12, 20, 32, 0.14);
      transition: box-shadow 160ms ease;
    }

    .pricing-reform-pill:hover {
      box-shadow: 0 12px 26px -10px rgba(12, 20, 32, 0.22);
    }

    .pricing-reform-pill strong {
      color: var(--chiffr-text);
      font-size: 13.5px;
      line-height: 1.2;
      font-weight: 600;
    }

    .pricing-reform-pill small {
      color: var(--chiffr-text-soft);
      font-size: 12px;
      line-height: 1.3;
      font-weight: 500;
    }

    .pricing-actions {
      margin-top: 26px;
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
    }

    .pricing-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 50px;
      border-radius: 999px;
      padding: 15px 24px;
      font-weight: 650;
      line-height: 1;
      transition: transform 180ms ease, box-shadow 180ms ease, background 180ms ease;
    }

    .pricing-btn-primary {
      color: white;
      background: var(--teal);
      box-shadow: 0 18px 38px rgba(12, 20, 32, 0.18);
    }

    .pricing-btn-primary:hover {
      transform: translateY(-2px);
      background: #043840;
      box-shadow: 0 22px 46px rgba(12, 20, 32, 0.22);
    }

    .pricing-btn-secondary {
      color: var(--teal);
      background: rgba(255, 255, 255, 0.84);
      border: 1px solid rgba(12, 20, 32, 0.14);
    }

    .pricing-btn-secondary:hover {
      transform: translateY(-2px);
      background: white;
      box-shadow: 0 18px 38px rgba(12, 20, 32, 0.08);
    }

    .pricing-btn-full {
      width: 100%;
    }

    .pricing-card,
    .pricing-plan,
    .pricing-table-card,
    .pricing-panel,
    .pricing-faq-card {
      border: 1px solid rgba(12, 20, 32, 0.12);
      background:
        linear-gradient(145deg, rgba(255, 252, 247, 0.96), rgba(255, 255, 255, 0.86));
      box-shadow:
        0 24px 70px rgba(12, 20, 32, 0.1),
        inset 0 1px 0 rgba(255, 255, 255, 0.9);
    }

    .pricing-card {
      overflow: hidden;
      border-radius: 24px;
      animation: pricingFloat 5.8s ease-in-out infinite;
    }

    .pricing-card-head {
      display: flex;
      justify-content: space-between;
      gap: 18px;
      padding: 24px;
      background: linear-gradient(135deg, #0C1420, #043840);
      color: white;
    }

    .pricing-card-head p {
      margin: 0;
      color: rgba(255, 255, 255, 0.72);
      font-size: 14px;
      font-weight: 600;
    }

    .pricing-card-head h2 {
      margin: 8px 0 0;
      color: white;
      font-size: 48px;
      line-height: 1;
      letter-spacing: -0.02em;
      font-weight: 650;
    }

    .pricing-card-price {
      min-width: 118px;
      height: 96px;
      border-radius: 16px;
      background: rgba(255, 255, 255, 0.1);
      display: grid;
      align-content: center;
      justify-items: center;
      text-align: center;
      padding: 12px;
    }

    .pricing-card-price strong {
      color: white;
      font-size: 30px;
      line-height: 1;
      font-weight: 650;
    }

    .pricing-card-price small {
      margin-top: 6px;
      color: rgba(255, 255, 255, 0.68);
      font-size: 12px;
      font-weight: 600;
    }

    .pricing-card-body {
      padding: 24px;
    }

    .pricing-card-body p {
      margin: 0;
      color: #5F6673;
      font-size: 16px;
      line-height: 1.6;
    }

    .pricing-cycle {
      margin-top: 18px;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 8px;
    }

    .pricing-cycle div {
      position: relative;
      min-height: 74px;
      padding: 12px;
      border-radius: 18px;
      background: rgba(12, 20, 32, 0.06);
      overflow: hidden;
    }

    .pricing-cycle div::after {
      content: "";
      position: absolute;
      inset: auto 0 0 0;
      height: 4px;
      background: var(--success);
      animation: pricingFill 1.2s ease both;
    }

    .pricing-cycle span {
      display: block;
      color: #5F6673;
      font-size: 12px;
      font-weight: 650;
    }

    .pricing-cycle strong {
      display: block;
      margin-top: 10px;
      color: var(--teal);
      font-size: 13px;
      line-height: 1.2;
      font-weight: 650;
    }

    .pricing-card-tags {
      margin-top: 16px;
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .pricing-card-tags span {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      padding: 8px 11px;
      border-radius: 999px;
      background: rgba(230, 241, 240, 0.85);
      color: var(--teal);
      font-size: 12px;
      font-weight: 650;
      animation: pricingPop 260ms ease both;
    }

    .pricing-card-tags span::before {
      content: "✓";
      color: var(--success);
    }

    .pricing-section-head {
      max-width: 920px;
    }

    .pricing-section-head-row {
      max-width: none;
      display: grid;
      gap: 24px;
      align-items: end;
    }

    .pricing-section-head h2,
    .pricing-panel h2,
    .pricing-cta h2 {
      margin: 12px 0 0;
      color: var(--teal);
      font-size: clamp(32px, 3.4vw, 48px);
      line-height: 1.06;
      letter-spacing: -0.02em;
      font-weight: 650;
    }

    .pricing-section-head p,
    .pricing-panel p,
    .pricing-cta p {
      margin: 16px 0 0;
      max-width: 820px;
      color: #5F6673;
      font-size: 17px;
      line-height: 1.62;
    }

    .pricing-compare .pricing-section-head h2 {
      font-size: clamp(28px, 3vw, 42px);
    }

    .pricing-compare .pricing-section-head p {
      margin-top: 10px;
      font-size: 15px;
      line-height: 1.5;
    }

    .pricing-billing {
      justify-self: start;
      display: inline-grid;
      grid-template-columns: 1fr 1fr;
      gap: 6px;
      padding: 6px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.84);
      border: 1px solid rgba(12, 20, 32, 0.12);
      box-shadow: 0 14px 34px rgba(12, 20, 32, 0.07);
    }

    .pricing-billing button {
      border: 0;
      border-radius: 999px;
      padding: 11px 16px;
      background: transparent;
      color: var(--teal);
      font: inherit;
      font-weight: 650;
      cursor: pointer;
      transition: background 180ms ease, color 180ms ease, transform 180ms ease;
    }

    .pricing-billing button:hover {
      transform: translateY(-1px);
    }

    .pricing-billing span {
      display: block;
      margin-top: 2px;
      color: var(--success);
      font-size: 11px;
    }

    .pricing-billing button.is-active {
      color: white;
      background: var(--teal);
      box-shadow: 0 10px 24px rgba(12, 20, 32, 0.16);
    }

    .pricing-billing button.is-active span {
      color: rgba(255, 255, 255, 0.74);
    }

    .pricing-plan-grid {
      margin-top: 28px;
      display: grid;
      gap: 16px;
      align-items: stretch;
    }

    .pricing-plan {
      position: relative;
      overflow: hidden;
      border-radius: 18px;
      padding: 20px;
      cursor: pointer;
      transition:
        transform 180ms ease,
        box-shadow 180ms ease,
        border-color 180ms ease,
        background 180ms ease;
    }

    .pricing-plan:hover {
      transform: translateY(-4px);
      background: white;
      box-shadow: 0 28px 80px rgba(12, 20, 32, 0.14);
      border-color: rgba(12, 20, 32, 0.22);
    }

    .pricing-plan.is-selected {
      border-color: rgba(185, 97, 52, 0.72);
      box-shadow:
        0 28px 90px rgba(12, 20, 32, 0.14),
        0 0 0 4px rgba(185, 97, 52, 0.13);
    }

    .pricing-plan.is-recommended {
      background:
        linear-gradient(145deg, rgba(255, 255, 255, 0.98), rgba(230, 241, 240, 0.72)),
        radial-gradient(circle at top right, rgba(47, 125, 70, 0.16), transparent 44%);
      border-color: rgba(12, 20, 32, 0.28);
    }

    .pricing-ribbon {
      margin: -20px -20px 16px;
      padding: 10px 14px;
      background: var(--teal);
      color: white;
      text-align: center;
      font-size: 12px;
      line-height: 1.25;
      font-weight: 650;
      white-space: normal;
    }

    .pricing-select {
      position: absolute;
      top: 18px;
      right: 18px;
      width: 30px;
      height: 30px;
      overflow: hidden;
      border: 1px solid rgba(12, 20, 32, 0.14);
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.86);
      color: transparent;
      cursor: pointer;
      z-index: 2;
      transition: background 180ms ease, border-color 180ms ease;
    }

    .pricing-plan.is-recommended .pricing-select {
      top: 58px;
    }

    .pricing-select::after {
      content: "";
      position: absolute;
      inset: 8px;
      border-radius: 999px;
      background: rgba(12, 20, 32, 0.18);
      transition: background 180ms ease, transform 180ms ease;
    }

    .pricing-plan.is-selected .pricing-select {
      background: var(--teal);
      border-color: var(--teal);
    }

    .pricing-plan.is-selected .pricing-select::after {
      background: white;
      transform: scale(0.74);
    }

    .pricing-plan-top {
      padding-right: 40px;
    }

    .pricing-plan-top span {
      display: inline-flex;
      padding: 7px 11px;
      border-radius: 999px;
      background: rgba(12, 20, 32, 0.07);
      color: var(--teal);
      font-size: 12px;
      font-weight: 650;
    }

    .pricing-plan-top h3 {
      margin: 14px 0 0;
      color: var(--teal);
      font-size: 31px;
      line-height: 1;
      letter-spacing: -0.02em;
      font-weight: 650;
    }

    .pricing-plan-top p {
      margin: 10px 0 0;
      min-height: 64px;
      color: #5F6673;
      font-size: 14px;
      line-height: 1.5;
    }

    .pricing-price {
      margin: 18px 0 14px;
      display: flex;
      align-items: end;
      gap: 8px;
      color: var(--teal);
    }

    .pricing-price strong {
      font-size: 36px;
      line-height: 1;
      letter-spacing: -0.02em;
      font-weight: 650;
    }

    .pricing-price small {
      margin-bottom: 5px;
      color: #5F6673;
      font-size: 12px;
      font-weight: 600;
    }

    .pricing-bestfor {
      margin-bottom: 14px;
      padding: 11px 12px;
      border-radius: 16px;
      background: rgba(12, 20, 32, 0.06);
    }

    .pricing-bestfor small {
      display: block;
      color: #5F6673;
      font-size: 12px;
      font-weight: 600;
    }

    .pricing-bestfor strong {
      display: block;
      margin-top: 4px;
