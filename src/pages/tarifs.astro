    }

    .pricing-reveal.is-visible,
    .pricing-reveal-card.is-visible {
      opacity: 1;
      transform: translateY(0);
    }


    .pricing-reform-premium-section {
      background:
        radial-gradient(circle at 88% 8%, rgba(12, 20, 32, 0.08), transparent 32%);
    }

    .pricing-reform-premium-panel {
      position: relative;
      overflow: hidden;
      display: grid;
      gap: 26px;
      padding: clamp(24px, 4vw, 42px);
      border-radius: 24px;
      border: 1px solid rgba(12, 20, 32, 0.12);
      background:
        linear-gradient(145deg, rgba(255, 255, 255, 0.9), rgba(255, 252, 247, 0.82));
      box-shadow:
        0 32px 90px rgba(12, 20, 32, 0.12),
        inset 0 1px 0 rgba(255, 255, 255, 0.9);
    }

    .pricing-reform-premium-panel::after {
      content: "";
      position: absolute;
      right: -110px;
      top: -130px;
      width: 280px;
      height: 280px;
      border-radius: 999px;
      background: rgba(185, 97, 52, 0.13);
      pointer-events: none;
