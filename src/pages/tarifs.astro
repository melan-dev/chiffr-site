      ['PDF premium', true, true, true, true],
      ['Préparation facturation électronique', false, 'Base propre', true, true],
      ['Factures acompte / solde', false, true, true, true],
    ],
  },
  {
    title: 'Métier énergie',
    rows: [
      ['Modèles métier', 'Limités', true, 'Avancés', 'Avancés'],
      ['Catalogue perso', '20 refs', 'Illimité', 'Import inclus', 'Import inclus'],
      ['Photos chantier', 'Limité', true, 'PDF inclus', 'Avancé'],
      ['Photo plaque machine', 'Limité', 'Quota inclus', 'Quota élevé', 'Quota élevé'],
      ['Scan EAN', 'Limité', true, 'Avancé', 'Avancé'],
    ],
  },
  {
    title: 'Conversion client',
    rows: [
      ['Signature électronique téléphone', true, true, true, true],
      ['Signature électronique à distance', false, false, true, true],
      ['Paiement acompte', false, false, true, true],
      ['Relances client', false, 'Manuelles', true, 'Avancées'],
