  <script is:inline>
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const revealItems = document.querySelectorAll('.pricing-reveal, .pricing-reveal-card');

    if (reduceMotion) {
      revealItems.forEach((item) => item.classList.add('is-visible'));
    } else {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          });
        },
        { threshold: 0.12, rootMargin: '0px 0px -30px 0px' }
      );

      revealItems.forEach((item) => observer.observe(item));
    }

    let currentBilling = 'annual';

    const billingButtons = document.querySelectorAll('[data-billing]');
    const annualPrices = document.querySelectorAll('[data-price-annual]');
    const monthlyPrices = document.querySelectorAll('[data-price-monthly]');
    const planCards = document.querySelectorAll('[data-plan-card]');
    const selectButtons = document.querySelectorAll('[data-select-plan]');
    const advisorName = document.querySelector('[data-advisor-name]');
    const advisorPrice = document.querySelector('[data-advisor-price]');
    const advisorText = document.querySelector('[data-advisor-text]');
    const advisorTags = document.querySelector('[data-advisor-tags]');
    const planColumns = document.querySelectorAll('[data-plan-column]');

    function updateVisiblePrices() {
      const showAnnual = currentBilling === 'annual';

      annualPrices.forEach((price) => {
        price.hidden = !showAnnual;
      });

      monthlyPrices.forEach((price) => {
        price.hidden = showAnnual;
      });

      const selected = document.querySelector('.pricing-plan.is-selected');

      if (selected && advisorPrice) {
        advisorPrice.textContent = showAnnual ? selected.dataset.annual : selected.dataset.monthly;
      }
    }

    function selectPlan(key) {
      const card = document.querySelector(`[data-plan-card="${key}"]`);

      if (!card) return;

      planCards.forEach((item) => item.classList.remove('is-selected'));
      card.classList.add('is-selected');

      planColumns.forEach((item) => {
        item.classList.toggle('is-selected-column', item.dataset.planColumn === key);
      });

      if (advisorName) advisorName.textContent = card.dataset.name || '';
      if (advisorText) advisorText.textContent = card.dataset.text || '';

      if (advisorTags) {
        const highlights = (card.dataset.highlights || '').split('|').filter(Boolean);
        advisorTags.innerHTML = highlights.map((item) => `<span>${item}</span>`).join('');
      }

      updateVisiblePrices();
    }

    billingButtons.forEach((button) => {
      button.addEventListener('click', () => {
        currentBilling = button.dataset.billing || 'annual';

        billingButtons.forEach((item) => item.classList.remove('is-active'));
        button.classList.add('is-active');

        updateVisiblePrices();
      });
    });

    selectButtons.forEach((button) => {
      button.addEventListener('click', (event) => {
        event.stopPropagation();
        selectPlan(button.dataset.selectPlan);
      });
    });

    planCards.forEach((card) => {
      card.addEventListener('click', (event) => {
        const target = event.target;

        if (!(target instanceof Element)) return;

        if (target.closest('a') || target.closest('details') || target.closest('summary')) {
          return;
        }

        selectPlan(card.dataset.planCard);
      });
    });

    selectPlan('pro');
  </script>
</BaseLayout>