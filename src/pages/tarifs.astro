    .pricing-reform-copy,
    .pricing-reform-timeline {
      position: relative;
      z-index: 1;
    }

    .pricing-reform-copy h2 {
      margin: 12px 0 0;
      max-width: 780px;
      color: var(--teal);
      font-size: clamp(32px, 3.8vw, 54px);
      line-height: 1.03;
      letter-spacing: -0.02em;
      font-weight: 650;
    }

    .pricing-reform-copy > p {
      margin: 18px 0 0;
      max-width: 760px;
      color: #5F6673;
      font-size: 17px;
      line-height: 1.68;
      font-weight: 500;
    }

    .pricing-reform-badges {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      align-items: center;
      margin-top: 24px;
    }

    .pricing-reform-premium-pill {
      display: inline-grid;
      gap: 3px;
      width: fit-content;
      padding: 14px 17px;
      border-radius: 999px;
      border: 1px solid rgba(12, 20, 32, 0.12);
      background: rgba(255, 255, 255, 0.86);
      box-shadow: 0 18px 44px rgba(12, 20, 32, 0.07);
    }

    .pricing-reform-premium-pill strong {
      color: var(--teal);
      font-size: 14px;
      line-height: 1;
      font-weight: 650;
    }

    .pricing-reform-premium-pill small {
      color: #5F6673;
      font-size: 12px;
      line-height: 1.25;
      font-weight: 600;
    }

    .pricing-reform-timeline {
      display: grid;
      gap: 12px;
      padding: 18px;
      border-radius: 20px;
      background:
        linear-gradient(145deg, #0C1420, #101B28);
      box-shadow:
        0 26px 68px rgba(12, 20, 32, 0.22),
        inset 0 1px 0 rgba(255, 255, 255, 0.13);
    }

    .timeline-card {
      padding: 18px;
      border-radius: 16px;
      background: rgba(255, 255, 255, 0.1);
      border: 1px solid rgba(255, 255, 255, 0.12);
    }

    .timeline-card.active {
      background: rgba(255, 255, 255, 0.16);
    }

    .timeline-card.chiffr {
      background: white;
    }

    .timeline-card span {
      display: inline-flex;
      width: fit-content;
      margin-bottom: 10px;
      padding: 7px 10px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.12);
      color: #F6E7DB;
      font-size: 12px;
      font-weight: 650;
    }

    .timeline-card strong {
      display: block;
      color: white;
      font-size: 23px;
      line-height: 1.05;
      letter-spacing: -0.02em;
      font-weight: 650;
    }

    .timeline-card p {
      margin: 10px 0 0;
      color: rgba(255, 255, 255, 0.72);
      font-size: 14px;
      line-height: 1.55;
      font-weight: 550;
    }

    .timeline-card.chiffr span {
      background: rgba(185, 97, 52, 0.12);
      color: var(--copper);
    }

    .timeline-card.chiffr strong {
      color: var(--teal);
    }

    .timeline-card.chiffr p {
      color: #5F6673;
    }

    @media (min-width: 980px) {
      .pricing-reform-premium-panel {
        grid-template-columns: minmax(0, 1.05fr) minmax(360px, 0.95fr);
        align-items: center;
      }
    }

    @media (max-width: 640px) {
      .pricing-reform-premium-panel {
        border-radius: 20px;
      }

      .pricing-reform-badges {
        display: grid;
      }

      .pricing-reform-premium-pill {
        width: 100%;
      }
    }


    @keyframes pricingGlow {
      from {
        transform: translate3d(0, 0, 0) scale(1);
      }

      to {
        transform: translate3d(24px, -18px, 0) scale(1.08);
      }
    }

    @keyframes pricingFloat {
      0%,
      100% {
        transform: translateY(0);
      }

      50% {
        transform: translateY(-6px);
      }
    }

    @keyframes pricingFill {
      from {
        transform: scaleX(0);
        transform-origin: left;
      }

      to {
        transform: scaleX(1);
        transform-origin: left;
      }
    }

    @keyframes pricingPop {
      from {
        opacity: 0;
        transform: translateY(4px) scale(0.96);
      }

      to {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }

    @media (min-width: 820px) {
      .pricing-section-head-row {
        grid-template-columns: 1fr auto;
      }

      .pricing-billing {
        justify-self: end;
      }

      .pricing-plan-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (min-width: 1120px) {
      .pricing-grid {
        grid-template-columns: 1.05fr 0.95fr;
      }

      .pricing-plan-grid {
        grid-template-columns: repeat(4, 1fr);
      }

      .pricing-split {
        grid-template-columns: 1fr 1fr;
      }
    }

    @media (max-width: 720px) {
      .pricing-hero,
      .pricing-plans,
      .pricing-compare,
      .pricing-proof-section,
      .pricing-faq,
      .pricing-cta {
        padding: 44px 18px;
      }

      .pricing-hero {
        padding-top: 52px;
      }

      .pricing-card-head {
        display: grid;
      }

      .pricing-card-price {
        width: 150px;
      }

      .pricing-cycle {
        grid-template-columns: 1fr 1fr;
      }

      .pricing-unlocks {
        grid-template-columns: 1fr;
      }

      .pricing-plan.is-recommended .pricing-select {
        top: 54px;
      }

      .pricing-table {
        min-width: 720px;
      }

      .pricing-table th:first-child,
      .pricing-table td:first-child {
        width: 180px;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .pricing-page *,
      .pricing-page *::before,
      .pricing-page *::after {
        animation-duration: 0.001ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.001ms !important;
      }

      .pricing-reveal,
      .pricing-reveal-card {
        opacity: 1;
        transform: none;
      }
    }
  </style>

  <div class="pricing-page">
    <section class="pricing-hero">
      <div class="pricing-glow pricing-glow-one"></div>
      <div class="pricing-glow pricing-glow-two"></div>

      <div class="pricing-shell pricing-grid">
        <div class="pricing-reveal">
          <p class="pricing-pill">Tarifs Chiffr</p>

          <h1>Des offres simples, pensées pour les artisans énergie</h1>

          <p class="pricing-lead">
            Commencez gratuitement, payez quand ça vous sert vraiment : créer des devis, faire
            signer, encaisser l’acompte, facturer. Sans carte bancaire, sans engagement.
          </p>

          <div class="pricing-proof">
            <span>Accès découverte</span>
            <span>Sans engagement</span>
            <span>Prix HT clairs</span>
            <span>Offre Pro recommandée</span>
            <span>Réforme 2026–2027</span>
          </div>

          <div class="pricing-badge-row">
            <SignatureProofBadge tone="compact" detail="Sur place ou à distance" />
            <a class="pricing-reform-pill" href="#facturation-electronique">
              <strong>Facturation électronique 2026–2027</strong>
              <small>Anticiper la réception 2026 et l’émission 2027</small>
            </a>
          </div>

          <div class="pricing-actions">
            <a href={APP_URL} class="pricing-btn pricing-btn-primary">Essayer gratuitement</a>
            <a href="#comparatif" class="pricing-btn pricing-btn-secondary">Comparer les offres</a>
          </div>

          <p class="cta-trust">{CTA_TRUST}</p>
        </div>

        <aside class="pricing-card pricing-reveal" aria-label="Offre sélectionnée">
          <div class="pricing-card-head">
            <div>
              <p>Offre sélectionnée</p>
              <h2 data-advisor-name>Pro</h2>
            </div>

            <div class="pricing-card-price">
              <strong data-advisor-price>39 €</strong>
              <small>HT/mois</small>
            </div>
          </div>

          <div class="pricing-card-body">
            <p data-advisor-text>
              Pour gérer le cycle complet : devis, signature électronique, acompte, facture et relance.
            </p>

            <div class="pricing-cycle">
              <div>
                <span>01</span>
                <strong>Devis</strong>
              </div>
              <div>
                <span>02</span>
                <strong>Signature e.</strong>
              </div>
              <div>
                <span>03</span>
                <strong>Acompte</strong>
              </div>
              <div>
                <span>04</span>
                <strong>Facture</strong>
              </div>
            </div>

            <div class="pricing-card-tags" data-advisor-tags>
              <span>Signature électronique</span>
              <span>Acompte Stripe</span>
              <span>Relances client</span>
              <span>Import catalogue IA</span>
            </div>
          </div>
        </aside>
      </div>
    </section>

    <section class="pricing-proof-section">
      <div class="pricing-shell">
        <PagePhotoShowcase
          variant="tarifs"
          eyebrow="Tarifs clairs"
          title="Un outil premium pour le terrain et le bureau"
          text="Les offres Chiffr suivent votre usage réel : préparer un devis, faire signer, demander un acompte, facturer, relancer et suivre le client."
          ctaLabel="Comparer les offres"
          ctaHref="#comparatif"
        />
      </div>
    </section>


    <section class="pricing-plans">
      <div class="pricing-shell">
        <div class="pricing-section-head pricing-section-head-row pricing-reveal">
          <div>
            <p class="pricing-kicker">Choisir son offre</p>
            <h2>Une grille lisible, avec l’offre Pro mise en avant</h2>
            <p>
              Les offres sont limitées par usage et par niveau de suivi, pas par documents moches
              ou PDF dégradés. Chiffr doit rester premium, même en Découverte.
            </p>
          </div>

          <div class="pricing-billing">
            <button type="button" class="is-active" data-billing="annual">
              Annuel
              <span>Prix réduit</span>
            </button>
            <button type="button" data-billing="monthly">Mensuel</button>
          </div>
        </div>

        <div class="pricing-plan-grid">
          {plans.map((plan) => (
            <article
              class={`pricing-plan pricing-reveal-card ${plan.recommended ? 'is-recommended' : ''}`}
              data-plan-card={plan.key}
              data-name={plan.name}
              data-annual={plan.annual}
              data-monthly={plan.monthly}
              data-text={plan.intro}
              data-highlights={plan.highlights.join('|')}
            >
              {plan.recommended && <div class="pricing-ribbon">Recommandé pour artisans énergie</div>}

              <button
                type="button"
                class="pricing-select"
                data-select-plan={plan.key}
                aria-label={`Sélectionner l’offre ${plan.name}`}
              >
                Sélectionner
              </button>

              <div class="pricing-plan-top">
                <span>{plan.badge}</span>
                <h3>{plan.name}</h3>
                <p>{plan.intro}</p>
              </div>

              <div class="pricing-price">
                <strong>
                  <span data-price-annual>{plan.annual}</span>
                  <span data-price-monthly hidden>{plan.monthly}</span>
                </strong>
                <small>{plan.period}</small>
              </div>

              <div class="pricing-bestfor">
                <small>Idéal pour</small>
                <strong>{plan.bestFor}</strong>
              </div>

              <a
                href="https://chiffr.web.app"
                class={`pricing-btn pricing-btn-full ${plan.recommended ? 'pricing-btn-primary' : 'pricing-btn-secondary'}`}
              >
                {plan.cta}
              </a>

              <div class="pricing-unlocks">
                {plan.highlights.map((item) => (
                  <span>{item}</span>
                ))}
              </div>

              <details class="pricing-details">
                <summary>Voir tout ce qui est inclus</summary>

                <div class="pricing-included">
                  <p>Inclus</p>
                  <ul>
                    {plan.included.map((item) => <li>{item}</li>)}
                  </ul>
                </div>

                {plan.notes.length > 0 && (
                  <div class="pricing-notes">
                    <p>À noter</p>
                    <ul>
                      {plan.notes.map((item) => <li>{item}</li>)}
                    </ul>
                  </div>
                )}
              </details>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="comparatif" class="pricing-compare">
      <div class="pricing-shell">
        <div class="pricing-section-head pricing-reveal">
          <p class="pricing-kicker">Comparatif interactif</p>
          <h2>Des cases cochées pour voir ce que chaque offre débloque</h2>
          <p>
            Découverte pour évaluer, Solo pour produire, Pro pour convertir, Équipe pour organiser.
          </p>
        </div>

        <div class="pricing-table-card pricing-reveal">
          <div class="pricing-table-wrap">
            <table class="pricing-table">
              <thead>
                <tr>
                  <th>Fonction</th>
                  <th data-plan-column="decouverte">Découverte</th>
                  <th data-plan-column="solo">Solo</th>
                  <th data-plan-column="pro">Pro</th>
                  <th data-plan-column="equipe">Équipe</th>
                </tr>
              </thead>

              <tbody>
                {comparisonGroups.map((group) => (
                  <>
                    <tr class="pricing-table-group">
                      <td colspan="5">{group.title}</td>
                    </tr>

                    {group.rows.map((row) => (
                      <tr>
                        <td>{row[0]}</td>

                        {row.slice(1).map((value, index) => {
                          const keys = ['decouverte', 'solo', 'pro', 'equipe'];

                          return (
                            <td data-plan-column={keys[index]}>
                              {value === true ? (
                                <span class="pricing-check pricing-check-yes">✓</span>
                              ) : value === false ? (
                                <span class="pricing-check pricing-check-no">–</span>
                              ) : (
                                <span class="pricing-value">{value}</span>
                              )}
                            </td>
                          );
                        })}
                      </tr>
                    ))}
                  </>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </section>

    <section class="pricing-proof-section">
      <div class="pricing-shell pricing-split">
        <div class="pricing-panel pricing-panel-dark pricing-reveal">
          <p class="pricing-kicker pricing-kicker-light">Pourquoi Pro est central</p>
