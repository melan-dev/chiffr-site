---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Logiciel devis facture pour artisans énergie | Chiffr';
const description =
  'Chiffr aide les artisans énergie à créer devis, factures, signatures, acomptes et PDF premium avec des modèles métier PAC, clim, CVC, VMC, IRVE et solaire.';

const benefits = [
  {
    label: 'Devis guidés',
    detail: 'Modèles métier prêts à adapter',
    icon: '<svg viewBox="0 0 24 24"><path d="M9 3h9a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V8z"/><path d="M9 3v5H4"/><path d="M9 13h7M9 17h5"/></svg>',
  },
  {
    label: 'PDF premium',
    detail: 'Des documents propres et sérieux',
    icon: '<svg viewBox="0 0 24 24"><path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z"/><path d="M14 3v5h5"/><path d="M9 14.5l2 2 4-4.5"/></svg>',
  },
  {
    label: 'Signature électronique',
    detail: 'Sur place ou à distance',
    icon: '<svg viewBox="0 0 24 24"><path d="m16.3 4.7 3 3L8.5 18.5 4 20l1.5-4.5z"/><path d="M14.5 6.5l3 3"/></svg>',
  },
  {
    label: 'Acomptes & relances',
    detail: 'Rien ne reste en attente',
    icon: '<svg viewBox="0 0 24 24"><path d="M18 8a6 6 0 1 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.7 21a2 2 0 0 1-3.4 0"/></svg>',
  },
  {
    label: 'Factures & suivi',
    detail: 'Le cycle complet, au même endroit',
    icon: '<svg viewBox="0 0 24 24"><path d="M3 3v18h18"/><path d="m7 14 4-4 3 3 5-6"/></svg>',
  },
];

const trades = [
  {
    label: 'Pompe à chaleur',
    detail: 'PAC air/eau & air/air',
    href: '/logiciel-devis-pompe-a-chaleur',
    icon: '<svg viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2"/><circle cx="12" cy="12" r="3.6"/><path d="M12 8.4v1.2M12 14.4v1.2M8.4 12h1.2M14.4 12h1.2"/></svg>',
  },
  {
    label: 'Climatisation',
    detail: 'Monosplit & multisplit',
    href: '/logiciel-devis-climatisation',
    icon: '<svg viewBox="0 0 24 24"><path d="M12 3v18"/><path d="m4.6 7.7 14.8 8.6M19.4 7.7 4.6 16.3"/><path d="M12 3l-2 2M12 3l2 2M12 21l-2-2M12 21l2-2"/></svg>',
  },
  {
    label: 'Chauffage',
    detail: 'Chaudières & radiateurs',
    href: '/logiciel-devis-chauffagiste',
    icon: '<svg viewBox="0 0 24 24"><path d="M12 3s5.5 4.8 5.5 9.3a5.5 5.5 0 1 1-11 0C6.5 7.8 12 3 12 3z"/><path d="M12 17.5a2.6 2.6 0 0 0 2.6-2.6c0-1.6-2.6-4-2.6-4s-2.6 2.4-2.6 4a2.6 2.6 0 0 0 2.6 2.6z"/></svg>',
  },
  {
    label: 'CVC / Froid',
    detail: 'Frigoriste & ventilation',
    href: '/logiciel-devis-frigoriste-cvc',
    icon: '<svg viewBox="0 0 24 24"><path d="M3 8.5h11a3 3 0 1 0-2.8-4"/><path d="M3 13h15a3 3 0 1 1-2.8 4"/><path d="M3 17.5h6a2.4 2.4 0 1 1-2.3 3.2"/></svg>',
  },
  {
    label: 'VMC',
    detail: 'Simple & double flux',
    href: '/logiciel-devis-vmc',
    icon: '<svg viewBox="0 0 24 24"><path d="M21.5 12a9.5 9.5 0 1 1-2.8-6.7"/><path d="M21.5 2.5v6h-6"/><circle cx="12" cy="12" r="2.2"/></svg>',
  },
  {
    label: 'IRVE',
    detail: 'Bornes de recharge',
    href: '/logiciel-devis-irve',
    icon: '<svg viewBox="0 0 24 24"><path d="M9 2.5V8M15 2.5V8"/><path d="M6 8h12v4.5a6 6 0 0 1-12 0z"/><path d="M12 18.5V22"/></svg>',
  },
  {
    label: 'Solaire',
    detail: 'Photovoltaïque',
    href: '/logiciel-devis-photovoltaique',
    icon: '<svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="4"/><path d="M12 2.5v2.6M12 18.9v2.6M2.5 12h2.6M18.9 12h2.6M5.3 5.3l1.8 1.8M16.9 16.9l1.8 1.8M18.7 5.3l-1.8 1.8M7.1 16.9l-1.8 1.8"/></svg>',
  },
  {
    label: 'Eau chaude',
    detail: 'Chauffe-eau thermodynamique',
    href: '/logiciel-devis-chauffe-eau-thermodynamique',
    icon: '<svg viewBox="0 0 24 24"><path d="M12 3s6 6.4 6 10.7a6 6 0 1 1-12 0C6 9.4 12 3 12 3z"/><path d="M9.5 14.5a2.5 2.5 0 0 0 2.5 2.5"/></svg>',
  },
];

const cockpitPoints = [
  'Devis, clients, suivi et planning centralisés',
  'Catalogue produit à jour',
  'Factures, acomptes et relances',
  'Statistiques et rentabilité',
];

const productViews = [
  {
    eyebrow: 'Accueil',
    title: 'Votre journée en un coup d’œil',
    text:
      'Devis à relancer, à signer, à facturer, à encaisser : l’accueil montre la prochaine bonne action et l’argent à récupérer, sans chercher.',
    points: [
      'La prochaine action mise en avant dès l’ouverture',
      'Relances, signatures et encaissements à traiter',
      'Les montants à récupérer toujours visibles',
    ],
    image: '/images/app/app-accueil-desktop.webp',
    alt: 'Tableau de bord Chiffr : suivi commercial, devis à relancer et actions rapides',
  },
  {
    eyebrow: 'Devis',
    title: 'Des devis professionnels, signés plus vite',
    text:
      'Statuts clairs, montants à jour, relances en un clic : chaque devis avance du brouillon à la signature sans rien laisser en attente.',
    points: [
      'Statuts lisibles : brouillon, envoyé, signé, payé',
      'Relance des devis en attente en un clic',
      'Recherche et filtres par client, date ou statut',
    ],
    image: '/images/app/app-devis-desktop.webp',
    alt: 'Liste des devis Chiffr avec statuts, montants et actions rapides',
  },
  {
    eyebrow: 'Clients',
    title: 'Chaque client, avec tout son historique',
    text:
      'Coordonnées, devis, factures et échanges restent reliés au bon dossier. Vous retrouvez le contexte complet avant chaque intervention.',
    points: [
      'Historique complet relié à chaque dossier',
      'Devis et factures rattachés au bon client',
      'Coordonnées et notes accessibles sur le terrain',
    ],
    image: '/images/app/app-clients-desktop.webp',
    alt: 'Fiches clients Chiffr avec historique des devis et factures',
  },
  {
    eyebrow: 'Catalogue & planning',
    title: 'Vos prix et vos chantiers, toujours à jour',
    text:
      'Un catalogue produit prêt à chiffrer et un planning qui organise les poses : le bureau et le terrain travaillent sur la même base.',
    points: [
      'Références et prix fournisseurs à jour',
      'Import de catalogue : CSV, Excel, PDF ou photo',
      'Le planning des poses partagé avec le terrain',
    ],
    image: '/images/app/app-catalogue-desktop.webp',
    alt: 'Catalogue produit Chiffr avec références et fournisseurs',
  },
];

const guideLinks = [
  ['Comment faire un devis PAC air/eau', '/comment-faire-un-devis-pac-air-eau'],
  ['Que mettre dans un devis climatisation ?', '/que-mettre-dans-un-devis-climatisation'],
  ['Facture d’acompte artisan énergie', '/facture-acompte-artisan-energie'],
  ['Relance devis artisan', '/relance-devis-artisan'],
];

const faqs = [
  [
    'Chiffr est-il seulement pour les installateurs de PAC ?',
    'Non. Chiffr est pensé pour les artisans énergie : PAC, climatisation, chauffage, CVC, VMC, IRVE, photovoltaïque et chauffe-eau thermodynamique.',
  ],
  [
    'Quelle est la différence avec un logiciel généraliste ?',
    'Chiffr ne vous donne pas une page blanche. Il prépare des modèles, des lignes et des actions selon le métier choisi.',
  ],
  [
    'Peut-on gérer les photos chantier ?',
    'Oui. Vous pouvez rattacher les photos importantes au dossier : plaque machine, accès chantier, tableau électrique, emplacement ou croquis.',
  ],
  [
    'Chiffr gère-t-il les acomptes et les factures ?',
    'Oui. Chiffr est conçu pour suivre le cycle complet : devis, signature électronique, acompte, facture d’acompte, facture de solde, facture finale et relance.',
  ],
  [
    'Chiffr est-il prêt pour la réforme de la facturation électronique ?',
    'Chiffr est pensé pour préparer la transition 2026–2027 : factures mieux structurées, données client plus propres, acompte, solde, suivi et future connexion aux plateformes agréées.',
  ],
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(([question, answer]) => ({
    '@type': 'Question',
    name: question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: answer,
    },
  })),
};
---

<BaseLayout title={title} description={description} canonicalPath="/" schema={faqSchema}>
  <!-- ============ Hero ============ -->
  <section class="hp-hero">
    <div class="hp-shell hp-hero-grid">
      <div class="hp-hero-copy">
        <a class="hp-hero-badge" href="#facturation-electronique">
          <span class="hp-hero-badge-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24"><path d="m5 12.5 4.5 4.5L19 7.5" /></svg>
          </span>
          Facturation électronique 2026–2027 : préparez-vous dès aujourd’hui
        </a>

        <h1>
          Le logiciel de devis pensé pour les
          <em>artisans énergie</em> exigeants
        </h1>

        <p class="hp-hero-lead">
          Chiffr vous aide à créer des devis professionnels, gagner du temps
          sur le terrain et développer votre activité.
        </p>

        <div class="hp-hero-actions">
          <a class="hp-btn primary" href="/contact">
            Demander un accès gratuit
            <span aria-hidden="true">→</span>
          </a>
          <a class="hp-btn secondary" href="#produit">
            <span class="hp-play" aria-hidden="true">
              <svg viewBox="0 0 24 24"><path d="M9 6.5v11l9-5.5z" /></svg>
            </span>
            Voir le logiciel en action
          </a>
        </div>

        <ul class="hp-hero-checks">
          <li>Devis ultra rapides</li>
          <li>PDF premium</li>
          <li>Signature électronique</li>
          <li>Acompte & relances</li>
        </ul>
      </div>

      <div class="hp-hero-visual" role="img" aria-label="Aperçu du logiciel Chiffr sur ordinateur, mobile et tablette">
        <div class="hp-stage" aria-hidden="true"></div>

        <figure class="hp-device hp-laptop">
          <span class="hp-laptop-screen">
            <img
              src="/images/app/app-accueil-desktop.webp"
              alt=""
              width="1800"
              height="908"
              loading="eager"
              fetchpriority="high"
              decoding="async"
            />
          </span>
          <span class="hp-laptop-base" aria-hidden="true"></span>
        </figure>

        <figure class="hp-device hp-tablet">
          <img
            src="/images/app/app-devis-desktop.webp"
            alt=""
            width="1800"
            height="908"
            loading="eager"
            decoding="async"
          />
        </figure>

        <figure class="hp-device hp-phone">
          <img
            src="/images/app/app-mobile-accueil.webp"
            alt=""
            width="576"
            height="1112"
            loading="eager"
            decoding="async"
          />
        </figure>
      </div>
    </div>
  </section>

  <!-- ============ Bandeau bénéfices ============ -->
  <section class="hp-benefits" aria-label="Ce que Chiffr apporte">
    <div class="hp-shell hp-benefits-grid">
      {benefits.map((benefit) => (
        <div class="hp-benefit reveal-card">
          <span class="hp-benefit-icon" aria-hidden="true" set:html={benefit.icon} />
          <div>
            <strong>{benefit.label}</strong>
            <small>{benefit.detail}</small>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ============ Métiers ============ -->
  <section class="hp-section" id="metiers">
    <div class="hp-shell">
      <div class="hp-section-head reveal">
        <p class="hp-kicker">Tous vos métiers couverts</p>
        <h2>Un logiciel adapté à tous les métiers de l’énergie</h2>
        <p class="hp-section-sub">
          PAC, climatisation, chauffage, CVC, VMC, IRVE et solaire : Chiffr s’adapte à votre expertise,
          avec des modèles et des lignes pensés pour chaque spécialité.
        </p>
      </div>

      <div class="hp-trades-grid">
        {trades.map((trade) => (
          <a class="hp-trade-card reveal-card" href={trade.href}>
            <span class="hp-trade-icon" aria-hidden="true" set:html={trade.icon} />
            <strong>{trade.label}</strong>
            <small>{trade.detail}</small>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ Cockpit (section sombre) ============ -->
  <section class="hp-cockpit">
    <div class="hp-shell hp-cockpit-grid">
      <div class="hp-cockpit-copy reveal">
        <p class="hp-kicker light">Tout au même endroit</p>
        <h2>Un cockpit clair pour piloter votre activité</h2>
        <p class="hp-cockpit-sub">
          Du premier rendez-vous à la facture finale, Chiffr garde votre activité lisible :
          vous savez toujours où en est chaque dossier.
        </p>

        <ul class="hp-cockpit-checks">
          {cockpitPoints.map((point) => (
            <li>
              <span aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="m5 12.5 4.5 4.5L19 7.5" /></svg>
              </span>
              {point}
            </li>
          ))}
        </ul>

        <a class="hp-btn ghost" href="/fonctionnalites">
          Voir toutes les fonctionnalités
          <span aria-hidden="true">→</span>
        </a>
      </div>

      <div class="hp-cockpit-visual reveal">
        <figure class="hp-cockpit-shot">
          <img
            src="/images/app/app-suivi-desktop.webp"
            alt="Suivi commercial Chiffr : devis envoyés, signatures, acomptes et factures"
            width="1800"
            height="908"
            loading="lazy"
            decoding="async"
          />
        </figure>

        <figure class="hp-cockpit-phone">
          <img
            src="/images/app/app-mobile-devis.webp"
            alt="Devis Chiffr sur mobile"
            width="576"
            height="1112"
            loading="lazy"
            decoding="async"
          />
        </figure>
      </div>
    </div>
  </section>

  <!-- ============ Produit ============ -->
  <section class="hp-section" id="produit">
    <div class="hp-shell">
      <div class="hp-section-head reveal">
        <p class="hp-kicker">Le logiciel en action</p>
        <h2>Simple en surface, sérieux en profondeur</h2>
        <p class="hp-section-sub">
          Chiffr montre la prochaine bonne action, sans transformer votre devis en usine à gaz.
          Voici l’outil tel que vous l’utiliserez au quotidien.
        </p>
      </div>

    </div>

    <div class="hp-showcases">
      {productViews.map((view) => (
        <article class="hp-showcase reveal">
          <div class="hp-showcase-copy">
            <p class="hp-kicker">{view.eyebrow}</p>
            <h3>{view.title}</h3>
            <p class="hp-showcase-text">{view.text}</p>

            <ul class="hp-showcase-points">
              {view.points.map((point) => (
                <li>
                  <span aria-hidden="true">
                    <svg viewBox="0 0 24 24"><path d="m5 12.5 4.5 4.5L19 7.5" /></svg>
                  </span>
                  {point}
                </li>
              ))}
            </ul>
          </div>

          <figure class="hp-showcase-shot">
            <span class="hp-window-bar" aria-hidden="true">
              <i></i><i></i><i></i>
            </span>
            <img
              src={view.image}
              alt={view.alt}
              width="1800"
              height="908"
              loading="lazy"
              decoding="async"
            />
          </figure>
        </article>
      ))}
    </div>
  </section>

  <!-- ============ E-facturation ============ -->
  <section class="hp-section hp-reform-section" id="facturation-electronique">
    <div class="hp-shell">
      <div class="hp-reform-card reveal">
        <div class="hp-reform-copy">
          <p class="hp-kicker">Réforme 2026–2027</p>
          <h2>Préparez la facturation électronique sans attendre le dernier moment</h2>
          <p>
            Chiffr vous aide à structurer vos clients, vos factures, vos acomptes, vos signatures
            et vos informations de dossier pour aborder plus sereinement la transition vers la
            facturation électronique.
          </p>
          <div class="hp-reform-tags">
            <span>Réception dès 2026</span>
            <span>Émission TPE/PME dès 2027</span>
            <span>Données client mieux rangées</span>
          </div>
        </div>

        <div class="hp-reform-points">
          <article>
            <b>01</b>
            <strong>Factures mieux structurées</strong>
            <span>Devis, acompte, solde et facture finale restent reliés au dossier client.</span>
          </article>
          <article>
            <b>02</b>
            <strong>Mentions à préparer</strong>
            <span>SIREN client, adresse, opération, paiement : les informations clés sont plus faciles à suivre.</span>
          </article>
          <article>
            <b>03</b>
            <strong>Transition plus simple</strong>
            <span>Chiffr est pensé pour accompagner la future connexion aux plateformes agréées.</span>
          </article>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ Guides ============ -->
  <section class="hp-section hp-guides">
    <div class="hp-shell hp-guides-grid">
      <div class="hp-section-head left reveal">
        <p class="hp-kicker">Guides pratiques</p>
        <h2>Des ressources concrètes pour mieux structurer vos devis</h2>
        <p class="hp-section-sub">
          PAC, clim, acompte, relance, photos chantier : les guides Chiffr répondent
          aux questions terrain que les artisans se posent vraiment.
        </p>
      </div>

      <div class="hp-guide-links">
        {guideLinks.map(([label, href]) => (
          <a href={href} class="hp-guide-link">
            <strong>{label}</strong>
            <span aria-hidden="true">→</span>
          </a>
        ))}

        <a href="/guides-devis-artisans-energie" class="hp-guide-link all">
          <strong>Tous les guides devis artisans énergie</strong>
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ============ FAQ ============ -->
  <section class="hp-section hp-faq">
    <div class="hp-shell hp-faq-grid">
      <div class="hp-section-head left reveal">
        <p class="hp-kicker">FAQ</p>
        <h2>Questions fréquentes</h2>
      </div>

      <div class="hp-faq-list">
        {faqs.map(([question, answer]) => (
          <details class="hp-faq-item">
            <summary>
              {question}
              <span aria-hidden="true">
                <svg viewBox="0 0 16 16"><path d="m4 6 4 4 4-4" /></svg>
              </span>
            </summary>
            <p>{answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ CTA final ============ -->
  <section class="hp-final">
    <div class="hp-shell">
      <div class="hp-final-card reveal">
        <h2>Prêt à simplifier vos devis et votre suivi client ?</h2>
        <p>
          Modèles métier prêts à adapter, PDF premium, signature électronique,
          acomptes, factures et relances : tout est déjà en place.
        </p>

        <div class="hp-hero-actions centered">
          <a class="hp-btn light" href="/contact">
            Demander un accès
            <span aria-hidden="true">→</span>
          </a>
          <a class="hp-btn ghost" href="/fonctionnalites">
            Voir les fonctionnalités
          </a>
        </div>
      </div>
    </div>
  </section>

  <style is:inline>
    .hp-hero,
    .hp-benefits,
    .hp-section,
    .hp-cockpit,
    .hp-final {
      position: relative;
      overflow: hidden;
    }

    .hp-hero *,
    .hp-benefits *,
    .hp-section *,
    .hp-cockpit *,
    .hp-final * {
      box-sizing: border-box;
    }

    .hp-shell {
      width: min(1280px, 100% - 48px);
      margin: 0 auto;
    }

    /* ===== Typo commune ===== */
    .hp-kicker {
      margin: 0;
      color: var(--chiffr-teal);
      font-size: 13px;
      line-height: 1;
      font-weight: 650;
      text-transform: uppercase;
      letter-spacing: 0.12em;
    }

    .hp-kicker.light {
      color: #9FC4C2;
    }

    .hp-section-head {
      max-width: 720px;
      margin: 0 auto 48px;
      text-align: center;
    }

    .hp-section-head.left {
      margin: 0 0 36px;
      text-align: left;
    }

    /* !important : neutralise les règles h1/h2 globales héritées de compact.css */
    .hp-section-head h2,
    .hp-cockpit h2,
    .hp-reform-copy h2,
    .hp-final-card h2 {
      margin: 16px 0 0;
      font-family: var(--font-display);
      color: var(--chiffr-text);
      font-size: clamp(30px, 3.4vw, 44px) !important;
      line-height: 1.12 !important;
      letter-spacing: -0.01em !important;
      font-weight: 550;
    }

    .hp-section-sub {
      margin: 16px auto 0;
      color: var(--chiffr-text-soft);
      font-size: 17px;
      line-height: 1.65;
      font-weight: 450;
    }

    .hp-section {
      padding: 88px 0;
    }

    /* ===== Boutons ===== */
    .hp-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      min-height: 52px;
      padding: 0 26px;
      border-radius: 12px;
      font-size: 15.5px;
      line-height: 1;
      font-weight: 600;
      transition: filter 160ms ease, box-shadow 160ms ease, background 160ms ease;
    }

    .hp-btn.primary {
      color: #FFFFFF;
      background: linear-gradient(165deg, #0E2230, var(--chiffr-navy));
      border: 1px solid rgba(255, 255, 255, 0.08);
      box-shadow: 0 16px 36px -10px rgba(12, 20, 32, 0.45);
    }

    .hp-btn.primary:hover {
      filter: brightness(1.25);
    }

    .hp-btn.secondary {
      color: var(--chiffr-text);
      background: var(--chiffr-surface);
      border: 1px solid var(--chiffr-border-strong);
      box-shadow: 0 10px 24px -12px rgba(12, 20, 32, 0.2);
    }

    .hp-btn.secondary:hover {
      box-shadow: 0 14px 30px -12px rgba(12, 20, 32, 0.3);
    }

    .hp-btn.light {
      color: var(--chiffr-navy);
      background: #FFFFFF;
      box-shadow: 0 16px 36px -10px rgba(0, 0, 0, 0.35);
    }

    .hp-btn.light:hover {
      filter: brightness(0.96);
    }

    .hp-btn.ghost {
      color: #FFFFFF;
      background: rgba(255, 255, 255, 0.06);
      border: 1px solid rgba(255, 255, 255, 0.22);
    }

    .hp-btn.ghost:hover {
      background: rgba(255, 255, 255, 0.12);
    }

    .hp-play {
      display: inline-grid;
      place-items: center;
      width: 26px;
      height: 26px;
      border-radius: 999px;
      background: var(--chiffr-teal-soft);
      color: var(--chiffr-teal);
    }

    .hp-play svg {
      width: 14px;
      height: 14px;
      fill: currentColor;
    }

    /* ===== Hero ===== */
    .hp-hero {
      padding: 72px 0 96px;
      background:
        radial-gradient(900px 420px at 82% -10%, rgba(6, 72, 80, 0.07), transparent 70%),
        linear-gradient(180deg, var(--chiffr-bg-warm), var(--chiffr-bg));
    }

    .hp-hero-grid {
      display: grid;
      gap: 64px;
      align-items: center;
    }

    .hp-hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 9px 16px 9px 10px;
      border-radius: 999px;
      background: var(--chiffr-surface);
      border: 1px solid var(--chiffr-border);
      box-shadow: 0 8px 20px -10px rgba(12, 20, 32, 0.14);
      color: var(--chiffr-text-soft);
      font-size: 13.5px;
      line-height: 1.3;
      font-weight: 550;
      transition: box-shadow 160ms ease;
    }

    .hp-hero-badge:hover {
      box-shadow: 0 12px 26px -10px rgba(12, 20, 32, 0.22);
    }

    .hp-hero-badge-icon {
      display: inline-grid;
      place-items: center;
      width: 22px;
      height: 22px;
      flex: none;
      border-radius: 999px;
      background: var(--chiffr-success-soft);
      color: var(--chiffr-success);
    }

    .hp-hero-badge-icon svg {
      width: 13px;
      height: 13px;
      fill: none;
      stroke: currentColor;
      stroke-width: 2.4;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    .hp-hero h1 {
      margin: 26px 0 0;
      max-width: 640px !important;
      font-family: var(--font-display);
      color: var(--chiffr-navy);
      font-size: clamp(38px, 3.7vw, 52px) !important;
      line-height: 1.1 !important;
      letter-spacing: -0.015em !important;
      font-weight: 550;
    }

    .hp-hero h1 em {
      font-style: normal;
      color: var(--chiffr-teal);
    }

    .hp-hero-lead {
      margin: 22px 0 0;
      max-width: 520px;
      color: var(--chiffr-text-soft);
      font-size: 18px;
      line-height: 1.7;
      font-weight: 450;
    }

    .hp-hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
      margin-top: 34px;
    }

    .hp-hero-actions.centered {
      justify-content: center;
    }

    .hp-hero-checks {
      display: flex;
      flex-wrap: wrap;
      gap: 10px 22px;
      margin: 30px 0 0;
      padding: 0;
      list-style: none;
      color: var(--chiffr-text-soft);
      font-size: 13.5px;
      font-weight: 550;
    }

    .hp-hero-checks li::before {
      content: "✓";
      margin-right: 8px;
      color: var(--chiffr-success);
      font-weight: 700;
    }

    /* ===== Hero — composition devices ===== */
    .hp-hero-visual {
      position: relative;
      padding: 44px 30px 0;
    }

    .hp-stage {
      position: absolute;
      inset: 0 0 34px;
      border-radius: 28px;
      background:
        radial-gradient(420px 260px at 28% 18%, rgba(6, 72, 80, 0.1), transparent 70%),
        linear-gradient(155deg, #F2EDE3, #E9E4D9);
      border: 1px solid var(--chiffr-border);
    }

    .hp-device {
      margin: 0;
    }

    .hp-device img {
      display: block;
      width: 100%;
      height: auto;
    }

    .hp-laptop {
      position: relative;
      z-index: 2;
      width: 86%;
      margin-left: 2%;
    }

    .hp-laptop-screen {
      display: block;
      padding: 9px 9px 12px;
      border-radius: 16px 16px 4px 4px;
      background: linear-gradient(180deg, #1B2634, #0C1420);
      border: 1px solid rgba(255, 255, 255, 0.09);
      box-shadow: 0 42px 80px -30px rgba(12, 20, 32, 0.5);
    }

    .hp-laptop-screen img {
      border-radius: 8px 8px 2px 2px;
    }

    .hp-laptop-base {
      display: block;
      width: 112%;
      height: 13px;
      margin-left: -6%;
      border-radius: 3px 3px 14px 14px;
      background: linear-gradient(180deg, #E2DDD3, #B9B3A7);
      box-shadow: 0 18px 32px -14px rgba(12, 20, 32, 0.45);
      position: relative;
    }

    .hp-laptop-base::after {
      content: "";
      position: absolute;
      left: 50%;
      top: 0;
      transform: translateX(-50%);
      width: 13%;
      height: 5px;
      border-radius: 0 0 8px 8px;
      background: rgba(12, 20, 32, 0.18);
    }

    .hp-tablet {
      position: absolute;
      z-index: 3;
      right: 0;
      bottom: -16px;
      width: 44%;
      padding: 11px;
      border-radius: 18px;
      background: linear-gradient(180deg, #1B2634, #0C1420);
      border: 1px solid rgba(255, 255, 255, 0.1);
      box-shadow: 0 34px 64px -22px rgba(12, 20, 32, 0.55);
    }

    .hp-tablet img {
      border-radius: 9px;
    }

    .hp-phone {
      position: absolute;
      z-index: 4;
      left: 0;
      bottom: -26px;
      width: 17%;
      padding: 7px;
      border-radius: 24px;
      background: linear-gradient(180deg, #1B2634, #0C1420);
      border: 1px solid rgba(255, 255, 255, 0.1);
      box-shadow: 0 30px 56px -18px rgba(12, 20, 32, 0.55);
    }

    .hp-phone img {
      border-radius: 17px;
    }

    /* ===== Bandeau bénéfices ===== */
    .hp-benefits {
      padding: 40px 0;
      background: linear-gradient(180deg, var(--chiffr-navy), var(--chiffr-navy-soft));
      border-top: 1px solid rgba(255, 255, 255, 0.05);
    }

    .hp-benefits-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 28px;
    }

    .hp-benefit {
      display: flex;
      align-items: center;
      gap: 14px;
    }

    .hp-benefit + .hp-benefit {
      padding-left: 28px;
      border-left: 1px solid rgba(255, 255, 255, 0.1);
    }

    .hp-benefit-icon {
      display: inline-grid;
      place-items: center;
      flex: none;
      width: 44px;
      height: 44px;
      border-radius: 12px;
      background: rgba(159, 196, 194, 0.1);
      color: #9FC4C2;
    }

    .hp-benefit-icon svg {
      width: 22px;
      height: 22px;
      fill: none;
      stroke: currentColor;
      stroke-width: 1.8;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    .hp-benefit strong {
      display: block;
      color: #FFFFFF;
      font-size: 15px;
      line-height: 1.25;
      font-weight: 600;
    }

    .hp-benefit small {
      display: block;
      margin-top: 3px;
      color: rgba(255, 255, 255, 0.55);
      font-size: 12.5px;
      line-height: 1.35;
      font-weight: 450;
    }

    /* ===== Métiers ===== */
    .hp-trades-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 14px;
    }

    .hp-trade-card {
      display: grid;
      justify-items: start;
      gap: 4px;
      padding: 24px 22px;
      border-radius: 16px;
      background: var(--chiffr-surface);
      border: 1px solid var(--chiffr-border);
      box-shadow: 0 10px 28px -18px rgba(12, 20, 32, 0.16);
      transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
    }

    .hp-trade-card:hover {
      transform: translateY(-3px);
      border-color: var(--chiffr-border-strong);
      box-shadow: 0 22px 44px -18px rgba(12, 20, 32, 0.24);
    }

    .hp-trade-icon {
      display: inline-grid;
      place-items: center;
      width: 46px;
      height: 46px;
      margin-bottom: 12px;
      border-radius: 13px;
      background: var(--chiffr-teal-soft);
      color: var(--chiffr-teal);
    }

    .hp-trade-icon svg {
      width: 23px;
      height: 23px;
      fill: none;
      stroke: currentColor;
      stroke-width: 1.7;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    .hp-trade-card strong {
      color: var(--chiffr-text);
      font-size: 15.5px;
      font-weight: 600;
    }

    .hp-trade-card small {
      color: var(--chiffr-text-soft);
      font-size: 13px;
      font-weight: 450;
    }

    /* ===== Cockpit ===== */
    .hp-cockpit {
      padding: 96px 0;
      background:
        radial-gradient(720px 420px at 85% 10%, rgba(6, 72, 80, 0.28), transparent 70%),
        linear-gradient(180deg, var(--chiffr-navy), var(--chiffr-navy-soft));
    }

    .hp-cockpit-grid {
      display: grid;
      gap: 56px;
      align-items: center;
    }

    .hp-cockpit h2 {
      color: #FFFFFF;
      max-width: 480px;
    }

    .hp-cockpit-sub {
      margin: 18px 0 0;
      max-width: 460px;
      color: rgba(255, 255, 255, 0.62);
      font-size: 16.5px;
      line-height: 1.7;
      font-weight: 450;
    }

    .hp-cockpit-checks {
      display: grid;
      gap: 14px;
      margin: 28px 0 0;
      padding: 0;
      list-style: none;
    }

    .hp-cockpit-checks li {
      display: flex;
      align-items: center;
      gap: 12px;
      color: rgba(255, 255, 255, 0.85);
      font-size: 15.5px;
      font-weight: 500;
    }

    .hp-cockpit-checks span {
      display: inline-grid;
      place-items: center;
      flex: none;
      width: 24px;
      height: 24px;
      border-radius: 999px;
      background: rgba(159, 196, 194, 0.14);
      color: #9FC4C2;
    }

    .hp-cockpit-checks svg {
      width: 13px;
      height: 13px;
      fill: none;
      stroke: currentColor;
      stroke-width: 2.4;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    .hp-cockpit-copy .hp-btn {
      margin-top: 32px;
    }

    .hp-cockpit-visual {
      position: relative;
      padding: 0 0 40px 36px;
    }

    .hp-cockpit-shot {
      margin: 0;
      padding: 10px;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.12);
      box-shadow: 0 40px 90px -30px rgba(0, 0, 0, 0.65);
    }

    .hp-cockpit-shot img,
    .hp-cockpit-phone img {
      display: block;
      width: 100%;
      height: auto;
      border-radius: 10px;
    }

    .hp-cockpit-phone {
      position: absolute;
      left: 0;
      bottom: 0;
      width: 132px;
      margin: 0;
      padding: 6px;
      border-radius: 22px;
      background: linear-gradient(180deg, #1B2634, #0C1420);
      border: 1px solid rgba(255, 255, 255, 0.14);
      box-shadow: 0 30px 60px -18px rgba(0, 0, 0, 0.7);
    }

    .hp-cockpit-phone img {
      border-radius: 16px;
    }

    /* ===== Produit — zones showcase ===== */
    .hp-showcases {
      display: grid;
      gap: 28px;
      width: min(1440px, 100% - 48px);
      margin: 0 auto;
    }

    .hp-showcase {
      display: grid;
      gap: 44px;
      align-items: center;
      padding: clamp(24px, 3vw, 44px);
      border-radius: 24px;
      background: var(--chiffr-surface-warm);
      border: 1px solid var(--chiffr-border);
      box-shadow: 0 20px 50px -32px rgba(12, 20, 32, 0.2);
    }

    .hp-showcase-copy h3 {
      margin: 14px 0 0;
      font-family: var(--font-display);
      color: var(--chiffr-text);
      font-size: clamp(24px, 2.4vw, 31px);
      line-height: 1.18;
      letter-spacing: -0.01em;
      font-weight: 550;
    }

    .hp-showcase-text {
      margin: 14px 0 0;
      color: var(--chiffr-text-soft);
      font-size: 16px;
      line-height: 1.7;
      font-weight: 450;
    }

    .hp-showcase-points {
      display: grid;
      gap: 12px;
      margin: 22px 0 0;
      padding: 0;
      list-style: none;
    }

    .hp-showcase-points li {
      display: flex;
      align-items: flex-start;
      gap: 11px;
      color: var(--chiffr-text);
      font-size: 14.5px;
      line-height: 1.5;
      font-weight: 500;
    }

    .hp-showcase-points span {
      display: inline-grid;
      place-items: center;
      flex: none;
      width: 22px;
      height: 22px;
      margin-top: 1px;
      border-radius: 999px;
      background: var(--chiffr-teal-soft);
      color: var(--chiffr-teal);
    }

    .hp-showcase-points svg {
      width: 12px;
      height: 12px;
      fill: none;
      stroke: currentColor;
      stroke-width: 2.4;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    .hp-showcase-shot {
      margin: 0;
      overflow: hidden;
      border-radius: 14px;
      background: var(--chiffr-surface);
      border: 1px solid var(--chiffr-border-strong);
      box-shadow: 0 34px 70px -30px rgba(12, 20, 32, 0.35);
    }

    .hp-window-bar {
      display: flex;
      align-items: center;
      gap: 7px;
      padding: 0 14px;
      height: 34px;
      background: linear-gradient(180deg, #18222F, var(--chiffr-navy-soft));
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    }

    .hp-window-bar i {
      width: 9px;
      height: 9px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.22);
    }

    .hp-showcase-shot img {
      display: block;
      width: 100%;
      height: auto;
    }

    /* ===== E-facturation ===== */
    .hp-reform-section {
      padding-top: 0;
    }

    .hp-reform-card {
      display: grid;
      gap: 44px;
      align-items: center;
      padding: clamp(28px, 4vw, 56px);
      border-radius: 24px;
      background: var(--chiffr-surface-warm);
      border: 1px solid var(--chiffr-border);
      box-shadow: 0 24px 60px -30px rgba(12, 20, 32, 0.18);
    }

    .hp-reform-copy h2 {
      max-width: 520px;
      font-size: clamp(26px, 2.8vw, 36px) !important;
    }

    .hp-reform-copy p {
      margin: 16px 0 0;
      max-width: 520px;
      color: var(--chiffr-text-soft);
      font-size: 16px;
      line-height: 1.7;
      font-weight: 450;
    }

    .hp-reform-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 22px;
    }

    .hp-reform-tags span {
      display: inline-flex;
      padding: 8px 14px;
      border-radius: 999px;
      background: var(--chiffr-teal-soft);
      color: var(--chiffr-teal);
      font-size: 12.5px;
      font-weight: 600;
    }

    .hp-reform-points {
      display: grid;
      gap: 12px;
    }

    .hp-reform-points article {
      padding: 20px;
      border-radius: 16px;
      background: var(--chiffr-surface);
      border: 1px solid var(--chiffr-border);
    }

    .hp-reform-points b {
      display: inline-grid;
      place-items: center;
      width: 34px;
      height: 34px;
      border-radius: 10px;
      background: var(--chiffr-navy);
      color: #FFFFFF;
      font-size: 12.5px;
      font-weight: 600;
    }

    .hp-reform-points strong {
      display: block;
      margin-top: 13px;
      color: var(--chiffr-text);
      font-size: 16px;
      line-height: 1.25;
      font-weight: 600;
    }

    .hp-reform-points span {
      display: block;
      margin-top: 7px;
      color: var(--chiffr-text-soft);
      font-size: 14px;
      line-height: 1.55;
      font-weight: 450;
    }

    /* ===== Guides ===== */
    .hp-guides {
      padding-top: 0;
    }

    .hp-guides-grid {
      display: grid;
      gap: 40px;
      align-items: start;
    }

    .hp-guide-links {
      display: grid;
      gap: 10px;
    }

    .hp-guide-link {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 18px;
      min-height: 66px;
      padding: 14px 20px;
      border-radius: 14px;
      background: var(--chiffr-surface);
      border: 1px solid var(--chiffr-border);
      color: var(--chiffr-text);
      transition: transform 160ms ease, box-shadow 160ms ease;
    }

    .hp-guide-link:hover {
      transform: translateY(-2px);
      box-shadow: 0 16px 36px -20px rgba(12, 20, 32, 0.3);
    }

    .hp-guide-link strong {
      font-size: 15px;
      line-height: 1.35;
      font-weight: 550;
    }

    .hp-guide-link span {
      color: var(--chiffr-copper);
      font-weight: 600;
    }

    .hp-guide-link.all {
      background: var(--chiffr-navy);
      border-color: var(--chiffr-navy);
      color: #FFFFFF;
    }

    .hp-guide-link.all span {
      color: #9FC4C2;
    }

    /* ===== FAQ ===== */
    .hp-faq {
      padding-top: 0;
    }

    .hp-faq-grid {
      display: grid;
      gap: 40px;
      align-items: start;
    }

    .hp-faq-list {
      display: grid;
      gap: 10px;
    }

    .hp-faq-item {
      padding: 0 22px;
      border-radius: 14px;
      background: var(--chiffr-surface);
      border: 1px solid var(--chiffr-border);
    }

    .hp-faq-item summary {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      padding: 19px 0;
      cursor: pointer;
      list-style: none;
      color: var(--chiffr-text);
      font-size: 15.5px;
      line-height: 1.4;
      font-weight: 550;
    }

    .hp-faq-item summary::-webkit-details-marker {
      display: none;
    }

    .hp-faq-item summary span {
      display: inline-grid;
      place-items: center;
      flex: none;
      width: 26px;
      height: 26px;
      border-radius: 999px;
      background: var(--chiffr-bg);
      color: var(--chiffr-text-soft);
      transition: transform 160ms ease;
    }

    .hp-faq-item[open] summary span {
      transform: rotate(180deg);
    }

    .hp-faq-item summary svg {
      width: 13px;
      height: 13px;
      fill: none;
      stroke: currentColor;
      stroke-width: 2;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    .hp-faq-item p {
      margin: 0;
      padding: 0 0 20px;
      color: var(--chiffr-text-soft);
      font-size: 14.5px;
      line-height: 1.65;
      font-weight: 450;
    }

    /* ===== CTA final ===== */
    .hp-final {
      padding: 0 0 96px;
    }

    .hp-final-card {
      padding: clamp(48px, 6vw, 80px) clamp(24px, 5vw, 64px);
      border-radius: 28px;
      text-align: center;
      background:
        radial-gradient(640px 320px at 50% -20%, rgba(6, 72, 80, 0.45), transparent 75%),
        linear-gradient(180deg, var(--chiffr-navy), var(--chiffr-navy-soft));
      border: 1px solid rgba(255, 255, 255, 0.08);
      box-shadow: 0 40px 90px -40px rgba(12, 20, 32, 0.55);
    }

    .hp-final-card h2 {
      max-width: 620px;
      margin: 0 auto;
      color: #FFFFFF;
    }

    .hp-final-card > p {
      max-width: 540px;
      margin: 18px auto 0;
      color: rgba(255, 255, 255, 0.62);
      font-size: 16.5px;
      line-height: 1.7;
      font-weight: 450;
    }

    /* ===== Responsive ===== */
    @media (min-width: 1041px) {
      .hp-hero-grid {
        grid-template-columns: minmax(0, 11fr) minmax(0, 12fr);
      }

      .hp-cockpit-grid {
        grid-template-columns: minmax(0, 9fr) minmax(0, 11fr);
      }

      .hp-showcase {
        grid-template-columns: minmax(280px, 340px) minmax(0, 1fr);
      }

      .hp-reform-card {
        grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      }

      .hp-guides-grid,
      .hp-faq-grid {
        grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
      }
    }

    @media (max-width: 1040px) {
      .hp-hero {
        padding: 52px 0 72px;
      }

      .hp-hero-visual {
        margin-top: 8px;
      }

      .hp-benefits-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
      }

      .hp-benefit + .hp-benefit {
        padding-left: 0;
        border-left: 0;
      }

      .hp-trades-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .hp-section {
        padding: 64px 0;
      }

      .hp-cockpit {
        padding: 72px 0;
      }

      .hp-cockpit-visual {
        padding-left: 0;
      }

      .hp-cockpit-phone {
