const softwareSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Chiffr',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web, iOS, Android',
  description,
  offers: {
    '@type': 'Offer',
    priceCurrency: 'EUR',
    availability: 'https://schema.org/OnlineOnly',
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath="/fonctionnalites"
  schema={[softwareSchema, faqSchema]}
>
  <style is:inline>
    .features-page,
    .features-page * {
      box-sizing: border-box;
    }

    .features-page {
      color: var(--ink);
      overflow: hidden;
    }

    .features-shell {
      width: 100%;
      max-width: 1280px;
      margin: 0 auto;
    }

    .features-narrow {
      max-width: 920px;
    }

    .features-hero,
    .features-section,
    .features-cta {
      position: relative;
      padding: 72px 20px;
    }

    .features-hero {
      padding-top: 90px;
      padding-bottom: 78px;
    }

    .features-hero::before {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      background:
        radial-gradient(circle at 12% 10%, rgba(183, 110, 60, 0.14), transparent 28%),
        radial-gradient(circle at 86% 12%, rgba(18, 63, 61, 0.12), transparent 30%);
    }

    .features-grid {
      position: relative;
      z-index: 1;
      display: grid;
      gap: 54px;
      align-items: center;
    }

    .features-pill,
    .features-kicker {
      display: inline-flex;
      align-items: center;
      width: fit-content;
      margin: 0;
      padding: 8px 14px;
      border-radius: 999px;
      border: 1px solid rgba(18, 63, 61, 0.12);
      background: rgba(255, 255, 255, 0.78);
      color: var(--teal);
      font-size: 14px;
      line-height: 1.3;
      font-weight: 850;
    }

    .features-kicker {
      padding: 0;
      border: 0;
      background: transparent;
      color: var(--copper);
      font-size: 15px;
      letter-spacing: 0.01em;
    }

    .features-kicker.light {
      color: #f3dfcf;
    }

    .features-page h1 {
      margin: 26px 0 0;
      max-width: 920px;
      color: var(--teal);
      font-size: clamp(44px, 5.6vw, 82px);
      line-height: 1;
      letter-spacing: -0.055em;
      font-weight: 950;
    }

    .features-lead {
      margin: 24px 0 0;
      max-width: 760px;
      color: #536866;
      font-size: 20px;
      line-height: 1.72;
    }

    .features-actions {
      margin-top: 32px;
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
    }

    .features-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 52px;
      border-radius: 999px;
      padding: 16px 24px;
      font-weight: 950;
      line-height: 1;
      transition: transform 180ms ease, box-shadow 180ms ease, background 180ms ease;
    }

    .features-btn.primary {
      background: var(--teal);
      color: white;
      box-shadow: 0 18px 38px rgba(18, 63, 61, 0.18);
    }

    .features-btn.primary:hover {
      transform: translateY(-2px);
      background: #0d302e;
      box-shadow: 0 24px 48px rgba(18, 63, 61, 0.22);
    }

    .features-btn.secondary {
      color: var(--teal);
      background: rgba(255, 255, 255, 0.82);
      border: 1px solid rgba(18, 63, 61, 0.14);
    }

    .features-btn.secondary:hover {
      transform: translateY(-2px);
      background: white;
      box-shadow: 0 18px 38px rgba(18, 63, 61, 0.08);
    }

    .features-badge-row {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      align-items: center;
      margin-top: 22px;
    }

    .features-badge-row.compact-line {
      margin-top: 26px;
    }

    .features-reform-pill {
      display: inline-grid;
      gap: 2px;
      width: fit-content;
      max-width: 100%;
      padding: 10px 13px;
      border-radius: 999px;
      border: 1px solid rgba(18, 63, 61, 0.12);
      background: rgba(255, 255, 255, 0.82);
      color: var(--teal);
      box-shadow: 0 16px 38px rgba(18, 63, 61, 0.06);
    }

    .features-reform-pill.static {
      pointer-events: none;
    }

    .features-reform-pill strong {
      color: var(--teal);
      font-size: 13px;
      line-height: 1.05;
      font-weight: 950;
    }

    .features-reform-pill small {
      color: #667977;
      font-size: 11px;
      line-height: 1.2;
      font-weight: 800;
    }

    .features-proof {
      margin-top: 24px;
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      color: #667977;
      font-size: 13px;
      font-weight: 850;
    }

    .features-proof span::before {
      content: "✓";
      margin-right: 6px;
      color: var(--success);
    }

    .app-card,
    .feature-card,
    .panel,
    .workflow-card,
    .trade-card,
    .faq-card,
    .dashboard-card {
      border: 1px solid rgba(18, 63, 61, 0.12);
      background:
        linear-gradient(145deg, rgba(255, 253, 249, 0.96), rgba(255, 255, 255, 0.86)),
        radial-gradient(circle at top right, rgba(183, 110, 60, 0.1), transparent 44%);
      box-shadow:
        0 26px 74px rgba(18, 63, 61, 0.1),
        inset 0 1px 0 rgba(255, 255, 255, 0.9);
    }

    .app-card {
      position: relative;
      overflow: hidden;
      border-radius: 38px;
      padding: 22px;
      animation: floatCard 5.8s ease-in-out infinite;
    }

    .app-top {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 18px;
      margin-bottom: 14px;
    }

    .dots {
      display: flex;
      gap: 7px;
    }

    .dots span {
      width: 10px;
      height: 10px;
      border-radius: 999px;
      background: rgba(18, 63, 61, 0.18);
    }

    .dots span:nth-child(1) {
      background: #f3dfcf;
    }

    .dots span:nth-child(2) {
      background: #dceceb;
    }

    .dots span:nth-child(3) {
      background: rgba(47, 143, 107, 0.45);
    }

    .app-status {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      border-radius: 999px;
      background: rgba(18, 63, 61, 0.08);
      color: var(--teal);
      padding: 8px 12px;
      font-size: 13px;
      font-weight: 900;
    }

    .app-status span {
      width: 8px;
      height: 8px;
      border-radius: 999px;
      background: var(--success);
      box-shadow: 0 0 0 6px rgba(47, 143, 107, 0.12);
    }

    .app-hero {
      display: flex;
      justify-content: space-between;
      gap: 18px;
      padding: 24px;
      border-radius: 28px;
      color: white;
      background:
        radial-gradient(circle at 80% 0%, rgba(255, 255, 255, 0.12), transparent 34%),
        linear-gradient(135deg, #123f3d, #0d302e);
    }

    .app-hero p {
      margin: 0;
      color: rgba(255, 255, 255, 0.66);
      font-size: 14px;
      font-weight: 800;
    }

    .app-hero h2 {
      margin: 8px 0 0;
      color: white;
      font-size: 32px;
      line-height: 1.04;
      letter-spacing: -0.04em;
      font-weight: 950;
    }

    .app-badge {
      min-width: 108px;
      height: 82px;
      border-radius: 24px;
      display: grid;
      place-items: center;
      text-align: center;
      padding: 10px;
      background: rgba(255, 255, 255, 0.1);
    }

    .app-badge small {
      display: block;
      color: rgba(255, 255, 255, 0.62);
      font-size: 11px;
      font-weight: 850;
    }

    .app-badge strong {
      display: block;
      margin-top: 5px;
      color: white;
      font-size: 18px;
      line-height: 1;
      font-weight: 950;
    }

    .app-list {
      margin-top: 16px;
      display: grid;
      gap: 10px;
    }

    .app-row {
      display: grid;
      grid-template-columns: 36px 1fr auto;
      gap: 12px;
      align-items: center;
      padding: 13px;
      border-radius: 20px;
      background: rgba(255, 255, 255, 0.78);
      border: 1px solid rgba(18, 63, 61, 0.08);
      transition: transform 180ms ease, background 180ms ease, box-shadow 180ms ease;
    }

    .app-row:hover {
      transform: translateX(4px);
      background: white;
      box-shadow: 0 14px 34px rgba(18, 63, 61, 0.08);
    }

    .app-row b {
      width: 36px;
      height: 36px;
      border-radius: 14px;
      display: grid;
      place-items: center;
      background: var(--teal);
      color: white;
      font-size: 13px;
      font-weight: 950;
    }

    .app-row strong {
      color: var(--teal);
      font-size: 15px;
      font-weight: 950;
    }

    .app-row small {
      color: #667977;
      font-size: 12px;
      font-weight: 850;
      white-space: nowrap;
    }

    .app-mini {
      margin-top: 16px;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
    }

    .app-mini div {
      min-height: 88px;
      padding: 15px;
      border-radius: 22px;
      background: white;
    }

    .app-mini div:nth-child(1) {
      background: #f3dfcf;
    }

    .app-mini div:nth-child(2) {
      background: #dceceb;
    }

    .app-mini small {
      display: block;
      color: #667977;
      font-size: 12px;
      font-weight: 850;
    }

    .app-mini strong {
      display: block;
      margin-top: 7px;
      color: var(--teal);
      font-size: 16px;
      line-height: 1.25;
      font-weight: 950;
    }

    .section-head {
      max-width: 880px;
      margin-bottom: 34px;
    }

    .section-head h2,
    .panel h2,
    .features-cta h2,
    .dashboard-card h2 {
      margin: 14px 0 0;
      color: var(--teal);
      font-size: clamp(34px, 3.8vw, 56px);
      line-height: 1.06;
      letter-spacing: -0.048em;
      font-weight: 950;
    }

    .section-head p,
    .panel p,
    .features-cta p,
    .dashboard-card p {
      margin: 16px 0 0;
      color: #536866;
      font-size: 18px;
      line-height: 1.68;
    }

    .category-shell {
      display: grid;
      gap: 24px;
      align-items: start;
    }

    .category-tabs {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-bottom: 24px;
    }

    .category-tab {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 42px;
      border: 1px solid rgba(18, 63, 61, 0.12);
      border-radius: 999px;
      padding: 0 16px;
      background: rgba(255, 255, 255, 0.78);
      color: var(--teal);
      font: inherit;
      font-size: 13px;
      font-weight: 950;
      cursor: pointer;
      transition: transform 180ms ease, background 180ms ease, color 180ms ease, box-shadow 180ms ease;
    }

    .category-tab:hover {
      transform: translateY(-2px);
      background: white;
      box-shadow: 0 14px 34px rgba(18, 63, 61, 0.08);
    }

    .category-tab.active {
      background: var(--teal);
      color: white;
      border-color: var(--teal);
      box-shadow: 0 16px 34px rgba(18, 63, 61, 0.16);
    }

    .category-preview {
      position: sticky;
      top: 128px;
      border-radius: 34px;
      padding: 28px;
      background:
        radial-gradient(circle at 90% 0%, rgba(47, 143, 107, 0.16), transparent 38%),
