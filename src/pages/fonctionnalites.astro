const trades = [
  { label: 'Pompe à chaleur', href: '/logiciel-devis-pompe-a-chaleur' },
  { label: 'Climatisation', href: '/logiciel-devis-climatisation' },
  { label: 'Chauffage', href: '/logiciel-devis-chauffagiste' },
  { label: 'Frigoriste / CVC', href: '/logiciel-devis-frigoriste-cvc' },
  { label: 'VMC', href: '/logiciel-devis-vmc' },
  { label: 'IRVE', href: '/logiciel-devis-irve' },
  { label: 'Photovoltaïque', href: '/logiciel-devis-photovoltaique' },
  { label: 'Tarifs', href: '/tarifs' },
];

const faqs = [
  {
    question: 'Chiffr est-il un logiciel de devis généraliste ?',
    answer:
      'Chiffr peut gérer devis, factures, clients et suivi, mais son positionnement est métier : il est pensé pour les artisans énergie comme PAC, climatisation, chauffage, CVC, VMC, IRVE et solaire.',
  },
  {
    question: 'Chiffr prépare-t-il vraiment les lignes de devis ?',
