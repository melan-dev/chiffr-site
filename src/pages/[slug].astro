---
import QuoteModelVisual from '../components/visuals/QuoteModelVisual.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import QuoteModelPdfPreview from '../components/QuoteModelPdfPreview.astro';
import CompetitorAlternativePage from '../components/CompetitorAlternativePage.astro';
import UseCaseAlternativePage from '../components/UseCaseAlternativePage.astro';
import SeoGuidePage from '../components/SeoGuidePage.astro';
import { quoteModels } from '../data/quoteModels';
import { competitorAlternatives } from '../data/competitorAlternatives';
import { useCaseAlternatives } from '../data/useCaseAlternatives';
import { seoGuides } from '../data/seoGuides';

export function getStaticPaths() {
  return [
    ...quoteModels.map((model) => ({
      params: { slug: model.slug },
      props: {
        pageType: 'quoteModel',
        model,
      },
    })),

    ...competitorAlternatives.map((alternative) => ({
      params: { slug: alternative.slug },
      props: {
        pageType: 'competitorAlternative',
        alternative,
      },
    })),

    ...useCaseAlternatives.map((useCasePage) => ({
      params: { slug: useCasePage.slug },
      props: {
        pageType: 'useCaseAlternative',
        useCasePage,
      },
    })),

    ...seoGuides.map((seoGuide) => ({
      params: { slug: seoGuide.slug },
      props: {
        pageType: 'seoGuide',
        seoGuide,
      },
    })),
  ];
}

const { pageType, model, alternative, useCasePage, seoGuide } = Astro.props;

const faqSchema = model
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: model.faqs.map((item) => ({
        '@type': 'Question',
        name: item.question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: item.answer,
        },
      })),
    }
  : null;

const breadcrumbSchema = model
  ? {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Accueil',
          item: '/',
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'Modèles de devis',
          item: '/modeles-devis',
        },
        {
          '@type': 'ListItem',
          position: 3,
          name: model.h1,
          item: `/${model.slug}`,
        },
      ],
    }
  : null;
---

{pageType === 'seoGuide' && seoGuide && (
  <SeoGuidePage guide={seoGuide} />
)}

{pageType === 'useCaseAlternative' && useCasePage && (
  <UseCaseAlternativePage page={useCasePage} />
)}

{pageType === 'competitorAlternative' && alternative && (
  <CompetitorAlternativePage alternative={alternative} />
)}

{pageType === 'quoteModel' && model && (
  <BaseLayout
    title={model.title}
    description={model.metaDescription}
    canonicalPath={`/${model.slug}`}
    schema={[faqSchema, breadcrumbSchema].filter(Boolean)}
  >
    <style is:inline>
      .quote-model-page,
      .quote-model-page * {
        box-sizing: border-box;
      }

      .quote-model-page {
        color: var(--ink);
        overflow: hidden;
      }

      .qm-shell {
        width: 100%;
        max-width: 1280px;
        margin: 0 auto;
      }

      .qm-narrow {
        max-width: 920px;
      }

      .qm-hero,
      .qm-section,
      .qm-cta {
        position: relative;
        padding: 72px 20px;
      }

      .qm-hero {
        padding-top: 90px;
        padding-bottom: 76px;
      }

      .qm-hero::before {
        content: "";
        position: absolute;
        inset: 0;
        pointer-events: none;
        background:
          radial-gradient(circle at 88% 18%, rgba(12, 20, 32, 0.12), transparent 32%);
      }

      .qm-grid {
        position: relative;
        z-index: 1;
        display: grid;
        gap: 52px;
        align-items: center;
      }

      .qm-pill,
      .qm-kicker {
        display: inline-flex;
        width: fit-content;
        margin: 0;
        padding: 8px 14px;
        border-radius: 999px;
        border: 1px solid rgba(12, 20, 32, 0.12);
        background: rgba(255, 255, 255, 0.78);
        color: var(--teal);
        font-size: 14px;
        line-height: 1.3;
        font-weight: 600;
      }

      .qm-kicker {
        padding: 0;
        border: 0;
        background: transparent;
        color: var(--copper);
        font-size: 15px;
      }

      .qm-kicker.light {
        color: #F6E7DB;
      }

      .quote-model-page h1 {
        margin: 26px 0 0;
        max-width: 920px;
        color: var(--teal);
        font-size: clamp(42px, 5.5vw, 82px);
        line-height: 1;
        letter-spacing: -0.02em;
        font-weight: 650;
      }

      .qm-lead {
        margin: 24px 0 0;
        max-width: 760px;
        color: #5F6673;
        font-size: 20px;
        line-height: 1.72;
      }

      .qm-actions {
        margin-top: 32px;
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
      }

      .qm-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 52px;
        border-radius: 999px;
        padding: 16px 24px;
        font-weight: 650;
        line-height: 1;
        transition: transform 180ms ease, box-shadow 180ms ease, background 180ms ease;
      }

      .qm-btn.primary {
        color: white;
        background: var(--teal);
        box-shadow: 0 18px 38px rgba(12, 20, 32, 0.18);
      }

      .qm-btn.primary:hover {
        transform: translateY(-2px);
        background: #043840;
        box-shadow: 0 24px 48px rgba(12, 20, 32, 0.22);
      }

      .qm-btn.secondary {
        color: var(--teal);
        background: rgba(255, 255, 255, 0.82);
        border: 1px solid rgba(12, 20, 32, 0.14);
      }

      .qm-btn.secondary:hover {
        transform: translateY(-2px);
        background: white;
        box-shadow: 0 18px 38px rgba(12, 20, 32, 0.08);
      }

      .qm-checks {
        margin-top: 24px;
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        color: #5F6673;
        font-size: 13px;
        font-weight: 600;
      }

      .qm-checks span::before {
        content: "✓";
        margin-right: 6px;
        color: var(--success);
      }

      .qm-card,
      .qm-panel,
      .qm-line-table-card,
      .qm-mini-card,
      .qm-faq-card {
        border: 1px solid rgba(12, 20, 32, 0.12);
        background:
          linear-gradient(145deg, rgba(255, 252, 247, 0.96), rgba(255, 255, 255, 0.86));
        box-shadow:
          0 26px 74px rgba(12, 20, 32, 0.1),
          inset 0 1px 0 rgba(255, 255, 255, 0.9);
      }

      .qm-card {
        overflow: hidden;
        border-radius: 24px;
        padding: 22px;
        animation: qmFloat 5.8s ease-in-out infinite;
      }

      .qm-app-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 18px;
        margin-bottom: 14px;
      }

      .qm-dots {
        display: flex;
        gap: 7px;
      }

      .qm-dots span {
        width: 10px;
        height: 10px;
        border-radius: 999px;
        background: rgba(12, 20, 32, 0.18);
      }

      .qm-dots span:nth-child(1) {
        background: #F6E7DB;
      }

      .qm-dots span:nth-child(2) {
        background: #E6F1F0;
      }

      .qm-dots span:nth-child(3) {
        background: rgba(47, 125, 70, 0.45);
      }

      .qm-status {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 12px;
        border-radius: 999px;
        background: rgba(12, 20, 32, 0.08);
        color: var(--teal);
        font-size: 13px;
        font-weight: 650;
      }

      .qm-status span {
        width: 8px;
        height: 8px;
        border-radius: 999px;
        background: var(--success);
        box-shadow: 0 0 0 6px rgba(47, 125, 70, 0.12);
      }

      .qm-card-head {
        padding: 24px;
        border-radius: 18px;
        color: white;
        background:
          radial-gradient(circle at 80% 0%, rgba(255, 255, 255, 0.12), transparent 34%),
          linear-gradient(135deg, #0C1420, #043840);
      }

      .qm-card-head p {
        margin: 0;
        color: rgba(255, 255, 255, 0.66);
        font-size: 14px;
        font-weight: 600;
      }

      .qm-card-head h2 {
        margin: 8px 0 0;
        color: white;
        font-size: 34px;
        line-height: 1.04;
        letter-spacing: -0.02em;
        font-weight: 650;
      }

      .qm-card-steps {
        margin-top: 16px;
        display: grid;
        gap: 10px;
      }

      .qm-card-step {
        display: grid;
        grid-template-columns: 36px 1fr auto;
        gap: 12px;
        align-items: center;
        padding: 13px;
        border-radius: 20px;
        background: rgba(255, 255, 255, 0.78);
        border: 1px solid rgba(12, 20, 32, 0.08);
        transition: transform 180ms ease, background 180ms ease, box-shadow 180ms ease;
      }

      .qm-card-step:hover {
        transform: translateX(4px);
        background: white;
        box-shadow: 0 14px 34px rgba(12, 20, 32, 0.08);
      }

      .qm-card-step b {
        width: 36px;
        height: 36px;
        display: grid;
        place-items: center;
        border-radius: 14px;
        background: var(--teal);
        color: white;
        font-size: 13px;
        font-weight: 650;
      }

      .qm-card-step strong {
        color: var(--teal);
        font-size: 15px;
        font-weight: 650;
      }

      .qm-card-step small {
        color: #5F6673;
        font-size: 12px;
        font-weight: 600;
        white-space: nowrap;
      }

      .qm-mini-grid {
        margin-top: 16px;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
      }

      .qm-mini-grid div {
        min-height: 88px;
        padding: 15px;
        border-radius: 16px;
        background: white;
      }

      .qm-mini-grid div:nth-child(1) {
        background: #F6E7DB;
      }

      .qm-mini-grid div:nth-child(2) {
        background: #E6F1F0;
      }

      .qm-mini-grid small {
        display: block;
        color: #5F6673;
        font-size: 12px;
        font-weight: 600;
      }

      .qm-mini-grid strong {
        display: block;
        margin-top: 7px;
        color: var(--teal);
        font-size: 16px;
        line-height: 1.25;
        font-weight: 650;
      }

      .qm-section-head {
        max-width: 880px;
        margin-bottom: 34px;
      }

      .qm-section-head h2,
      .qm-panel h2,
      .qm-cta h2 {
        margin: 14px 0 0;
        color: var(--teal);
        font-size: clamp(34px, 3.8vw, 56px);
        line-height: 1.06;
        letter-spacing: -0.02em;
        font-weight: 650;
      }

      .qm-section-head p,
      .qm-panel p,
      .qm-cta p {
        margin: 16px 0 0;
        color: #5F6673;
        font-size: 18px;
        line-height: 1.68;
      }

      .qm-table-head {
        margin-top: 42px;
      }

      .qm-table-head h2 {
        font-size: clamp(30px, 3.2vw, 44px);
      }

      .qm-split {
        display: grid;
        gap: 22px;
      }

      .qm-panel {
        border-radius: 24px;
        padding: 34px;
      }

      .qm-panel.dark {
        background: var(--teal);
        color: white;
      }

      .qm-panel.dark h2 {
        color: white;
      }

      .qm-panel.dark p {
        color: rgba(255, 255, 255, 0.74);
      }

      .qm-list-grid,
      .qm-benefit-grid,
      .qm-related-grid {
        display: grid;
        gap: 12px;
      }

      .qm-mini-card,
      .qm-related-link {
        border-radius: 16px;
        padding: 17px 18px;
        color: var(--teal);
        font-weight: 650;
        transition: transform 180ms ease, background 180ms ease, box-shadow 180ms ease;
      }

      .qm-mini-card:hover,
      .qm-related-link:hover {
        transform: translateY(-3px);
        background: white;
        box-shadow: 0 18px 46px rgba(12, 20, 32, 0.09);
      }

      .qm-mini-card::before {
        content: "✓";
        display: inline-flex;
        width: 24px;
        height: 24px;
        align-items: center;
        justify-content: center;
        margin-right: 10px;
        border-radius: 999px;
        background: var(--success);
        color: white;
        font-size: 12px;
        font-weight: 650;
      }

      .qm-line-table-card {
        overflow: hidden;
        border-radius: 20px;
      }

      .qm-table-wrap {
        overflow-x: auto;
      }

      .qm-table {
        width: 100%;
        min-width: 980px;
        border-collapse: collapse;
        background: rgba(255, 255, 255, 0.72);
      }

      .qm-table th,
      .qm-table td {
        padding: 14px 16px;
        border-bottom: 1px solid rgba(12, 20, 32, 0.08);
        border-right: 1px solid rgba(12, 20, 32, 0.05);
        text-align: left;
        vertical-align: top;
        font-size: 13px;
        line-height: 1.4;
      }

      .qm-table th {
        background: var(--teal);
        color: white;
        font-weight: 650;
        white-space: nowrap;
      }

      .qm-table td:first-child {
        color: var(--teal);
        font-weight: 650;
      }

      .qm-table td:nth-child(5) {
        color: var(--copper);
        font-weight: 650;
        white-space: nowrap;
      }

      .qm-note {
        margin-top: 16px;
        padding: 16px 18px;
        border-radius: 16px;
        background: rgba(230, 241, 240, 0.72);
        color: #5F6673;
        font-size: 14px;
        line-height: 1.55;
        font-weight: 600;
      }

      .qm-warning {
        display: grid;
        gap: 14px;
        padding: 28px;
        border-radius: 24px;
        background:
          linear-gradient(145deg, rgba(255, 255, 255, 0.82), rgba(255, 252, 247, 0.76));
        border: 1px solid rgba(12, 20, 32, 0.1);
        box-shadow: 0 22px 60px rgba(12, 20, 32, 0.08);
      }

      .qm-warning-list {
        display: grid;
        gap: 10px;
      }

      .qm-warning-list span {
        display: flex;
        gap: 12px;
        align-items: flex-start;
        padding: 14px 16px;
        border-radius: 18px;
        background: rgba(255, 255, 255, 0.76);
        color: var(--teal);
        font-size: 14px;
        line-height: 1.4;
        font-weight: 600;
      }

      .qm-warning-list span::before {
        content: "!";
        width: 24px;
        height: 24px;
        flex: none;
        display: grid;
        place-items: center;
        border-radius: 999px;
        background: rgba(185, 97, 52, 0.18);
        color: var(--copper);
        font-weight: 650;
      }

      .qm-related-link {
        display: flex;
        justify-content: space-between;
        gap: 14px;
        text-decoration: none;
      }

      .qm-related-link span {
        color: var(--copper);
      }

      .qm-faq-list {
        display: grid;
        gap: 14px;
      }

      .qm-faq-card {
        border-radius: 18px;
        padding: 22px 24px;
        transition: transform 180ms ease, background 180ms ease, box-shadow 180ms ease;
      }

      .qm-faq-card:hover {
        transform: translateY(-2px);
        background: white;
        box-shadow: 0 18px 46px rgba(12, 20, 32, 0.08);
      }

      .qm-faq-card summary {
        cursor: pointer;
        color: var(--teal);
        font-size: 18px;
        line-height: 1.4;
        letter-spacing: -0.015em;
        font-weight: 650;
      }

      .qm-faq-card p {
        margin: 14px 0 0;
        color: #5F6673;
        font-size: 16px;
        line-height: 1.7;
      }

      .qm-cta {
        text-align: center;
      }

      .qm-cta .qm-shell {
        padding: 50px 28px;
        border-radius: 24px;
        border: 1px solid rgba(12, 20, 32, 0.1);
        background:
          linear-gradient(145deg, rgba(255, 255, 255, 0.78), rgba(255, 252, 247, 0.86));
        box-shadow: 0 26px 78px rgba(12, 20, 32, 0.1);
      }

      .qm-cta .qm-btn {
        margin-top: 26px;
      }

      .reveal,
      .reveal-card {
        opacity: 0;
        transform: translateY(18px);
        transition: opacity 620ms ease, transform 620ms cubic-bezier(0.16, 1, 0.3, 1);
      }

      .reveal.visible,
      .reveal-card.visible {
        opacity: 1;
        transform: translateY(0);
      }

      @keyframes qmFloat {
        0%,
        100% {
          transform: translateY(0);
        }

        50% {
          transform: translateY(-7px);
        }
      }

      @media (min-width: 760px) {
        .qm-list-grid,
        .qm-benefit-grid,
        .qm-related-grid {
          grid-template-columns: repeat(2, 1fr);
        }
      }

      @media (min-width: 1020px) {
        .qm-grid {
          grid-template-columns: 1.05fr 0.95fr;
        }

        .qm-split {
          grid-template-columns: 1fr 1fr;
        }

        .qm-list-grid {
          grid-template-columns: repeat(2, 1fr);
        }

        .qm-benefit-grid {
          grid-template-columns: repeat(3, 1fr);
        }

        .qm-related-grid {
          grid-template-columns: repeat(3, 1fr);
        }
      }

      @media (max-width: 720px) {
        .qm-hero,
        .qm-section,
        .qm-cta {
          padding: 52px 18px;
        }

        .qm-hero {
          padding-top: 58px;
        }

        .quote-model-page h1 {
          font-size: clamp(40px, 14vw, 58px);
        }

        .qm-lead {
          font-size: 18px;
        }

        .qm-card-step {
          grid-template-columns: 36px 1fr;
        }

        .qm-card-step small {
          grid-column: 2;
        }

        .qm-mini-grid {
          grid-template-columns: 1fr;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .quote-model-page *,
        .quote-model-page *::before,
        .quote-model-page *::after {
          transition-duration: 0.001ms !important;
          animation-duration: 0.001ms !important;
          animation-iteration-count: 1 !important;
        }

        .reveal,
        .reveal-card {
          opacity: 1;
          transform: none;
        }
      }
    </style>

    <div class="quote-model-page">
      <section class="qm-hero">
        <div class="qm-shell qm-grid">
          <div class="reveal">
            <p class="qm-pill">{model.trade} · Modèle de devis</p>

            <h1>{model.h1}</h1>

            <p class="qm-lead">{model.intro}</p>

            <div class="qm-actions">
              <a href="/contact" class="qm-btn primary">Demander un accès</a>
              <a href="/modeles-devis" class="qm-btn secondary">Voir les modèles de devis</a>
            </div>

            <div class="qm-checks">
              {model.heroChecks.map((check) => <span>{check}</span>)}
            </div>
          </div>

          <aside class="qm-card reveal" aria-label="Aperçu du modèle de devis">
            <div class="qm-app-top">
              <div class="qm-dots" aria-hidden="true">
                <span></span><span></span><span></span>
              </div>
              <div class="qm-status"><span></span> Modèle prêt</div>
            </div>

            <div class="qm-card-head">
              <p>{model.trade}</p>
              <h2>{model.useCase}</h2>
            </div>

            <div class="qm-card-steps">
              <div class="qm-card-step">
                <b>01</b>
                <strong>Lignes métier préparées</strong>
                <small>à adapter</small>
              </div>
              <div class="qm-card-step">
                <b>02</b>
                <strong>Prix à renseigner signalés</strong>
                <small>contrôle</small>
              </div>
              <div class="qm-card-step">
                <b>03</b>
                <strong>Photos chantier possibles</strong>
                <small>terrain</small>
              </div>
              <div class="qm-card-step">
                <b>04</b>
                <strong>Signature, acompte, facture</strong>
                <small>suivi</small>
              </div>
            </div>

            <div class="qm-mini-grid">
              <div>
                <small>Document</small>
                <strong>PDF premium</strong>
              </div>
              <div>
                <small>Client</small>
                <strong>Signature</strong>
              </div>
              <div>
                <small>Suite</small>
                <strong>Facture</strong>
              </div>
            </div>
          </aside>
        </div>
      </section>

      <section class="qm-section">
        <div class="qm-shell">
          <QuoteModelVisual currentPath={`/${model.slug}`} />
        </div>
      </section>


      <section class="qm-section">
        <div class="qm-shell qm-split">
          <article class="qm-panel dark reveal">
            <p class="qm-kicker light">Pour qui ?</p>
            <h2>Ce modèle sert aux artisans qui veulent gagner du temps sans perdre le contrôle.</h2>
            <p>
              Il donne une structure claire pour préparer un devis métier, mais chaque chantier
              reste à vérifier selon les contraintes techniques, l’accès, le matériel, le client,
              la TVA applicable et vos propres prix.
            </p>
          </article>

          <article class="qm-panel reveal">
            <p class="qm-kicker">Cas d’usage</p>
            <h2>{model.useCase}</h2>
            <p>
              Vous pouvez recopier une structure à la main… ou démarrer directement depuis un modèle
              métier dans Chiffr, avec les lignes importantes déjà organisées.
            </p>
          </article>
        </div>
      </section>

      <section class="qm-section">
        <div class="qm-shell">
          <div class="qm-section-head reveal">
            <p class="qm-kicker">Utilisateurs concernés</p>
            <h2>Pour qui est ce modèle ?</h2>
            <p>
              Cette page cible les recherches d’artisans qui cherchent un exemple concret de devis,
              mais aussi une façon plus simple de produire un document propre.
            </p>
          </div>

          <div class="qm-list-grid">
            {model.forWho.map((item) => (
