const description =
  'Mentions légales du site Chiffr : éditeur, contact, immatriculation, hébergement, propriété intellectuelle et responsabilité.';
---

<BaseLayout title={title} description={description} canonicalPath="/mentions-legales">
  <LegalPageShell
    eyebrow="Informations légales"
    title="Mentions légales"
    description="Cette page rassemble les informations d’identification relatives au site marketing Chiffr accessible sur chiffr-devis.fr."
  >
    <h2>Éditeur du site</h2>
    <div class="legal-card">
      <p><strong>Site :</strong> chiffr-devis.fr</p>
      <p><strong>Application :</strong> app.chiffr-devis.fr</p>
      <p><strong>Éditeur :</strong> Melan Valet, entrepreneur individuel</p>
      <p><strong>Nom commercial déclaré au RNE :</strong> LIVD</p>
      <p><strong>SIREN :</strong> 103 905 741</p>
      <p><strong>SIRET :</strong> 103 905 741 00015</p>
      <p><strong>Code APE :</strong> 5829C - Édition de logiciels applicatifs</p>
      <p><strong>Date d’immatriculation au RNE :</strong> 24/04/2026</p>
      <p><strong>Adresse de l’entreprise :</strong> 1444 Route de Mende, Bât. A - Appart. 94, 34090 Montpellier, France</p>
      <p><strong>Responsable de la publication :</strong> Melan Valet</p>
      <p><strong>Contact :</strong> <a href="mailto:melan@livdapps.com">melan@livdapps.com</a></p>
