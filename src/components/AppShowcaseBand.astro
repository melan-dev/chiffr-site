---
/**
 * Bandeau navy "section sombre produit" : copy + vrai screenshot app + CTA.
 * Factorisé pour les pages guides, alternatives et modèles de devis.
 */
interface Props {
  kicker?: string;
  title: string;
  text: string;
  image?: string;
  alt?: string;
  checks?: string[];
}

const {
  kicker = 'Demander un accès',
  title,
  text,
  image = '/images/app/app-suivi-desktop.webp',
  alt = 'Suivi commercial Chiffr : devis envoyés, signatures, acomptes et factures',
  checks = [
    'Modèles métier prêts à adapter',
    'PDF premium et signature électronique',
    'Acomptes, factures et relances',
  ],
} = Astro.props;
---

<section class="asb-section">
  <div class="asb-shell">
    <div class="asb-card reveal">
      <div class="asb-copy">
        <p class="asb-kicker">{kicker}</p>
        <h2>{title}</h2>
        <p class="asb-text">{text}</p>

        <ul class="asb-checks">
          {checks.map((check) => (
            <li>
              <span aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="m5 12.5 4.5 4.5L19 7.5" /></svg>
              </span>
              {check}
            </li>
          ))}
        </ul>

        <div class="asb-actions">
          <a class="asb-btn light" href="/contact">Demander un accès</a>
          <a class="asb-btn ghost" href="/fonctionnalites">Voir les fonctionnalités</a>
        </div>
      </div>

      <figure class="asb-shot">
        <span class="asb-bar" aria-hidden="true"><i></i><i></i><i></i></span>
        <img src={image} alt={alt} width="1800" height="908" loading="lazy" decoding="async" />
      </figure>
    </div>
  </div>
</section>

<style>
  .asb-section,
  .asb-section * {
    box-sizing: border-box;
  }

  .asb-section {
    padding: 36px 20px;
  }

  .asb-shell {
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
  }

  .asb-card {
    display: grid;
    gap: 40px;
    align-items: center;
    padding: clamp(28px, 4vw, 52px);
    border-radius: 24px;
    background:
      radial-gradient(640px 360px at 85% 0%, rgba(6, 72, 80, 0.4), transparent 72%),
      linear-gradient(180deg, var(--chiffr-navy), var(--chiffr-navy-soft));
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 36px 80px -38px rgba(12, 20, 32, 0.55);
  }

  .asb-kicker {
    margin: 0;
    color: #9FC4C2;
    font-size: 13px;
    line-height: 1;
    font-weight: 650;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .asb-card h2 {
    margin: 16px 0 0;
    max-width: 480px;
    color: #FFFFFF;
  }

  .asb-text {
    margin: 16px 0 0;
    max-width: 480px;
    color: rgba(255, 255, 255, 0.66);
    font-size: 16px;
    line-height: 1.7;
    font-weight: 450;
  }

  .asb-checks {
    display: grid;
    gap: 12px;
    margin: 24px 0 0;
    padding: 0;
    list-style: none;
  }

  .asb-checks li {
    display: flex;
    align-items: center;
    gap: 12px;
    color: rgba(255, 255, 255, 0.85);
    font-size: 15px;
    font-weight: 500;
  }

  .asb-checks span {
    display: inline-grid;
    place-items: center;
    flex: none;
    width: 24px;
    height: 24px;
    border-radius: 999px;
    background: rgba(159, 196, 194, 0.14);
    color: #9FC4C2;
  }

  .asb-checks svg {
    width: 13px;
    height: 13px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2.4;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .asb-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 30px;
  }

  .asb-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 50px;
    padding: 0 24px;
    border-radius: 12px;
    font-size: 15px;
    line-height: 1;
    font-weight: 600;
    transition: transform 160ms ease, background 160ms ease, filter 160ms ease;
  }

  .asb-btn.light {
    color: var(--chiffr-navy);
    background: #FFFFFF;
    box-shadow: 0 16px 36px -12px rgba(0, 0, 0, 0.4);
  }

  .asb-btn.light:hover {
    transform: translateY(-2px);
    background: #F1EDE5;
  }

  .asb-btn.ghost {
    color: #FFFFFF;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.22);
  }

  .asb-btn.ghost:hover {
    transform: translateY(-2px);
    background: rgba(255, 255, 255, 0.12);
  }

  .asb-shot {
    margin: 0;
    overflow: hidden;
    border-radius: 14px;
    border: 1px solid rgba(255, 255, 255, 0.14);
    box-shadow: 0 36px 80px -28px rgba(0, 0, 0, 0.65);
    background: var(--chiffr-surface);
  }

  .asb-bar {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 0 14px;
    height: 32px;
    background: linear-gradient(180deg, #18222F, var(--chiffr-navy-soft));
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .asb-bar i {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.22);
  }

  .asb-shot img {
    display: block;
    width: 100%;
    height: auto;
  }

  @media (min-width: 1020px) {
    .asb-card {
      grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    }
  }
</style>
