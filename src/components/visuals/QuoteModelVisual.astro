---
import { getVisualStoryByPath } from '../../data/visualAssets';

interface Props {
  currentPath?: string;
  title?: string;
  text?: string;
}

const {
  currentPath = Astro.url.pathname,
  title = 'Un modèle plus concret, avec le chantier en tête',
  text = 'Le devis ne part pas d’une page blanche : lignes utiles, photos chantier, signature, acompte et factures restent dans un dossier clair.',
} = Astro.props;

const story = getVisualStoryByPath(currentPath);
---

<aside class="quote-model-visual">
  <img
    src={story.hero.src}
    alt={story.hero.alt}
    width="1800"
    height="1200"
    loading="lazy"
    decoding="async"
  />

  <div class="quote-model-visual-card">
    <p>Modèle Chiffr</p>
    <h2>{title}</h2>
    <span>{text}</span>
  </div>
</aside>

<style>
  .quote-model-visual,
  .quote-model-visual * {
    box-sizing: border-box;
  }

  .quote-model-visual {
    position: relative;
    overflow: hidden;
    min-height: 430px;
    display: grid;
    align-items: end;
    border-radius: 24px;
    isolation: isolate;
    background: var(--teal);
    box-shadow: 0 28px 82px rgba(12, 20, 32, 0.14);
    border: 1px solid rgba(12, 20, 32, 0.1);
  }

  .quote-model-visual::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(180deg, rgba(8, 29, 28, 0.03), rgba(8, 29, 28, 0.78));
  }

  .quote-model-visual img {
    position: absolute;
    inset: 0;
    z-index: -2;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .quote-model-visual-card {
    padding: clamp(24px, 4vw, 36px);
    color: white;
  }

  .quote-model-visual-card p {
    margin: 0 0 12px;
    color: #F6E7DB;
    font-size: 13px;
    font-weight: 650;
  }

  .quote-model-visual-card h2 {
    margin: 0;
    max-width: 680px;
    color: white;
    font-size: clamp(30px, 4vw, 52px);
    line-height: 1.02;
    letter-spacing: -0.02em;
    font-weight: 650;
  }

  .quote-model-visual-card span {
    display: block;
    max-width: 640px;
    margin-top: 14px;
    color: rgba(255, 255, 255, 0.78);
    font-size: 16px;
    line-height: 1.6;
    font-weight: 550;
  }
</style>
