---
import { imgDims } from '../../data/imageDimensions';

interface Props {
  variant?: string;
  eyebrow?: string;
  title: string;
  text: string;
  ctaLabel?: string;
  ctaHref?: string;
  imageSrc?: string;
  imageAlt?: string;
  reversed?: boolean;
}

const {
  variant = 'guides',
  eyebrow = 'Chiffr en situation',
  title,
  text,
  ctaLabel = 'Découvrir Chiffr',
  ctaHref = '/fonctionnalites',
  imageSrc,
  imageAlt,
  reversed = false,
} = Astro.props;

// Vitrine produit = vrai screenshot net de l'app, encadré navigateur
// (plus de composite IA avec écran muddy). Un écran réel par variante.
const APP_SHOTS: Record<string, { src: string; alt: string }> = {
  modeles: { src: '/images/app/app-devis-desktop.webp', alt: 'Liste des devis dans Chiffr : statuts, montants et relances' },
  guides: { src: '/images/app/app-accueil-desktop.webp', alt: 'Accueil Chiffr : priorités du jour et suivi commercial' },
  tarifs: { src: '/images/app/app-suivi-desktop.webp', alt: 'Suivi commercial Chiffr : devis, signatures, acomptes et factures' },
  contact: { src: '/images/app/app-clients-desktop.webp', alt: 'Fiches clients Chiffr : dossiers, devis et historique' },
  alternatives: { src: '/images/app/app-devis-desktop.webp', alt: 'Liste des devis Chiffr : un outil pensé pour le chantier' },
  dashboard: { src: '/images/app/app-suivi-desktop.webp', alt: 'Tableau de suivi Chiffr : ce qu’il reste à signer, facturer et encaisser' },
};

const shot =
  imageSrc && imageAlt
    ? { src: imageSrc, alt: imageAlt }
    : APP_SHOTS[variant] ?? APP_SHOTS.guides;
---

<article class:list={['page-photo-showcase', { reversed }]}>
  <div class="page-photo-showcase-image">
    <figure class="pps-shot">
      <span class="pps-bar" aria-hidden="true"><i></i><i></i><i></i></span>
      <img
        src={shot.src}
        alt={shot.alt}
        {...imgDims(shot.src)}
        loading="lazy"
        decoding="async"
      />
    </figure>
  </div>

  <div class="page-photo-showcase-copy">
    <p>{eyebrow}</p>
    <h2>{title}</h2>
    <span>{text}</span>
    <a href={ctaHref}>{ctaLabel} →</a>
  </div>
</article>

<style>
  .page-photo-showcase,
  .page-photo-showcase * {
    box-sizing: border-box;
  }

  .page-photo-showcase {
    overflow: hidden;
    display: grid;
    gap: 0;
    border-radius: 24px;
    border: 1px solid rgba(12, 20, 32, 0.1);
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.84), rgba(255, 252, 247, 0.9));
    box-shadow:
      0 30px 90px rgba(12, 20, 32, 0.11),
      inset 0 1px 0 rgba(255, 255, 255, 0.88);
  }

  .page-photo-showcase-image {
    position: relative;
    display: grid;
    place-items: center;
    padding: clamp(22px, 3vw, 40px);
    background:
      radial-gradient(120% 120% at 80% 0%, rgba(6, 72, 80, 0.1), transparent 60%),
      linear-gradient(160deg, var(--chiffr-bg-warm), #FFFFFF);
  }

  .pps-shot {
    margin: 0;
    width: 100%;
    overflow: hidden;
    border-radius: 14px;
    border: 1px solid var(--chiffr-border);
    background: var(--chiffr-surface);
    box-shadow: 0 36px 80px -30px rgba(12, 20, 32, 0.45);
    transition: transform 520ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .page-photo-showcase:hover .pps-shot {
    transform: translateY(-4px);
  }

  .pps-bar {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 0 14px;
    height: 34px;
    background: linear-gradient(180deg, #18222F, var(--chiffr-navy-soft));
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .pps-bar i {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.22);
  }

  .pps-shot img {
    display: block;
    width: 100%;
    height: auto;
  }

  .page-photo-showcase-copy {
    display: grid;
    align-content: center;
    padding: clamp(24px, 4vw, 44px);
  }

  .page-photo-showcase-copy p {
    margin: 0;
    color: var(--copper);
    font-size: 14px;
    line-height: 1;
    font-weight: 650;
  }

  .page-photo-showcase-copy h2 {
    margin: 14px 0 0;
    color: var(--teal);
    font-size: clamp(30px, 3.9vw, 54px);
    line-height: 1.03;
    letter-spacing: -0.02em;
    font-weight: 650;
  }

  .page-photo-showcase-copy span {
    display: block;
    margin-top: 16px;
    color: #5F6673;
    font-size: 17px;
    line-height: 1.66;
    font-weight: 550;
  }

  .page-photo-showcase-copy a {
    display: inline-flex;
    width: fit-content;
    margin-top: 22px;
    padding: 13px 18px;
    border-radius: 999px;
    background: var(--teal);
    color: white;
    font-weight: 650;
    box-shadow: 0 18px 38px rgba(12, 20, 32, 0.16);
  }

  @media (min-width: 900px) {
    .page-photo-showcase {
      grid-template-columns: 1.02fr 0.98fr;
      min-height: 440px;
    }

    .page-photo-showcase.reversed {
      grid-template-columns: 0.98fr 1.02fr;
    }

    .page-photo-showcase.reversed .page-photo-showcase-image {
      order: 2;
    }
  }

  @media (max-width: 720px) {
    .page-photo-showcase {
      border-radius: 20px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pps-shot {
      transition-duration: 0.001ms !important;
    }
  }
</style>
