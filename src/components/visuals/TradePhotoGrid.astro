---
import { tradeVisuals } from '../../data/visualAssets';

const trades = [
  ['pac', 'PAC', '/logiciel-devis-pompe-a-chaleur'],
  ['clim', 'Climatisation', '/logiciel-devis-climatisation'],
  ['chauffage', 'Chauffage', '/logiciel-devis-chauffagiste'],
  ['cvc', 'CVC', '/logiciel-devis-frigoriste-cvc'],
  ['vmc', 'VMC', '/logiciel-devis-vmc'],
  ['irve', 'IRVE', '/logiciel-devis-irve'],
  ['solaire', 'Solaire', '/logiciel-devis-photovoltaique'],
] as const;
---

<div class="trade-photo-grid-premium">
  {trades.map(([key, label, href]) => {
    const visual = tradeVisuals[key];
    return (
      <a href={href} class="trade-photo-premium-card">
        <img src={visual.hero.src} alt={visual.hero.alt} width="1400" height="933" loading="lazy" decoding="async" />
        <strong>{label}</strong>
        <span>{visual.eyebrow}</span>
      </a>
    );
  })}
</div>

<style>
  .trade-photo-grid-premium,
  .trade-photo-grid-premium * {
    box-sizing: border-box;
  }

  .trade-photo-grid-premium {
    display: grid;
    gap: 14px;
  }

  .trade-photo-premium-card {
    position: relative;
    min-height: 250px;
    overflow: hidden;
    display: grid;
    align-items: end;
    padding: 20px;
    border-radius: 28px;
    isolation: isolate;
    background: var(--teal);
    box-shadow: 0 20px 60px rgba(18, 63, 61, 0.1);
  }

  .trade-photo-premium-card::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(180deg, transparent, rgba(8, 29, 28, 0.78));
  }

  .trade-photo-premium-card img {
    position: absolute;
    inset: 0;
    z-index: -2;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 420ms ease;
  }

  .trade-photo-premium-card:hover img {
    transform: scale(1.035);
  }

  .trade-photo-premium-card strong {
    color: white;
    font-size: 24px;
    line-height: 1;
    font-weight: 950;
  }

  .trade-photo-premium-card span {
    display: block;
    margin-top: 6px;
    color: rgba(255, 255, 255, 0.72);
    font-size: 13px;
    font-weight: 850;
  }

  @media (min-width: 760px) {
    .trade-photo-grid-premium {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1100px) {
    .trade-photo-grid-premium {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>
