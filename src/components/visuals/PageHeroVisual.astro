---
import { getVisualStoryByPath } from '../../data/visualAssets';

interface Props {
  currentPath?: string;
  title?: string;
  eyebrow?: string;
  text?: string;
  ctaLabel?: string;
  ctaHref?: string;
  imageSrc?: string;
  imageAlt?: string;
}

const {
  currentPath = Astro.url.pathname,
  title,
  eyebrow,
  text,
  ctaLabel,
  ctaHref,
  imageSrc,
  imageAlt,
} = Astro.props;

const story = getVisualStoryByPath(currentPath);
const finalTitle = title ?? story.title;
const finalEyebrow = eyebrow ?? story.eyebrow;
const finalText = text ?? story.text;
const finalCtaLabel = ctaLabel ?? story.ctaLabel;
const finalCtaHref = ctaHref ?? story.ctaHref;
const finalImageSrc = imageSrc ?? story.hero.src;
const finalImageAlt = imageAlt ?? story.hero.alt;
---

<section class="page-hero-visual" aria-label={finalEyebrow}>
  <img
    src={finalImageSrc}
    alt={finalImageAlt}
    width="1800"
    height="1200"
    loading="lazy"
    decoding="async"
  />

  <div class="page-hero-visual-copy">
    <p>{finalEyebrow}</p>
    <h2>{finalTitle}</h2>
    <span>{finalText}</span>
    <a href={finalCtaHref}>{finalCtaLabel} →</a>
  </div>
</section>

<style>
  .page-hero-visual,
  .page-hero-visual * {
    box-sizing: border-box;
  }

  .page-hero-visual {
    position: relative;
    overflow: hidden;
    min-height: 420px;
    display: grid;
    align-items: end;
    border-radius: 36px;
    isolation: isolate;
    background: var(--teal);
    box-shadow: 0 30px 90px rgba(12, 20, 32, 0.16);
  }

  .page-hero-visual::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(180deg, rgba(8, 29, 28, 0.04), rgba(8, 29, 28, 0.78)),
      radial-gradient(circle at 86% 0%, rgba(185, 97, 52, 0.24), transparent 34%);
  }

  .page-hero-visual img {
    position: absolute;
    inset: 0;
    z-index: -2;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .page-hero-visual-copy {
    max-width: 760px;
    padding: clamp(24px, 5vw, 44px);
    color: white;
  }

  .page-hero-visual-copy p {
    margin: 0 0 12px;
    color: #F6E7DB;
    font-size: 14px;
    font-weight: 950;
  }

  .page-hero-visual-copy h2 {
    margin: 0;
    color: white;
    font-size: clamp(30px, 4vw, 56px);
    line-height: 1.02;
    letter-spacing: -0.052em;
    font-weight: 950;
  }

  .page-hero-visual-copy span {
    display: block;
    margin-top: 14px;
    color: rgba(255, 255, 255, 0.76);
    font-size: 17px;
    line-height: 1.62;
    font-weight: 700;
  }

  .page-hero-visual-copy a {
    display: inline-flex;
    margin-top: 22px;
    padding: 13px 17px;
    border-radius: 999px;
    background: white;
    color: var(--teal);
    font-weight: 950;
  }
</style>
