---
import PageHeroVisual from './visuals/PageHeroVisual.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import AppShowcaseBand from './AppShowcaseBand.astro';
import type { UseCaseAlternativePage as UseCaseAlternativeData } from '../data/useCaseAlternatives';

interface Props {
  page: UseCaseAlternativeData;
}

const { page } = Astro.props;

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: page.faqs.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Accueil',
      item: '/',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Alternatives logiciels devis bâtiment',
      item: '/alternatives-logiciels-devis-batiment',
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: page.h1,
      item: `/${page.slug}`,
    },
  ],
};
---

<BaseLayout
  title={page.title}
  description={page.metaDescription}
  canonicalPath={`/${page.slug}`}
  schema={[faqSchema, breadcrumbSchema]}
>
  <style is:inline>
    .usecase-page,
    .usecase-page * {
      box-sizing: border-box;
    }

    .usecase-page {
      color: var(--ink);
      overflow: hidden;
    }

    .usecase-shell {
      width: 100%;
      max-width: 1280px;
      margin: 0 auto;
    }

    .usecase-narrow {
      max-width: 920px;
    }

    .usecase-hero,
    .usecase-section,
    .usecase-cta {
      position: relative;
      padding: 72px 20px;
    }

    .usecase-hero {
      padding-top: 88px;
      padding-bottom: 76px;
    }

    .usecase-hero::before {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      background:
        radial-gradient(circle at 88% 18%, rgba(12, 20, 32, 0.12), transparent 32%);
    }

    .usecase-grid {
      position: relative;
      z-index: 1;
      display: grid;
      gap: 46px;
      align-items: center;
    }

    .usecase-pill,
    .usecase-kicker {
      display: inline-flex;
      width: fit-content;
      margin: 0;
      padding: 8px 14px;
      border-radius: 999px;
      border: 1px solid rgba(12, 20, 32, 0.12);
      background: rgba(255, 255, 255, 0.78);
      color: var(--teal);
      font-size: 14px;
      line-height: 1.3;
      font-weight: 600;
    }

    .usecase-kicker {
      padding: 0;
      border: 0;
      background: transparent;
      color: var(--copper);
      font-size: 15px;
    }

    .usecase-kicker.light {
      color: #F6E7DB;
    }

    .usecase-page h1 {
      margin: 26px 0 0;
      max-width: 940px;
      color: var(--teal);
      font-size: clamp(42px, 5.4vw, 78px);
      line-height: 1;
      letter-spacing: -0.02em;
      font-weight: 650;
    }

    .usecase-lead {
      margin: 22px 0 0;
      max-width: 780px;
      color: #5F6673;
      font-size: 20px;
      line-height: 1.7;
    }

    .usecase-actions {
      margin-top: 30px;
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
    }

    .usecase-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 52px;
      border-radius: 999px;
      padding: 16px 24px;
      font-weight: 650;
      line-height: 1;
      transition: transform 180ms ease, box-shadow 180ms ease, background 180ms ease;
    }

    .usecase-btn.primary {
      color: white;
      background: var(--teal);
      box-shadow: 0 18px 38px rgba(12, 20, 32, 0.18);
    }

    .usecase-btn.primary:hover {
      transform: translateY(-2px);
      background: #043840;
      box-shadow: 0 24px 48px rgba(12, 20, 32, 0.22);
    }

    .usecase-btn.secondary {
      color: var(--teal);
      background: rgba(255, 255, 255, 0.82);
      border: 1px solid rgba(12, 20, 32, 0.14);
    }

    .usecase-btn.secondary:hover {
      transform: translateY(-2px);
      background: white;
      box-shadow: 0 18px 38px rgba(12, 20, 32, 0.08);
    }

    .usecase-proof {
      margin-top: 22px;
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      color: #5F6673;
      font-size: 13px;
      font-weight: 600;
    }

    .usecase-proof span::before {
      content: "✓";
      margin-right: 6px;
      color: var(--success);
    }

    .usecase-card,
    .usecase-panel,
    .usecase-mini-card,
    .usecase-comparison-card,
    .usecase-link-card,
    .usecase-faq-card {
      border: 1px solid rgba(12, 20, 32, 0.12);
      background:
        linear-gradient(145deg, rgba(255, 252, 247, 0.96), rgba(255, 255, 255, 0.86));
      box-shadow:
        0 26px 74px rgba(12, 20, 32, 0.1),
        inset 0 1px 0 rgba(255, 255, 255, 0.9);
    }

    .usecase-card {
      overflow: hidden;
      border-radius: 24px;
      padding: 22px;
    }

    .usecase-card-top {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 18px;
      margin-bottom: 14px;
    }

    .usecase-dots {
      display: flex;
      gap: 7px;
    }

    .usecase-dots span {
      width: 10px;
      height: 10px;
      border-radius: 999px;
      background: rgba(12, 20, 32, 0.18);
    }

    .usecase-dots span:nth-child(1) {
      background: #F6E7DB;
    }

    .usecase-dots span:nth-child(2) {
      background: #E6F1F0;
    }

    .usecase-dots span:nth-child(3) {
      background: rgba(47, 125, 70, 0.45);
    }

    .usecase-status {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(12, 20, 32, 0.08);
      color: var(--teal);
      font-size: 13px;
      font-weight: 650;
    }

    .usecase-status span {
      width: 8px;
      height: 8px;
      border-radius: 999px;
      background: var(--success);
      box-shadow: 0 0 0 6px rgba(47, 125, 70, 0.12);
    }

    .usecase-card-head {
      padding: 24px;
      border-radius: 18px;
      color: white;
      background:
        radial-gradient(circle at 80% 0%, rgba(255, 255, 255, 0.12), transparent 34%),
        linear-gradient(135deg, #0C1420, #043840);
    }

    .usecase-card-head p {
      margin: 0;
      color: rgba(255, 255, 255, 0.66);
      font-size: 14px;
      font-weight: 600;
    }

    .usecase-card-head h2 {
      margin: 8px 0 0;
      color: white;
      font-size: 34px;
      line-height: 1.04;
      letter-spacing: -0.02em;
      font-weight: 650;
    }

    .usecase-card-list {
      margin-top: 16px;
      display: grid;
      gap: 10px;
    }

    .usecase-card-row {
      display: grid;
      grid-template-columns: 36px 1fr auto;
      gap: 12px;
      align-items: center;
      padding: 13px;
      border-radius: 20px;
      background: rgba(255, 255, 255, 0.78);
      border: 1px solid rgba(12, 20, 32, 0.08);
    }

    .usecase-card-row b {
      width: 36px;
      height: 36px;
      display: grid;
      place-items: center;
      border-radius: 14px;
      background: var(--teal);
      color: white;
      font-size: 13px;
      font-weight: 650;
    }

    .usecase-card-row strong {
      color: var(--teal);
      font-size: 15px;
      font-weight: 650;
    }

    .usecase-card-row small {
      color: #5F6673;
      font-size: 12px;
      font-weight: 600;
      white-space: nowrap;
    }

    .usecase-section-head {
      max-width: 880px;
      margin-bottom: 30px;
    }

    .usecase-section-head h2,
    .usecase-panel h2,
    .usecase-cta h2 {
      margin: 14px 0 0;
      color: var(--teal);
      font-size: clamp(34px, 3.8vw, 56px);
      line-height: 1.06;
      letter-spacing: -0.02em;
      font-weight: 650;
    }

    .usecase-section-head p,
    .usecase-panel p,
    .usecase-cta p {
      margin: 14px 0 0;
      color: #5F6673;
      font-size: 18px;
      line-height: 1.65;
    }

    .usecase-split {
      display: grid;
      gap: 22px;
    }

    .usecase-panel {
      border-radius: 24px;
      padding: 34px;
    }

    .usecase-panel.dark {
      background: var(--teal);
      color: white;
    }

    .usecase-panel.dark h2 {
      color: white;
    }

    .usecase-panel.dark p {
      color: rgba(255, 255, 255, 0.74);
    }

    .usecase-panel-note {
      margin-top: 20px;
      padding: 18px;
      border-radius: 20px;
      background: rgba(255, 255, 255, 0.74);
      border: 1px solid rgba(12, 20, 32, 0.1);
    }

    .usecase-panel.dark .usecase-panel-note {
      background: rgba(255, 255, 255, 0.1);
      border-color: rgba(255, 255, 255, 0.14);
    }

    .usecase-panel-note strong {
      display: block;
      color: var(--teal);
      font-size: 14px;
      font-weight: 650;
    }

    .usecase-panel.dark .usecase-panel-note strong {
      color: white;
    }

    .usecase-panel-note p {
      margin-top: 7px;
      font-size: 14px;
      line-height: 1.55;
    }

    .usecase-list-grid,
    .usecase-benefit-grid,
    .usecase-link-grid {
      display: grid;
      gap: 14px;
    }

    .usecase-mini-card {
      border-radius: 16px;
      padding: 20px;
      color: var(--teal);
      font-weight: 650;
      transition: transform 180ms ease, background 180ms ease, box-shadow 180ms ease;
    }

    .usecase-mini-card:hover {
      transform: translateY(-3px);
      background: white;
      box-shadow: 0 18px 46px rgba(12, 20, 32, 0.09);
    }

    .usecase-mini-card::before {
      content: "✓";
      display: inline-grid;
      width: 24px;
      height: 24px;
      place-items: center;
      margin-right: 10px;
      border-radius: 999px;
      background: var(--success);
      color: white;
      font-size: 12px;
      font-weight: 650;
    }

    .usecase-comparison-card {
      overflow: hidden;
      border-radius: 20px;
    }

    .usecase-table-wrap {
      overflow-x: auto;
    }

    .usecase-table {
      width: 100%;
      min-width: 880px;
      border-collapse: collapse;
      background: rgba(255, 255, 255, 0.74);
    }

    .usecase-table th,
    .usecase-table td {
      padding: 16px;
      border-bottom: 1px solid rgba(12, 20, 32, 0.08);
      border-right: 1px solid rgba(12, 20, 32, 0.05);
      text-align: left;
      vertical-align: top;
      font-size: 14px;
      line-height: 1.45;
    }

    .usecase-table th {
      background: var(--teal);
      color: white;
      font-weight: 650;
    }

    .usecase-table td:first-child {
      color: var(--teal);
      font-weight: 650;
      white-space: nowrap;
    }

    .usecase-table td:nth-child(3) {
      color: #111827;
      font-weight: 600;
    }

    .usecase-note {
      margin-top: 16px;
      padding: 16px 18px;
      border-radius: 16px;
      background: rgba(230, 241, 240, 0.72);
      color: #5F6673;
      font-size: 14px;
      line-height: 1.55;
      font-weight: 600;
    }

    .usecase-link-card {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 14px;
      border-radius: 16px;
      padding: 17px 18px;
      color: var(--teal);
      font-weight: 650;
      text-decoration: none;
      transition: transform 180ms ease, background 180ms ease, box-shadow 180ms ease;
    }

    .usecase-link-card:hover {
      transform: translateY(-3px);
      background: white;
      box-shadow: 0 18px 46px rgba(12, 20, 32, 0.09);
    }

    .usecase-link-card span {
      color: var(--copper);
      font-weight: 650;
    }

    .usecase-faq-list {
      display: grid;
      gap: 14px;
    }

    .usecase-faq-card {
      border-radius: 18px;
      padding: 22px 24px;
      transition: transform 180ms ease, background 180ms ease, box-shadow 180ms ease;
    }

    .usecase-faq-card:hover {
      transform: translateY(-2px);
      background: white;
      box-shadow: 0 18px 46px rgba(12, 20, 32, 0.08);
    }

    .usecase-faq-card summary {
      cursor: pointer;
      color: var(--teal);
      font-size: 18px;
      line-height: 1.4;
      letter-spacing: -0.015em;
      font-weight: 650;
    }

    .usecase-faq-card p {
      margin: 14px 0 0;
      color: #5F6673;
      font-size: 16px;
      line-height: 1.7;
    }

    .usecase-cta {
      text-align: center;
    }

    .usecase-cta .usecase-shell {
      padding: 50px 28px;
      border-radius: 24px;
      border: 1px solid rgba(12, 20, 32, 0.1);
      background:
        linear-gradient(145deg, rgba(255, 255, 255, 0.78), rgba(255, 252, 247, 0.86));
      box-shadow: 0 26px 78px rgba(12, 20, 32, 0.1);
    }

    .usecase-cta .usecase-btn {
      margin-top: 24px;
    }

    @media (min-width: 760px) {
      .usecase-list-grid,
      .usecase-benefit-grid,
      .usecase-link-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (min-width: 1020px) {
      .usecase-grid {
        grid-template-columns: 1.05fr 0.95fr;
      }

      .usecase-split {
        grid-template-columns: 1fr 1fr;
      }

      .usecase-list-grid {
        grid-template-columns: repeat(3, 1fr);
      }

      .usecase-benefit-grid {
        grid-template-columns: repeat(3, 1fr);
      }

      .usecase-link-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    @media (max-width: 720px) {
      .usecase-hero,
      .usecase-section,
      .usecase-cta {
        padding: 52px 18px;
      }

      .usecase-hero {
        padding-top: 58px;
      }

      .usecase-page h1 {
        font-size: clamp(40px, 14vw, 58px);
      }

      .usecase-lead {
        font-size: 18px;
      }

      .usecase-actions {
        display: grid;
      }

      .usecase-btn {
        width: 100%;
      }

      .usecase-card-row {
        grid-template-columns: 36px 1fr;
      }

      .usecase-card-row small {
        grid-column: 2;
      }

      .usecase-panel {
        padding: 24px;
        border-radius: 18px;
      }
    }
  </style>

  <div class="usecase-page">
    <section class="usecase-hero">
      <div class="usecase-shell usecase-grid">
        <div>
          <p class="usecase-pill">{page.eyebrow}</p>

          <h1>{page.h1}</h1>

          <p class="usecase-lead">{page.intro}</p>

          <div class="usecase-actions">
            <a href="https://chiffr.web.app" class="usecase-btn primary">
              Essayer gratuitement
            </a>
            <a href="/modeles-devis" class="usecase-btn secondary">
              Voir les modèles de devis
            </a>
          </div>

          <div class="usecase-proof">
            <span>Modèles métier</span>
            <span>PAC · Clim · VMC · IRVE</span>
            <span>PDF premium</span>
            <span>Signature</span>
            <span>Acompte</span>
            <span>Factures</span>
          </div>
        </div>

        <aside class="usecase-card" aria-label={`Aperçu ${page.eyebrow}`}>
          <div class="usecase-card-top">
            <div class="usecase-dots" aria-hidden="true">
              <span></span><span></span><span></span>
            </div>
            <div class="usecase-status"><span></span> Usage guidé</div>
          </div>

          <div class="usecase-card-head">
            <p>Intention de recherche</p>
            <h2>{page.searchIntent}</h2>
          </div>

          <div class="usecase-card-list">
            <div class="usecase-card-row">
              <b>01</b>
              <strong>Partir d’un modèle métier</strong>
              <small>PAC · Clim</small>
            </div>
            <div class="usecase-card-row">
              <b>02</b>
              <strong>Compléter les lignes utiles</strong>
              <small>devis</small>
            </div>
            <div class="usecase-card-row">
              <b>03</b>
              <strong>Joindre les photos chantier</strong>
              <small>terrain</small>
            </div>
            <div class="usecase-card-row">
              <b>04</b>
              <strong>Signer, encaisser, facturer</strong>
              <small>suivi</small>
            </div>
          </div>
        </aside>
      </div>
    </section>

    <section class="usecase-section">
      <div class="usecase-shell">
        <PageHeroVisual
          currentPath={`/${page.slug}`}
          eyebrow="Usage concret"
          title="Un logiciel utile seulement s’il simplifie le dossier client"
          text="Chiffr relie le devis, les lignes métier, les photos, la signature, l’acompte, la facture et la relance pour éviter les oublis après l’envoi."
          ctaLabel="Voir les fonctionnalités"
          ctaHref="/fonctionnalites"
        />
      </div>
    </section>


    <section class="usecase-section">
      <div class="usecase-shell usecase-split">
        <article class="usecase-panel dark">
          <p class="usecase-kicker light">Le problème</p>
          <h2>{page.problemTitle}</h2>
          <p>{page.problemText}</p>
        </article>

        <article class="usecase-panel">
          <p class="usecase-kicker">La réponse Chiffr</p>
          <h2>Un outil plus guidé pour les artisans énergie</h2>
          <p>{page.chiffrPromise}</p>

          <div class="usecase-panel-note">
            <strong>Principe Chiffr</strong>
            <p>
              Chiffr prépare la structure, mais l’artisan garde toujours la main sur les prix,
              les quantités, les options, les conditions et les choix techniques.
            </p>
          </div>
        </article>
      </div>
    </section>

    <section class="usecase-section">
      <div class="usecase-shell">
        <div class="usecase-section-head">
          <p class="usecase-kicker">Pour qui ?</p>
          <h2>Les profils concernés par cette recherche</h2>
          <p>
            Cette page répond à une intention précise : trouver un outil plus simple,
            plus concret ou plus spécialisé pour gérer ses devis et factures.
          </p>
        </div>

        <div class="usecase-list-grid">
          {page.forWho.map((item) => (
            <div class="usecase-mini-card">{item}</div>
          ))}
        </div>
      </div>
    </section>

    <section class="usecase-section">
      <div class="usecase-shell">
        <div class="usecase-section-head">
          <p class="usecase-kicker">Ce que Chiffr apporte</p>
          <h2>Pas une page blanche : une structure métier exploitable</h2>
          <p>
            Le but est de gagner du temps sans envoyer un devis vague. Chiffr aide à préparer
            les bons postes, puis à faire avancer le dossier après l’envoi.
          </p>
        </div>

        <div class="usecase-benefit-grid">
          {page.chiffrBenefits.map((item) => (
            <div class="usecase-mini-card">{item}</div>
          ))}
        </div>
      </div>
    </section>

    <section class="usecase-section">
      <div class="usecase-shell">
        <div class="usecase-section-head">
          <p class="usecase-kicker">Comparatif par usage</p>
          <h2>Comparer un outil classique et Chiffr selon le besoin réel</h2>
          <p>
            Ce tableau ne classe pas les logiciels. Il clarifie les différences de positionnement
            selon l’usage recherché par l’artisan.
          </p>
        </div>

        <div class="usecase-comparison-card">
          <div class="usecase-table-wrap">
            <table class="usecase-table">
              <thead>
                <tr>
                  <th>Critère</th>
                  <th>Outil classique</th>
                  <th>Chiffr</th>
                </tr>
              </thead>

              <tbody>
                {page.comparisonRows.map((row) => (
                  <tr>
                    <td>{row.label}</td>
                    <td>{row.classicTool}</td>
                    <td>{row.chiffr}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

        <p class="usecase-note">
          Les besoins varient selon votre métier, votre organisation et vos habitudes de chiffrage.
          Le bon outil est celui qui vous aide à produire un devis clair plus vite, sans perdre le contrôle.
        </p>
      </div>
    </section>

    <section class="usecase-section">
      <div class="usecase-shell">
        <div class="usecase-section-head">
          <p class="usecase-kicker">Cas métiers énergie</p>
          <h2>Des usages concrets pour PAC, clim, VMC, IRVE et solaire</h2>
        </div>

        <div class="usecase-benefit-grid">
          {page.energyUseCases.map((item) => (
            <div class="usecase-mini-card">{item}</div>
          ))}
        </div>
      </div>
    </section>

    <section class="usecase-section">
      <div class="usecase-shell">
        <div class="usecase-section-head">
          <p class="usecase-kicker">Pages liées</p>
          <h2>Continuer avec les pages utiles</h2>
        </div>

        <div class="usecase-link-grid">
          {page.relatedLinks.map((item) => (
            <a href={item.href} class="usecase-link-card">
              {item.label}
              <span>→</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <AppShowcaseBand
      title="Vous voulez un outil plus guidé pour vos devis énergie ?"
      text="Chiffr vous aide à partir d’un modèle métier, ajouter vos lignes, joindre vos photos, générer un PDF premium, faire signer, demander un acompte et facturer."
    />

    <section class="usecase-section">
      <div class="usecase-shell usecase-narrow">
        <div class="usecase-section-head">
          <p class="usecase-kicker">FAQ</p>
          <h2>Questions fréquentes</h2>
        </div>

        <div class="usecase-faq-list">
          {page.faqs.map((item) => (
            <details class="usecase-faq-card">
              <summary>{item.question}</summary>
              <p>{item.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  </div>
</BaseLayout>