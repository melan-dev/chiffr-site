---
interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  ogImage?: string;
  noindex?: boolean;
  schema?: Record<string, any> | Record<string, any>[];
}

const {
  title,
  description,
  canonicalPath = Astro.url.pathname,
  ogImage = '/og/chiffr-default.png',
  noindex = false,
  schema,
} = Astro.props;

const siteUrl = Astro.site ?? new URL('https://chiffr-devis.fr');
const canonicalUrl = new URL(canonicalPath, siteUrl).toString().replace(/\/$/, '');
const absoluteOgImage = new URL(ogImage, siteUrl).toString();
const baseSchemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'Chiffr',
    url: siteUrl.toString().replace(/\/$/, ''),
    logo: new URL('/favicon.svg', siteUrl).toString(),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Chiffr',
    url: siteUrl.toString().replace(/\/$/, ''),
    inLanguage: 'fr-FR',
  },
];

const pageSchemas = Array.isArray(schema) ? schema : schema ? [schema] : [];
const schemas = [...baseSchemas, ...pageSchemas];
---

<title>{title}</title>
<meta name="description" content={description} />
<meta name="theme-color" content="#123f3d" />
<link rel="canonical" href={canonicalUrl} />

{noindex && <meta name="robots" content="noindex,nofollow" />}

<meta property="og:type" content="website" />
<meta property="og:locale" content="fr_FR" />
<meta property="og:site_name" content="Chiffr" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:image" content={absoluteOgImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={absoluteOgImage} />

{schemas.map((item) => (
  <script type="application/ld+json" set:html={JSON.stringify(item)} />
))}