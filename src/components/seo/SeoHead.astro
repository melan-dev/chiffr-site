---
interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  ogImage?: string;
  noindex?: boolean;
  schema?: Record<string, any> | Record<string, any>[];
}

const {
  title,
  description,
  canonicalPath = Astro.url.pathname,
  ogImage = '/og/chiffr-default.png',
  noindex = false,
  schema,
} = Astro.props;

const siteUrl = Astro.site ?? new URL('https://chiffr-devis.fr');
// Canonical AVEC slash final (Cloudflare Pages sert les pages en /page/ et
// redirige /page → /page/ en 308). Sans slash, le canonical pointait vers une
// URL qui redirige → « Erreur liée à des redirections » dans Search Console.
const canonicalUrl = new URL(canonicalPath, siteUrl).toString().replace(/\/+$/, '') + '/';
const absoluteOgImage = new URL(ogImage, siteUrl).toString();
const toAbsoluteSiteUrl = (value: string) => new URL(value, siteUrl).toString();

const absolutizeSchemaUrls = (value: any): any => {
  if (Array.isArray(value)) {
    return value.map(absolutizeSchemaUrls);
  }

  if (value && typeof value === 'object') {
    return Object.fromEntries(
      Object.entries(value).map(([key, entry]) => {
        if (
          (key === 'item' || key === 'url' || key === '@id') &&
          typeof entry === 'string' &&
          entry.startsWith('/')
        ) {
          return [key, toAbsoluteSiteUrl(entry)];
        }

        return [key, absolutizeSchemaUrls(entry)];
      }),
    );
  }

  return value;
};

const rawSchemas = Array.isArray(schema) ? schema : schema ? [schema] : [];
const schemas = rawSchemas.map(absolutizeSchemaUrls);
---

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />

{noindex && <meta name="robots" content="noindex,nofollow" />}

<meta property="og:type" content="website" />
<meta property="og:site_name" content="Chiffr" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:image" content={absoluteOgImage} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={absoluteOgImage} />

{schemas.map((item) => (
  <script type="application/ld+json" set:html={JSON.stringify(item)} />
))}