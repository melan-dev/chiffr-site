---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getVisualStoryByPath } from '../data/visualAssets';
import { imgDims } from '../data/imageDimensions';
import { APP_URL, CTA_TRUST } from '../config';

type TextCard = {
  title: string;
  text: string;
};

type LinkCard = {
  label: string;
  href: string;
};

type FaqItem = {
  question: string;
  answer: string;
};

type AppStep = {
  title: string;
  text: string;
  status: string;
};

type AppMini = {
  label: string;
  value: string;
};

interface Props {
  title: string;
  description: string;
  canonicalPath: string;
  pill: string;
  h1: string;
  lead: string;
  checks: string[];
  appTitle: string;
  appSubtitle: string;
  appBadgeLabel: string;
  appBadgeValue: string;
  appStripLabel: string;
  appStripText: string;
  appSteps: AppStep[];
  appMini: AppMini[];
  problemTitle: string;
  problemText: string;
  solutionTitle: string;
  solutionText: string;
  quoteKicker: string;
  quoteTitle: string;
  quoteIntro: string;
  quoteLines: TextCard[];
  featuresKicker: string;
  featuresTitle: string;
  featuresIntro: string;
  features: TextCard[];
  usecaseTitle: string;
  usecaseIntro: string;
  useCases: TextCard[];
  photoTitle: string;
  photoIntro: string;
  photoItems: string[];
  internalTitle: string;
  internalIntro: string;
  internalLinks: LinkCard[];
  ctaTitle: string;
  ctaText: string;
  faqTitle: string;
  faqs: FaqItem[];
  chantierType?: {
    title: string;
    intro: string;
    steps: string[];
    note?: string;
  };
  comingSoon?: boolean;
}

const {
  title,
  description,
  canonicalPath,
  pill,
  h1,
  lead,
  checks,
  appTitle,
  appSubtitle,
  appBadgeLabel,
  appBadgeValue,
  appStripLabel,
  appStripText,
  appSteps,
  appMini,
  problemTitle,
  problemText,
  solutionTitle,
  solutionText,
  quoteKicker,
  quoteTitle,
  quoteIntro,
  quoteLines,
  featuresKicker,
  featuresTitle,
  featuresIntro,
  features,
  usecaseTitle,
  usecaseIntro,
  useCases,
  photoTitle,
  photoIntro,
  photoItems,
  internalTitle,
  internalIntro,
  internalLinks,
  ctaTitle,
  ctaText,
  faqTitle,
  faqs,
  chantierType,
  comingSoon,
} = Astro.props;

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};

// Fil d'Ariane (BreadcrumbList) : Accueil → page métier. Les URLs relatives sont
// absolutisées par SeoHead. On garde le slash final (cohérent avec le canonical).
const trailPath = `/${canonicalPath.replace(/^\/+|\/+$/g, '')}/`;
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: '/' },
    { '@type': 'ListItem', position: 2, name: pill, item: trailPath },
  ],
};

// Entité produit (SoftwareApplication) — données VÉRIDIQUES uniquement : offre
// gratuite + plans 19→89 € HT/mois (aucune note/avis inventé, pas d'aggregateRating).
const softwareSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Chiffr',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web, Android, iOS, Windows',
  url: '/',
  description,
  offers: {
    '@type': 'AggregateOffer',
    priceCurrency: 'EUR',
    lowPrice: '0',
    highPrice: '89',
    offerCount: '4',
  },
};

const visualStory = getVisualStoryByPath(canonicalPath);

// Accent subtil par métier (DA §10/§146) : nuance constante, dérivée du
// teal/cuivre — froide pour clim/CVC/VMC/IRVE, chaude pour PAC/chauffage/solaire.
// Appliqué à la pastille du hero (point + filet), sans toucher au système
// teal=action / cuivre=marque.
const METIER_ACCENTS: Record<string, string> = {
  'pac-air-air': '#C8702A',
  'renovation-energetique': '#B96134',
  'plombier-chauffagiste': '#C8702A',
  'electricien': '#0E7C86',
  'pompe-a-chaleur': '#B96134',
  'climatisation': '#0E7C86',
  'chauffagiste': '#C8702A',
  'frigoriste-cvc': '#0C6B73',
  'vmc': '#2A8A8A',
  'irve': '#0E8A7A',
  'photovoltaique': '#C98A2A',
  'chauffe-eau-thermodynamique': '#A85A30',
};
const metierAccent =
  Object.entries(METIER_ACCENTS).find(([key]) => canonicalPath.includes(key))?.[1] ??
  'var(--chiffr-copper)';

// Mot-clé métier du H1 souligné cuivre (DA §15, « 1 accent par titre »).
// Surlignage sûr : si le terme n'est pas dans le H1, on rend le titre tel quel.
const METIER_TERMS: Record<string, string> = {
  'pac-air-air': 'air/air',
  'renovation-energetique': 'rénovation énergétique',
  'plombier-chauffagiste': 'plombier-chauffagiste',
  'electricien': 'électricien',
  'pompe-a-chaleur': 'pompe à chaleur',
  'climatisation': 'climatisation',
  'chauffagiste': 'chauffagistes',
  'frigoriste-cvc': 'CVC',
  'vmc': 'VMC',
  'irve': 'IRVE',
  'photovoltaique': 'photovoltaïque',
  'chauffe-eau-thermodynamique': 'chauffe-eau thermodynamique',
};
const metierTerm =
  Object.entries(METIER_TERMS).find(([key]) => canonicalPath.includes(key))?.[1] ?? '';
// Lead-magnet (audit conversion) : exemple de devis PDF du métier (rendu réel
// de l'app). Repli pour les visiteurs pas encore prêts à s'inscrire.
const EXEMPLE_MAP: Record<string, string> = {
  'pac-air-air': 'pac',
  'plombier-chauffagiste': 'chauffagiste',
  'pompe-a-chaleur': 'pac',
  'climatisation': 'climatisation',
  'chauffagiste': 'chauffagiste',
  'frigoriste-cvc': 'frigoriste-cvc',
  'vmc': 'vmc',
  'irve': 'irve',
  'photovoltaique': 'photovoltaique',
  'chauffe-eau-thermodynamique': 'chauffe-eau-thermodynamique',
};
const exempleSlug =
  Object.entries(EXEMPLE_MAP).find(([key]) => canonicalPath.includes(key))?.[1] ?? null;
const exempleHref = exempleSlug ? `/exemples/devis-${exempleSlug}.pdf` : null;

let h1Parts: { before: string; match: string; after: string } | null = null;
if (metierTerm) {
  const idx = h1.toLowerCase().lastIndexOf(metierTerm.toLowerCase());
  if (idx >= 0) {
    h1Parts = {
      before: h1.slice(0, idx),
      match: h1.slice(idx, idx + metierTerm.length),
      after: h1.slice(idx + metierTerm.length),
    };
  }
}
---

<BaseLayout title={title} description={description} canonicalPath={canonicalPath} schema={[faqSchema, breadcrumbSchema, softwareSchema]}>
  <section class="hero trade-hero-simple" style={`--metier-accent: ${metierAccent}`}>
    <div class="shell hero-grid trade-hero-simple-grid">
      <div class="hero-copy reveal">
        <nav class="trade-crumb" aria-label="Fil d'Ariane" style="display:flex;gap:8px;align-items:center;font-size:12.5px;color:#6E6A62;margin-bottom:14px;flex-wrap:wrap;">
          <a href="/" style="color:#6E6A62;text-decoration:none;">Accueil</a>
          <span aria-hidden="true" style="color:#B7AE9E;">›</span>
          <span style="color:#3A4A4D;">{pill}</span>
        </nav>
        <p class="pill">
          {pill}
          {comingSoon && <span class="soon-badge">Bientôt</span>}
        </p>

        <h1>
          {h1Parts ? (
            <>{h1Parts.before}<span class="h1-accent">{h1Parts.match}</span>{h1Parts.after}</>
          ) : (
            h1
          )}
        </h1>

        <p class="lead">{lead}</p>

        {comingSoon && (
          <p class="soon-note">
            <strong>Bientôt dans Chiffr.</strong> Le préréglage métier {appTitle.toLowerCase()} arrive prochainement.
            Chiffr est déjà disponible pour les métiers de l’énergie — créez votre compte et nous vous préviendrons dès que ce métier est prêt.
          </p>
        )}

        <div class="actions">
          <a class="btn primary" href={APP_URL}>{comingSoon ? 'Créer mon compte Chiffr' : `Créer mon devis ${appTitle}`}</a>
          <a class="btn secondary" href="#lignes-devis">Voir les lignes à prévoir</a>
        </div>

        <p class="cta-trust">{CTA_TRUST}</p>

        <div class="checks">
          {checks.map((check) => <span>{check}</span>)}
        </div>

        {exempleHref && (
          <a class="trade-example-link" href={exempleHref} download>
            <span class="trade-example-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24"><path d="M7 3h7l4 4v14H7z"/><path d="M14 3v4h4"/><path d="M9.5 13h5M9.5 16h5"/></svg>
            </span>
            Voir un exemple de devis {appTitle} (PDF)
            <span aria-hidden="true">→</span>
          </a>
        )}
      </div>

      <aside class="trade-hero-capture reveal" aria-label={`Aperçu d’un devis ${pill} dans Chiffr`}>
        <div class="thc-bar" aria-hidden="true">
          <span class="thc-dots"><i></i><i></i><i></i></span>
          <span class="thc-status"><i></i>{appSubtitle}</span>
        </div>

        <div class="thc-body">
          <div class="thc-head">
            <p>Exemple dans Chiffr</p>
            <strong>{appTitle}</strong>
          </div>

          <div class="thc-badge">
            <small>{appBadgeLabel}</small>
            <b>{appBadgeValue}</b>
          </div>

          <div class="thc-list">
            {appSteps.slice(0, 4).map((step, index) => (
              <div class="thc-row">
                <span class="thc-num">{String(index + 1).padStart(2, '0')}</span>
                <span class="thc-label">{step.title}</span>
                <small class="thc-state">{step.status}</small>
              </div>
            ))}
          </div>

          {appMini.length > 0 && (
            <div class="thc-mini">
              {appMini.slice(0, 3).map((mini) => (
                <div>
                  <small>{mini.label}</small>
                  <strong>{mini.value}</strong>
                </div>
              ))}
            </div>
          )}

          <div class="thc-strip">
            <small>{appStripLabel}</small>
            <span>{appStripText}</span>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="shell split">
      <div class="panel dark reveal">
        <p class="kicker light">Le problème</p>
        <h2>{problemTitle}</h2>
        <p>{problemText}</p>
      </div>

      <div class="panel reveal">
        <p class="kicker">La réponse Chiffr</p>
        <h2>{solutionTitle}</h2>
        <p>{solutionText}</p>
      </div>
    </div>
  </section>

  <section id="lignes-devis" class="section">
    <div class="shell">
      <div class="section-head reveal">
        <p class="kicker">{quoteKicker}</p>
        <h2>{quoteTitle}</h2>
        <p>{quoteIntro}</p>
      </div>

      <div class="line-grid">
        {quoteLines.map((item) => (
          <article class="line-card reveal-card">
            <strong>{item.title}</strong>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  {chantierType && (
    <section class="section">
      <div class="shell tl-chantier reveal">
        <div class="tl-chantier-head">
          <p class="kicker">Chantier type</p>
          <h2>{chantierType.title}</h2>
          <p>{chantierType.intro}</p>
        </div>

        <ol class="tl-chantier-steps">
          {chantierType.steps.map((step) => <li>{step}</li>)}
        </ol>

        {chantierType.note && <p class="tl-chantier-note">{chantierType.note}</p>}
      </div>
    </section>
  )}

  <section class="section">
    <div class="shell">
      <div class="section-head reveal">
        <p class="kicker">{featuresKicker}</p>
        <h2>{featuresTitle}</h2>
        <p>{featuresIntro}</p>
      </div>

      <div class="feature-grid">
        {features.map((item) => (
          <article class="feature-card reveal-card">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section tl-cockpit-section">
    <div class="shell tl-cockpit reveal">
      <div class="tl-cockpit-copy">
        <p class="kicker light">Le logiciel</p>
        <h2>Un cockpit clair pour préparer, suivre et facturer vos devis</h2>
        <p class="tl-cockpit-lead">
          Chiffr relie le devis, la signature, l’acompte, la facture et la relance
          dans un seul dossier. Vous savez toujours où en est chaque chantier.
        </p>

        <div class="tl-cockpit-steps">
          {appSteps.slice(0, 4).map((step, index) => (
            <div>
              <b>{String(index + 1).padStart(2, '0')}</b>
              <strong>{step.title}</strong>
              <span>{step.status}</span>
            </div>
          ))}
        </div>

        <div class="actions">
          <a class="btn light" href={APP_URL}>Essayer gratuitement</a>
          <a class="btn ghost" href="/fonctionnalites">Voir les fonctionnalités</a>
        </div>

        <p class="cta-trust on-dark">{CTA_TRUST}</p>
      </div>

      <figure class="tl-cockpit-shot">
        <span class="tl-window-bar" aria-hidden="true"><i></i><i></i><i></i></span>
        <img
          src="/images/app/app-suivi-desktop.webp"
          alt={`Suivi des devis ${pill} dans Chiffr : statuts, signatures, acomptes et factures`}
          width="1800"
          height="908"
          loading="lazy"
          decoding="async"
        />
      </figure>
    </div>
  </section>

  <section class="section">
    <div class="shell usecase-panel reveal">
      <div>
        <p class="kicker">Cas fréquents</p>
        <h2>{usecaseTitle}</h2>
        <p>{usecaseIntro}</p>
      </div>

      <div class="usecase-grid">
        {useCases.map((item) => (
          <article>
            <strong>{item.title}</strong>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <div class="section-head reveal">
        <p class="kicker">Le logiciel en situation</p>
        <h2>L’outil tel que vous l’utiliserez au quotidien</h2>
        <p>
          De vrais écrans de Chiffr, sans retouche : l’accueil qui priorise votre
          journée et la liste de devis qui suit chaque dossier.
        </p>
      </div>

      <div class="tl-screens">
        <figure class="reveal-card">
          <span class="tl-window-bar" aria-hidden="true"><i></i><i></i><i></i></span>
          <img
            src="/images/app/app-accueil-desktop.webp"
            alt="Accueil Chiffr : priorités du jour, suivi commercial et actions rapides"
            width="1800"
            height="908"
            loading="lazy"
            decoding="async"
          />
          <figcaption>L’accueil : vos priorités du jour et l’argent à récupérer.</figcaption>
        </figure>

        <figure class="reveal-card">
          <span class="tl-window-bar" aria-hidden="true"><i></i><i></i><i></i></span>
          <img
            src="/images/app/app-devis-desktop.webp"
            alt="Liste des devis Chiffr : statuts, montants et relances"
            width="1800"
            height="908"
            loading="lazy"
            decoding="async"
          />
          <figcaption>Vos devis : statuts, montants et relances en un clic.</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell trade-photo-proof-panel reveal">
      <div class="trade-photo-proof-copy">
        <p class="kicker">Photos chantier</p>
        <h2>{photoTitle}</h2>
        <p>{photoIntro}</p>

        <div class="trade-photo-proof-list">
          {photoItems.slice(0, 4).map((item, index) => (
            <div>
              <span>{String(index + 1).padStart(2, '0')}</span>
              {item}
            </div>
          ))}
        </div>
      </div>

      <div class="trade-photo-proof-grid">
        {visualStory.cards.map((card) => (
          <article class="trade-photo-proof-card">
            <img
              src={card.image.src}
              alt={card.image.alt}
              {...imgDims(card.image.src)}
              loading="lazy"
              decoding="async"
            />

            <div>
              <strong>{card.title}</strong>
              <p>{card.text}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell resource reveal">
      <div>
        <p class="kicker">Maillage interne</p>
        <h2>{internalTitle}</h2>
        <p>{internalIntro}</p>
      </div>

      <div class="link-grid">
        {internalLinks.map((item) => (
          <a href={item.href}>{item.label}<span>→</span></a>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell narrow">
      <div class="section-head reveal">
        <p class="kicker">Questions fréquentes</p>
        <h2>{faqTitle}</h2>
      </div>

      <div class="faq-list">
        {faqs.map((item) => (
          <details class="reveal-card">
            <summary>{item.question}</summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="section cta">
    <div class="shell">
      <div class="cta-card reveal">
        <h2>{ctaTitle}</h2>
        <p>{ctaText}</p>
        <div class="actions">
          <a class="btn light" href={APP_URL}>{comingSoon ? 'Créer mon compte Chiffr' : `Créer mon devis ${appTitle}`}</a>
          <a class="btn ghost" href="/fonctionnalites">Voir les fonctionnalités</a>
        </div>

        <p class="cta-trust on-dark">{CTA_TRUST}</p>
      </div>
    </div>
  </section>


  <style is:global>
    .trade-hero-simple {
      background:
        radial-gradient(circle at 84% 8%, rgba(12, 20, 32, 0.09), transparent 34%),
        linear-gradient(180deg, rgba(250, 248, 242, 0.92), rgba(250, 248, 242, 0.62));
    }

    .trade-hero-simple-grid {
      display: grid;
      gap: 54px;
      align-items: center;
    }

    /* Hero métier = capture d'un devis Chiffr (mockup net, pas de photo IA).
       Délivre la promesse "modèle métier préparé" en montrant l'app, par métier. */
    .trade-hero-capture,
    .trade-hero-capture * {
      box-sizing: border-box;
    }

    .trade-hero-capture {
      position: relative;
      overflow: hidden;
      border-radius: 24px;
      background: linear-gradient(180deg, #FFFFFF, var(--chiffr-surface-warm));
      border: 1px solid var(--chiffr-border);
      box-shadow:
        0 40px 110px -34px rgba(12, 20, 32, 0.34),
        inset 0 1px 0 rgba(255, 255, 255, 0.8);
    }

    .thc-bar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 0 16px;
      height: 46px;
      background: linear-gradient(180deg, var(--chiffr-navy), var(--chiffr-navy-soft));
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    }

    .thc-dots {
      display: inline-flex;
      gap: 7px;
    }

    .thc-dots i {
      width: 9px;
      height: 9px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.22);
    }

    .thc-status {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      color: #DBA47C;
      font-size: 12px;
      font-weight: 650;
    }

    .thc-status i {
      width: 7px;
      height: 7px;
      border-radius: 999px;
      background: #DBA47C;
      box-shadow: 0 0 0 3px rgba(219, 164, 124, 0.18);
    }

    .thc-body {
      display: grid;
      gap: 16px;
      padding: clamp(22px, 3vw, 30px);
    }

    .thc-head p {
      margin: 0 0 7px;
      color: var(--copper);
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    .thc-head strong {
      display: block;
      color: var(--teal);
      font-family: var(--font-display);
      font-size: clamp(23px, 2.6vw, 33px);
      line-height: 1.06;
      letter-spacing: -0.01em;
      font-weight: 600;
    }

    .thc-badge {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 12px;
      padding: 13px 16px;
      border-radius: 14px;
      background: var(--chiffr-teal-soft);
      border: 1px solid rgba(6, 72, 80, 0.12);
    }

    .thc-badge small {
      color: var(--teal);
      font-size: 13px;
      font-weight: 600;
    }

    .thc-badge b {
      color: var(--teal);
      font-family: var(--font-display);
      font-size: clamp(21px, 2.3vw, 29px);
      font-weight: 600;
      letter-spacing: -0.01em;
    }

    .thc-list {
      display: grid;
      gap: 8px;
    }

    .thc-row {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr) auto;
      align-items: center;
      gap: 12px;
      padding: 11px 13px;
      border-radius: 12px;
      background: #FFFFFF;
      border: 1px solid var(--chiffr-border);
    }

    .thc-num {
      display: inline-grid;
      place-items: center;
      width: 26px;
      height: 26px;
      border-radius: 8px;
      background: var(--chiffr-copper-soft);
      color: var(--copper-dark);
      font-size: 12px;
      font-weight: 700;
    }

    .thc-label {
      min-width: 0;
      color: var(--chiffr-text);
      font-size: 15px;
      font-weight: 600;
    }

    .thc-state {
      padding: 4px 9px;
      border-radius: 999px;
      background: var(--chiffr-teal-soft);
      color: var(--teal);
      font-size: 12px;
      font-weight: 650;
      white-space: nowrap;
    }

    .thc-mini {
