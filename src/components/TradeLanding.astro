      line-height: 1.7;
    }

    .tl-cockpit-steps {
      display: grid;
      gap: 9px;
      margin-top: 24px;
    }

    .tl-cockpit-steps > div {
      display: flex;
      align-items: center;
      gap: 13px;
      padding: 11px 14px;
      border-radius: 12px;
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.09);
    }

    .tl-cockpit-steps b {
      width: 30px;
      height: 30px;
      flex: none;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 9px;
      background: rgba(159, 196, 194, 0.14);
      color: #9FC4C2;
      font-size: 11.5px;
      font-weight: 600;
    }

    .tl-cockpit-steps strong {
      flex: 1;
      color: rgba(255, 255, 255, 0.9);
      font-size: 14.5px;
      line-height: 1.3;
      font-weight: 550;
    }

    .tl-cockpit-steps span {
      flex: none;
      padding: 5px 10px;
      border-radius: 999px;
      background: rgba(159, 196, 194, 0.12);
      color: #9FC4C2;
      font-size: 11px;
      line-height: 1;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      white-space: nowrap;
    }

    .tl-cockpit .actions {
      margin-top: 30px;
    }

    .tl-cockpit-shot {
      margin: 0;
      overflow: hidden;
      border-radius: 14px;
      border: 1px solid rgba(255, 255, 255, 0.14);
      box-shadow: 0 36px 80px -28px rgba(0, 0, 0, 0.65);
      background: var(--chiffr-surface);
    }

    .tl-cockpit-shot img {
      display: block;
      width: 100%;
      height: auto;
    }

    .tl-window-bar {
      display: flex;
      align-items: center;
      gap: 7px;
      padding: 0 14px;
      height: 32px;
      background: linear-gradient(180deg, #18222F, var(--chiffr-navy-soft));
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    }

    .tl-window-bar i {
      width: 8px;
      height: 8px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.22);
    }

    /* ===== Screens produit ===== */
    .tl-screens {
      display: grid;
      gap: 30px;
      max-width: 1040px;
      margin: 40px auto 0;
    }

    .tl-screens figure {
      margin: 0;
      overflow: hidden;
      border-radius: 14px;
      background: var(--chiffr-surface);
      border: 1px solid var(--chiffr-border-strong);
      box-shadow: 0 30px 64px -30px rgba(12, 20, 32, 0.32);
    }

    .tl-screens img {
      display: block;
      width: 100%;
      height: auto;
    }

    .tl-screens figcaption {
      padding: 14px 18px;
      border-top: 1px solid var(--chiffr-border);
      background: var(--chiffr-surface-warm);
      color: var(--chiffr-text-soft);
      font-size: 13.5px;
      line-height: 1.4;
      font-weight: 500;
    }

    /* ===== Boutons variantes sombres ===== */
    .btn.light {
      color: var(--chiffr-navy);
      background: #FFFFFF;
      box-shadow: 0 16px 36px -12px rgba(0, 0, 0, 0.4);
    }

    .btn.light:hover {
      transform: translateY(-2px);
      background: #F1EDE5;
    }

    .btn.ghost {
      color: #FFFFFF;
      background: rgba(255, 255, 255, 0.06);
      border: 1px solid rgba(255, 255, 255, 0.22);
    }

    .btn.ghost:hover {
      transform: translateY(-2px);
      background: rgba(255, 255, 255, 0.12);
    }

    /* ===== CTA final navy ===== */
    .cta {
      text-align: center;
    }

    .cta-card {
      padding: clamp(44px, 5.5vw, 72px) clamp(24px, 5vw, 64px);
      border-radius: 24px;
      background:
        radial-gradient(640px 320px at 50% -20%, rgba(6, 72, 80, 0.45), transparent 75%),
        linear-gradient(180deg, var(--chiffr-navy), var(--chiffr-navy-soft));
      border: 1px solid rgba(255, 255, 255, 0.08);
      box-shadow: 0 36px 80px -38px rgba(12, 20, 32, 0.55);
    }

    .cta-card h2 {
      margin: 0 auto;
      max-width: 640px;
      color: #FFFFFF;
    }

    .cta-card > p {
      margin: 18px auto 0;
      max-width: 560px;
      color: rgba(255, 255, 255, 0.66);
      font-size: 16.5px;
      line-height: 1.7;
    }

    .cta-card .actions {
      margin-top: 30px;
      justify-content: center;
    }

    .faq-list {
      margin-top: 32px;
      display: grid;
      gap: 14px;
    }

    details {
      padding: 22px 24px;
      transition: transform 180ms ease, background 180ms ease, box-shadow 180ms ease;
    }

    details:hover {
      transform: translateY(-2px);
      background: white;
      box-shadow: 0 18px 46px rgba(12, 20, 32, 0.08);
    }

    summary {
      cursor: pointer;
      color: var(--teal);
      font-size: 18px;
      line-height: 1.4;
      letter-spacing: -0.015em;
      font-weight: 600;
    }

    details p {
      margin: 14px 0 0;
      color: #5F6673;
      font-size: 16px;
      line-height: 1.75;
    }

    /* ===== Bientôt disponible ===== */
    .soon-badge {
      display: inline-flex;
      align-items: center;
      margin-left: 8px;
      padding: 3px 9px;
      border-radius: 999px;
      background: var(--chiffr-copper);
      color: #fff;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.03em;
      text-transform: uppercase;
    }

    .soon-note {
      margin: 22px 0 0;
      max-width: 640px;
      padding: 16px 18px;
      border-radius: 16px;
      border: 1px solid var(--chiffr-copper-soft);
      background: var(--chiffr-cream);
      color: var(--chiffr-text-soft);
      font-size: 15px;
      line-height: 1.6;
    }

    .soon-note strong {
      color: var(--chiffr-copper-dark);
    }

    /* ===== Chantier type (récit terrain) ===== */
    .tl-chantier {
      border-radius: 24px;
      padding: clamp(28px, 4vw, 48px);
      border: 1px solid rgba(12, 20, 32, 0.1);
      background:
        linear-gradient(145deg, rgba(255, 255, 255, 0.82), rgba(255, 252, 247, 0.72));
      box-shadow: 0 18px 50px rgba(12, 20, 32, 0.07);
    }

    .tl-chantier-head {
      max-width: 840px;
    }

    .tl-chantier-head h2 {
      margin: 14px 0 0;
      color: var(--teal);
      font-size: clamp(30px, 3.4vw, 46px);
      line-height: 1.1;
      letter-spacing: -0.02em;
      font-weight: 650;
    }

    .tl-chantier-head p {
      margin: 18px 0 0;
      color: #5F6673;
      font-size: 18px;
      line-height: 1.75;
    }

    .tl-chantier-steps {
      margin: 26px 0 0;
      padding: 0;
      list-style: none;
      counter-reset: ct;
      display: grid;
      gap: 10px;
    }

    .tl-chantier-steps li {
      counter-increment: ct;
      position: relative;
      padding: 14px 16px 14px 58px;
      border-radius: 16px;
      background: rgba(255, 255, 255, 0.8);
      border: 1px solid rgba(12, 20, 32, 0.08);
      color: var(--chiffr-text);
      font-size: 15.5px;
      line-height: 1.5;
      font-weight: 500;
    }

    .tl-chantier-steps li::before {
      content: counter(ct, decimal-leading-zero);
      position: absolute;
      left: 14px;
      top: 12px;
      width: 30px;
      height: 30px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 10px;
      background: var(--chiffr-teal-soft);
      color: var(--teal);
      font-size: 12px;
      font-weight: 650;
    }

    .tl-chantier-note {
      margin: 18px 0 0;
      color: var(--chiffr-text-soft);
      font-size: 14px;
      line-height: 1.6;
      font-style: italic;
    }

    @media (min-width: 760px) {
      .tl-chantier-steps {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    .reveal,
    .reveal-card {
      opacity: 0;
      transform: translateY(18px);
      transition: opacity 620ms ease, transform 620ms cubic-bezier(0.16, 1, 0.3, 1);
    }

    .reveal.visible,
    .reveal-card.visible {
      opacity: 1;
      transform: translateY(0);
    }

    @keyframes cardFloat {
      0%,
      100% {
        transform: translateY(0);
      }

      50% {
        transform: translateY(-8px);
      }
    }

    @media (min-width: 760px) {
      .line-grid,
      .feature-grid,
      .usecase-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .link-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (min-width: 1020px) {
      .hero-grid {
        grid-template-columns: 1.05fr 0.95fr;
      }

      .tl-cockpit {
        grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
      }

      .split {
        grid-template-columns: 1fr 1fr;
      }

      .line-grid {
        grid-template-columns: repeat(4, 1fr);
      }

      .feature-grid {
        grid-template-columns: repeat(4, 1fr);
      }

      .usecase-panel,
      .photo-panel,
      .resource {
        grid-template-columns: 0.82fr 1.18fr;
        align-items: center;
      }
    }

    @media (max-width: 680px) {
      .hero-photo-card {
        min-height: 360px;
        border-radius: 20px;
      }

      .hero-photo-overlay {
        padding: 22px;
      }

      .app-hero,
      .steps > div {
        grid-template-columns: 1fr;
      }

      .mini-grid {
        grid-template-columns: 1fr;
      }

      .badge {
        width: 120px;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      *,
      *::before,
      *::after {
        animation-duration: 0.001ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.001ms !important;
      }

      .reveal,
      .reveal-card {
        opacity: 1;
        transform: none;
      }
    }
  </style>
</BaseLayout>