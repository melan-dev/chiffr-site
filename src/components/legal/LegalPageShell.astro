---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
  updatedAt?: string;
}

const { eyebrow, title, description, updatedAt = '8 juin 2026' } = Astro.props;
---

<section class="legal-hero">
  <div class="legal-shell">
    <p class="legal-eyebrow">{eyebrow}</p>
    <h1>{title}</h1>
    <p>{description}</p>

    <div class="legal-meta">
      <span>Chiffr - chiffr-devis.fr</span>
      <span>Dernière mise à jour : {updatedAt}</span>
    </div>
  </div>
</section>

<section class="legal-section">
  <div class="legal-shell legal-content">
    <slot />
  </div>
</section>

<style>
  .legal-hero,
  .legal-section,
  .legal-hero *,
  .legal-section * {
    box-sizing: border-box;
  }

  .legal-hero {
    padding: 76px 20px 42px;
    background:
      radial-gradient(circle at 88% 8%, rgba(12, 20, 32, 0.09), transparent 34%),
      linear-gradient(180deg, rgba(250, 248, 242, 0.96), rgba(250, 248, 242, 0.72));
  }

  .legal-shell {
    width: 100%;
    max-width: 980px;
    margin: 0 auto;
  }

  .legal-eyebrow {
    display: inline-flex;
    width: fit-content;
    margin: 0;
    color: var(--copper);
    font-size: 14px;
    line-height: 1;
    font-weight: 650;
  }

  .legal-hero h1 {
    margin: 18px 0 0;
    max-width: 820px;
    color: var(--teal);
    font-size: clamp(42px, 5.2vw, 72px);
    line-height: 0.98;
    letter-spacing: -0.02em;
    font-weight: 650;
  }

  .legal-hero p:not(.legal-eyebrow) {
    margin: 22px 0 0;
    max-width: 820px;
    color: #5F6673;
    font-size: 18px;
    line-height: 1.72;
    font-weight: 550;
  }

  .legal-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 24px;
  }

  .legal-meta span {
    display: inline-flex;
    padding: 9px 12px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.8);
    border: 1px solid rgba(12, 20, 32, 0.1);
    color: var(--teal);
    font-size: 12px;
    line-height: 1;
    font-weight: 650;
  }

  .legal-section {
    padding: 44px 20px 76px;
    background:
      linear-gradient(180deg, rgba(250, 248, 242, 0.46), rgba(250, 248, 242, 0.84));
  }

  .legal-content {
    display: grid;
    gap: 18px;
    padding: clamp(22px, 4vw, 38px);
    border-radius: 24px;
    border: 1px solid rgba(12, 20, 32, 0.1);
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.88), rgba(255, 252, 247, 0.9));
    box-shadow:
      0 30px 90px rgba(12, 20, 32, 0.09),
      inset 0 1px 0 rgba(255, 255, 255, 0.9);
  }

  .legal-content h2 {
    margin: 18px 0 0;
    color: var(--teal);
    font-size: clamp(25px, 2.5vw, 34px);
    line-height: 1.12;
    letter-spacing: -0.02em;
    font-weight: 650;
  }

  .legal-content h2:first-child {
    margin-top: 0;
  }

  .legal-content h3 {
    margin: 12px 0 0;
    color: var(--teal);
    font-size: 20px;
    line-height: 1.2;
    font-weight: 650;
  }

  .legal-content p,
  .legal-content li {
    color: #5F6673;
    font-size: 15px;
    line-height: 1.72;
    font-weight: 550;
  }

  .legal-content p {
    margin: 0;
  }

  .legal-content ul {
    display: grid;
    gap: 8px;
    margin: 0;
    padding-left: 20px;
  }

  .legal-content a {
    color: var(--teal);
    font-weight: 650;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  .legal-alert {
    display: grid;
    gap: 8px;
    padding: 18px;
    border-radius: 16px;
    background: rgba(185, 97, 52, 0.1);
    border: 1px solid rgba(185, 97, 52, 0.18);
  }

  .legal-alert strong {
    color: var(--teal);
    font-weight: 650;
  }

  .legal-card {
    display: grid;
    gap: 8px;
    padding: 18px;
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(12, 20, 32, 0.08);
  }

  .legal-card strong {
    color: var(--teal);
    font-weight: 650;
  }

  .legal-muted {
    color: #5F6673;
    font-size: 14px;
  }

  @media (max-width: 720px) {
    .legal-hero {
      padding-top: 52px;
    }

    .legal-content {
      border-radius: 18px;
    }
  }
</style>
