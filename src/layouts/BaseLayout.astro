---
import '../styles/global.css';
import '../styles/compact.css';
import '../styles/responsive.css';
import '../styles/stability.css';
import SeoHead from '../components/seo/SeoHead.astro';
import RelatedQuoteModels from '../components/RelatedQuoteModels.astro';
import RelatedSeoGuides from '../components/RelatedSeoGuides.astro';
import RelatedAlternatives from '../components/RelatedAlternatives.astro';
import ContextualPhotoSection from '../components/ContextualPhotoSection.astro';

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  ogImage?: string;
  schema?: Record<string, any> | Record<string, any>[];
}

const {
  title,
  description,
  canonicalPath,
  ogImage,
  schema,
} = Astro.props;

const currentPath = Astro.url.pathname;

const navItems = [
  { label: 'PAC', href: '/logiciel-devis-pompe-a-chaleur' },
  { label: 'Clim', href: '/logiciel-devis-climatisation' },
  { label: 'Chauffage', href: '/logiciel-devis-chauffagiste' },
  { label: 'CVC', href: '/logiciel-devis-frigoriste-cvc' },
  { label: 'VMC', href: '/logiciel-devis-vmc' },
  { label: 'IRVE', href: '/logiciel-devis-irve' },
  { label: 'Solaire', href: '/logiciel-devis-photovoltaique' },
  { label: 'Tarifs', href: '/tarifs' },
];

const resourceItems = [
  { label: 'Fonctionnalités', href: '/fonctionnalites' },
  { label: 'Modèles de devis', href: '/modeles-devis' },
  { label: 'Guides', href: '/guides-devis-artisans-energie' },
  { label: 'Alternatives logiciels', href: '/alternatives-logiciels-devis-batiment' },
  { label: 'Contact', href: '/contact' },
];

const footerMetiers = [
  { label: 'Pompe à chaleur', href: '/logiciel-devis-pompe-a-chaleur' },
  { label: 'Climatisation', href: '/logiciel-devis-climatisation' },
  { label: 'Chauffagiste', href: '/logiciel-devis-chauffagiste' },
  { label: 'Frigoriste / CVC', href: '/logiciel-devis-frigoriste-cvc' },
  { label: 'VMC', href: '/logiciel-devis-vmc' },
  { label: 'IRVE', href: '/logiciel-devis-irve' },
  { label: 'Solaire', href: '/logiciel-devis-photovoltaique' },
];

const footerChiffr = [
  { label: 'Tarifs', href: '/tarifs' },
  { label: 'Alternatives logiciels', href: '/alternatives-logiciels-devis-batiment' },
  { label: 'Guides devis', href: '/guides-devis-artisans-energie' },
  { label: 'Modèles de devis', href: '/modeles-devis' },
  { label: 'Fonctionnalités', href: '/fonctionnalites' },
  { label: 'Contact', href: '/contact' },
  { label: 'Mentions légales', href: '/mentions-legales' },
  { label: 'Confidentialité', href: '/confidentialite' },
  { label: 'CGU', href: '/cgu' },
];

const isActive = (href: string) => {
  if (href === '/') return currentPath === '/';
  return currentPath === href || currentPath.startsWith(`${href}/`);
};

const isResourceActive = resourceItems.some((item) => isActive(item.href));

const legalPaths = ['/mentions-legales', '/confidentialite', '/cgu'];
const isLegalPath = legalPaths.some(
  (path) => currentPath === path || currentPath.startsWith(`${path}/`)
);
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <SeoHead
      title={title}
      description={description}
      canonicalPath={canonicalPath}
      ogImage={ogImage}
      schema={schema}
    />

    <style is:inline>
      :root {
        --chiffr-header-height: 132px;
      }

      html {
        scroll-padding-top: calc(var(--chiffr-header-height) + 18px);
      }

      body {
        padding-top: var(--chiffr-header-height);
      }

      body.mobile-menu-open {
        overflow: hidden;
      }

      [id] {
        scroll-margin-top: calc(var(--chiffr-header-height) + 18px);
      }

      .site-header,
      .site-header *,
      .site-footer,
      .site-footer * {
        box-sizing: border-box;
      }

      .site-header {
        position: fixed;
        top: 0;
        right: 0;
        left: 0;
        z-index: 1000;
        padding: 14px 20px 10px;
        background:
          linear-gradient(180deg, rgba(255, 248, 239, 0.97), rgba(255, 248, 239, 0.9)),
          radial-gradient(circle at 20% 0%, rgba(183, 110, 60, 0.1), transparent 30%),
          radial-gradient(circle at 85% 0%, rgba(18, 63, 61, 0.08), transparent 28%);
        border-bottom: 1px solid rgba(18, 63, 61, 0.08);
        backdrop-filter: blur(18px);
        -webkit-backdrop-filter: blur(18px);
        box-shadow: 0 16px 50px rgba(18, 63, 61, 0.08);
      }

      .header-shell {
        width: 100%;
        max-width: 1420px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 18px;
        align-items: center;
      }

      .brand-card {
        display: grid;
        grid-template-columns: 54px auto;
        align-items: center;
        gap: 14px;
        min-width: 264px;
        padding: 11px 14px;
        border-radius: 26px;
        background:
          linear-gradient(145deg, rgba(255, 255, 255, 0.82), rgba(255, 253, 249, 0.72));
        border: 1px solid rgba(18, 63, 61, 0.08);
        box-shadow:
          0 18px 46px rgba(18, 63, 61, 0.06),
          inset 0 1px 0 rgba(255, 255, 255, 0.8);
        transition: transform 180ms ease, box-shadow 180ms ease, background 180ms ease;
      }

      .brand-card:hover {
        transform: translateY(-1px);
        background: rgba(255, 255, 255, 0.92);
        box-shadow:
          0 22px 56px rgba(18, 63, 61, 0.09),
          inset 0 1px 0 rgba(255, 255, 255, 0.9);
      }

      .brand-mark {
        position: relative;
        width: 54px;
        height: 54px;
        display: grid;
        place-items: center;
        border-radius: 18px;
        overflow: hidden;
        background:
          radial-gradient(circle at 65% 10%, rgba(255, 255, 255, 0.18), transparent 32%),
          linear-gradient(145deg, #123f3d, #0b302e);
        color: white;
        font-size: 28px;
        line-height: 1;
        font-weight: 950;
        letter-spacing: -0.06em;
        box-shadow:
          0 14px 28px rgba(18, 63, 61, 0.18),
          inset 0 -5px 0 rgba(183, 110, 60, 0.55);
      }

      .brand-mark.small {
        width: 44px;
        height: 44px;
        border-radius: 15px;
        font-size: 23px;
      }

      .brand-name {
        color: var(--teal);
        font-size: 23px;
        line-height: 1;
        font-weight: 950;
        letter-spacing: -0.04em;
      }

      .brand-subtitle {
        margin-top: 4px;
        color: #667977;
        font-size: 13px;
        line-height: 1.25;
        font-weight: 800;
      }

      .nav-card {
        min-width: 0;
        display: grid;
        grid-template-columns: auto minmax(0, 1fr) auto;
        align-items: center;
        gap: 14px;
        padding: 10px;
        border-radius: 30px;
        background:
          linear-gradient(145deg, rgba(255, 255, 255, 0.92), rgba(255, 253, 249, 0.78));
        border: 1px solid rgba(18, 63, 61, 0.1);
        box-shadow:
          0 22px 60px rgba(18, 63, 61, 0.09),
          inset 0 1px 0 rgba(255, 255, 255, 0.9);
      }

      .home-link {
        width: 46px;
        height: 46px;
        display: grid;
        place-items: center;
        flex: none;
        border-radius: 18px;
        color: var(--copper);
        background: rgba(183, 110, 60, 0.07);
        border: 1px solid rgba(183, 110, 60, 0.12);
        transition: transform 180ms ease, background 180ms ease, color 180ms ease;
      }

      .home-link:hover,
      .home-link.active {
        transform: translateY(-1px);
        background: rgba(183, 110, 60, 0.13);
        color: #9d552d;
      }

      .home-link svg,
      .header-cta svg {
        width: 21px;
        height: 21px;
        fill: none;
        stroke: currentColor;
        stroke-width: 2;
        stroke-linecap: round;
        stroke-linejoin: round;
      }

      .nav-links {
        min-width: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 3px;
      }

      .nav-link,
      .nav-more-button {
        position: relative;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 44px;
        padding: 0 11px;
        border-radius: 17px;
        color: #244a47;
        font-size: 13px;
        line-height: 1;
        font-weight: 950;
        white-space: nowrap;
        transition:
          transform 180ms ease,
          background 180ms ease,
          color 180ms ease,
          box-shadow 180ms ease;
      }

      .nav-more {
        position: relative;
        display: inline-flex;
      }

      .nav-more-button {
        border: 0;
        background: transparent;
        font: inherit;
        cursor: pointer;
        list-style: none;
      }

      .nav-more-button::-webkit-details-marker {
        display: none;
      }

      .nav-more-button span {
        margin-left: 7px;
        color: var(--copper);
        font-size: 15px;
        line-height: 1;
        transition: transform 180ms ease;
      }

      .nav-link::after,
      .nav-more-button::after {
        content: "";
        position: absolute;
        left: 18px;
        right: 18px;
        bottom: 7px;
        height: 3px;
        border-radius: 999px;
        background: var(--copper);
        opacity: 0;
        transform: scaleX(0.4);
        transition: opacity 180ms ease, transform 180ms ease;
      }

      .nav-link:hover,
      .nav-link.active,
      .nav-more.active .nav-more-button,
      .nav-more[open] .nav-more-button,
      .nav-more-button:hover {
        transform: translateY(-1px);
        background: rgba(255, 248, 239, 0.9);
        color: var(--teal);
        box-shadow: inset 0 0 0 1px rgba(18, 63, 61, 0.06);
      }

      .nav-link:hover::after,
      .nav-link.active::after,
      .nav-more.active .nav-more-button::after,
      .nav-more[open] .nav-more-button::after,
      .nav-more-button:hover::after {
        opacity: 1;
        transform: scaleX(1);
      }

      .nav-more[open] .nav-more-button span {
        transform: rotate(180deg);
      }

      .nav-more-panel {
        position: absolute;
        top: calc(100% + 12px);
        right: 0;
        width: 292px;
        padding: 10px;
        border-radius: 24px;
        background:
          radial-gradient(circle at 20% 0%, rgba(183, 110, 60, 0.12), transparent 36%),
          linear-gradient(145deg, rgba(255, 253, 249, 0.98), rgba(255, 255, 255, 0.94));
        border: 1px solid rgba(18, 63, 61, 0.12);
        box-shadow:
          0 28px 80px rgba(18, 63, 61, 0.18),
          inset 0 1px 0 rgba(255, 255, 255, 0.9);
        opacity: 0;
        visibility: hidden;
        transform: translateY(10px) scale(0.98);
        pointer-events: none;
        transition:
          opacity 180ms ease,
          transform 180ms cubic-bezier(0.16, 1, 0.3, 1),
          visibility 180ms ease;
      }

      .nav-more[open] .nav-more-panel {
        opacity: 1;
        visibility: visible;
        transform: translateY(0) scale(1);
        pointer-events: auto;
      }

      .nav-more-link {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
        padding: 14px 15px;
        border-radius: 18px;
        color: var(--teal);
        transition: transform 180ms ease, background 180ms ease, box-shadow 180ms ease;
      }

      .nav-more-link strong {
        font-size: 14px;
        font-weight: 950;
      }

      .nav-more-link span {
        color: var(--copper);
        font-weight: 950;
      }

      .nav-more-link:hover,
      .nav-more-link.active {
        transform: translateY(-2px);
        background: rgba(255, 255, 255, 0.9);
        box-shadow: 0 14px 34px rgba(18, 63, 61, 0.08);
      }

      .header-cta {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        min-height: 50px;
        padding: 0 22px;
        border-radius: 999px;
        background:
          radial-gradient(circle at 20% 0%, rgba(255, 255, 255, 0.14), transparent 36%),
          linear-gradient(145deg, #123f3d, #0e3432);
        color: white;
        font-size: 14px;
        font-weight: 950;
        white-space: nowrap;
        box-shadow:
          0 18px 42px rgba(18, 63, 61, 0.22),
          inset 0 1px 0 rgba(255, 255, 255, 0.12);
        transition: transform 180ms ease, box-shadow 180ms ease, background 180ms ease;
      }

      .header-cta:hover {
        transform: translateY(-1px);
        box-shadow:
          0 22px 50px rgba(18, 63, 61, 0.27),
          inset 0 1px 0 rgba(255, 255, 255, 0.14);
      }

      .header-reform-strip {
        width: 100%;
        max-width: 1420px;
        min-height: 40px;
        margin: 10px auto 0;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 8px 16px;
        border-radius: 999px;
        color: var(--teal);
        background:
          linear-gradient(90deg, rgba(220, 236, 235, 0.78), rgba(255, 255, 255, 0.78));
        border: 1px solid rgba(18, 63, 61, 0.1);
        box-shadow:
          0 16px 40px rgba(18, 63, 61, 0.06),
          inset 0 1px 0 rgba(255, 255, 255, 0.7);
        font-size: 13px;
        line-height: 1.25;
        font-weight: 850;
      }

      .header-reform-icon {
        width: 24px;
        height: 24px;
        display: inline-grid;
        place-items: center;
        flex: none;
        border-radius: 999px;
        background: var(--teal);
        color: white;
        font-size: 13px;
      }

      .header-reform-strip strong {
        font-weight: 950;
      }

      .header-reform-strip span:last-child {
        color: #667977;
      }

      .mobile-menu-toggle,
      .mobile-menu-backdrop,
      .mobile-menu-panel {
        display: none;
      }

      .site-footer {
        margin-top: 0;
        background:
          radial-gradient(circle at 15% 0%, rgba(183, 110, 60, 0.16), transparent 38%),
          linear-gradient(180deg, #123f3d, #0b302e);
        color: white;
      }

      .footer-shell {
        width: min(1180px, calc(100% - 40px));
        margin: 0 auto;
        padding: 62px 0 46px;
        display: grid;
        gap: 36px;
      }

      .footer-logo {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        color: white;
      }

      .footer-logo strong {
        display: block;
        font-size: 24px;
        line-height: 1;
        font-weight: 950;
        letter-spacing: -0.04em;
      }

      .footer-logo span {
        display: block;
        margin-top: 4px;
        color: rgba(255, 255, 255, 0.68);
        font-size: 12px;
        font-weight: 780;
      }

      .footer-brand p {
        max-width: 550px;
        margin: 20px 0 0;
        color: rgba(255, 255, 255, 0.72);
        font-size: 15px;
        line-height: 1.7;
        font-weight: 650;
      }

      .footer-cta {
        width: fit-content;
        min-height: 48px;
        margin-top: 24px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0 22px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.1);
        color: white;
        font-weight: 950;
        border: 1px solid rgba(255, 255, 255, 0.16);
      }

      .footer-column {
        display: grid;
        align-content: start;
        gap: 12px;
      }

      .footer-column h2 {
        margin: 0 0 8px;
        color: white;
        font-size: 14px;
        font-weight: 950;
      }

      .footer-column a {
        color: rgba(255, 255, 255, 0.7);
        font-size: 14px;
        font-weight: 720;
      }

      .footer-column a:hover {
        color: white;
      }

      .footer-bottom {
        width: min(1180px, calc(100% - 40px));
        margin: 0 auto;
        padding: 20px 0 30px;
        display: flex;
        justify-content: space-between;
        gap: 18px;
        border-top: 1px solid rgba(255, 255, 255, 0.12);
        color: rgba(255, 255, 255, 0.58);
        font-size: 13px;
        font-weight: 680;
      }

      .footer-bottom p {
        margin: 0;
      }

      .footer-bottom a {
        color: rgba(255, 255, 255, 0.7);
      }

      .footer-bottom a:hover {
        color: white;
      }

      @media (min-width: 820px) {
        .footer-shell {
          grid-template-columns: 1.2fr 0.8fr 0.8fr;
        }
      }

      @media (max-width: 1240px) {
        .header-shell {
          grid-template-columns: 1fr;
        }

        .brand-card {
          width: fit-content;
        }

        .nav-links {
          justify-content: flex-start;
          overflow-x: auto;
          scrollbar-width: none;
          padding-bottom: 2px;
        }

        .nav-links::-webkit-scrollbar {
          display: none;
        }
      }

      @media (max-width: 860px) {
        :root {
          --chiffr-header-height: 112px;
        }

        .site-header {
          padding: 10px 12px 8px;
        }

        .header-shell {
          display: flex;
          align-items: center;
          justify-content: space-between;
          gap: 10px;
        }

        .brand-card {
          min-width: 0;
          grid-template-columns: 44px auto;
          gap: 10px;
          padding: 8px 10px;
          border-radius: 20px;
        }

        .brand-mark {
          width: 44px;
          height: 44px;
          border-radius: 15px;
          font-size: 23px;
        }

        .brand-name {
          font-size: 20px;
        }

        .brand-subtitle {
          font-size: 10.5px;
          line-height: 1.18;
        }

        .nav-card {
          width: auto;
          display: flex;
          padding: 0;
          border: 0;
          background: transparent;
          box-shadow: none;
        }

        .home-link,
        .nav-links,
        .header-cta {
          display: none !important;
        }

        .mobile-menu-toggle {
          width: 52px;
          height: 52px;
          display: inline-flex;
          flex-direction: column;
          align-items: center;
          justify-content: center;
          gap: 6px;
          border: 1px solid rgba(18, 63, 61, 0.1);
          border-radius: 18px;
          background: rgba(255, 255, 255, 0.82);
          color: var(--teal);
          box-shadow:
            0 16px 36px rgba(18, 63, 61, 0.08),
            inset 0 1px 0 rgba(255, 255, 255, 0.9);
          cursor: pointer;
        }

        .mobile-menu-toggle span {
          width: 21px;
          height: 2px;
          border-radius: 999px;
          background: currentColor;
          transition: transform 180ms ease, opacity 180ms ease;
        }

        .mobile-menu-toggle.is-open span:nth-child(1) {
          transform: translateY(8px) rotate(45deg);
        }

        .mobile-menu-toggle.is-open span:nth-child(2) {
          opacity: 0;
        }

        .mobile-menu-toggle.is-open span:nth-child(3) {
          transform: translateY(-8px) rotate(-45deg);
        }

        .header-reform-strip {
          min-height: 34px;
          margin-top: 8px;
          justify-content: center;
          border-radius: 18px;
          overflow: hidden;
          white-space: nowrap;
          font-size: 12px;
        }

        .header-reform-strip span:not(.header-reform-icon) {
          display: none;
        }

        .mobile-menu-backdrop {
          position: fixed;
          inset: 0;
          z-index: 1090;
          display: block;
          background: rgba(8, 29, 28, 0.46);
          opacity: 0;
          transition: opacity 180ms ease;
        }

        .mobile-menu-backdrop.is-visible {
          opacity: 1;
        }

        .mobile-menu-panel {
          position: fixed;
          top: 0;
          right: 0;
          bottom: 0;
          z-index: 1100;
          width: min(390px, 88vw);
          display: flex;
          flex-direction: column;
          background:
            radial-gradient(circle at 100% 0%, rgba(183, 110, 60, 0.12), transparent 34%),
            linear-gradient(180deg, rgba(255, 253, 249, 0.98), rgba(248, 241, 232, 0.98));
          border-left: 1px solid rgba(18, 63, 61, 0.12);
          box-shadow: -28px 0 80px rgba(18, 63, 61, 0.22);
          transform: translateX(104%);
          transition: transform 220ms cubic-bezier(0.16, 1, 0.3, 1);
        }

        .mobile-menu-panel.is-open {
          transform: translateX(0);
        }

        .mobile-menu-head {
          display: flex;
          align-items: center;
          justify-content: space-between;
          gap: 14px;
          padding: 18px 18px 14px;
          border-bottom: 1px solid rgba(18, 63, 61, 0.08);
        }

        .mobile-menu-logo {
          display: flex;
          align-items: center;
          gap: 12px;
          color: var(--teal);
        }

        .mobile-menu-logo strong {
          display: block;
          font-size: 22px;
          line-height: 1;
          font-weight: 950;
          letter-spacing: -0.04em;
        }

        .mobile-menu-logo span {
          display: block;
          margin-top: 4px;
          color: #667977;
          font-size: 11px;
          line-height: 1.2;
          font-weight: 800;
        }

        .mobile-menu-close {
          width: 46px;
          height: 46px;
          display: inline-flex;
          align-items: center;
          justify-content: center;
          border: 1px solid rgba(18, 63, 61, 0.1);
          border-radius: 16px;
          background: rgba(255, 255, 255, 0.8);
          color: var(--teal);
          font-size: 32px;
          line-height: 1;
          cursor: pointer;
        }

        .mobile-menu-body {
          display: grid;
          gap: 18px;
          padding: 18px;
          overflow-y: auto;
        }

        .mobile-menu-group p {
          margin: 0 0 10px;
          color: var(--copper);
          font-size: 12px;
          line-height: 1;
          font-weight: 950;
          text-transform: uppercase;
          letter-spacing: 0.08em;
        }

        .mobile-menu-grid {
          display: grid;
          grid-template-columns: repeat(2, minmax(0, 1fr));
          gap: 9px;
        }

        .mobile-menu-link,
        .mobile-menu-row {
          color: var(--teal);
          border: 1px solid rgba(18, 63, 61, 0.1);
          background: rgba(255, 255, 255, 0.78);
          box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.8);
        }

        .mobile-menu-link {
          min-height: 46px;
          display: inline-flex;
          align-items: center;
          justify-content: center;
          padding: 0 12px;
          border-radius: 17px;
          font-size: 13px;
          font-weight: 950;
        }

        .mobile-menu-link.active,
        .mobile-menu-row.active {
          border-color: rgba(18, 63, 61, 0.2);
          background: var(--teal);
          color: white;
        }

        .mobile-menu-list {
          display: grid;
          gap: 9px;
        }

        .mobile-menu-row {
          min-height: 52px;
          display: flex;
          align-items: center;
          justify-content: space-between;
          gap: 14px;
          padding: 0 15px;
          border-radius: 18px;
          font-size: 15px;
          font-weight: 950;
        }

        .mobile-menu-row strong {
          color: var(--copper);
          font-size: 18px;
        }

        .mobile-menu-row.active strong {
          color: white;
        }

        .mobile-menu-cta {
          min-height: 56px;
          display: inline-flex;
          align-items: center;
          justify-content: center;
          gap: 10px;
          border-radius: 999px;
          background: var(--teal);
          color: white;
          font-size: 15px;
          font-weight: 950;
          box-shadow: 0 18px 44px rgba(18, 63, 61, 0.18);
        }

        .mobile-menu-reform {
          display: grid;
          gap: 6px;
          padding: 16px;
          border-radius: 20px;
          background: rgba(220, 236, 235, 0.68);
          border: 1px solid rgba(18, 63, 61, 0.1);
          color: var(--teal);
        }

        .mobile-menu-reform strong {
          font-size: 14px;
          font-weight: 950;
        }

        .mobile-menu-reform span {
          color: #667977;
          font-size: 13px;
          line-height: 1.35;
          font-weight: 760;
        }

        .footer-bottom {
          display: grid;
        }
      }

      @media (max-width: 420px) {
        .brand-card {
          grid-template-columns: 40px auto;
          padding: 8px;
        }

        .brand-mark {
          width: 40px;
          height: 40px;
          border-radius: 14px;
          font-size: 21px;
        }

        .brand-name {
          font-size: 19px;
        }

        .mobile-menu-toggle {
          width: 48px;
          height: 48px;
          border-radius: 17px;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .site-header *,
        .site-footer *,
        .mobile-menu-panel,
        .mobile-menu-backdrop {
          transition-duration: 0.001ms !important;
          animation-duration: 0.001ms !important;
          animation-iteration-count: 1 !important;
        }
      }

      .reveal,
      .reveal-card,
      .reveal.visible,
      .reveal-card.visible,
      .pricing-reveal,
      .pricing-reveal-card,
      .pricing-reveal.is-visible,
      .pricing-reveal-card.is-visible {
        opacity: 1 !important;
        transform: none !important;
      }

      .hero,
      .section,
      .irve-hero,
      .irve-section,
      .pricing-hero,
      .pricing-plans,
      .pricing-compare,
      .pricing-proof-section,
      .pricing-faq,
      .pricing-cta,
      .features-hero,
      .features-section,
      .features-cta,
      .qm-hero,
      .qm-section,
      .qm-cta,
      .models-hero,
      .models-section,
      .models-cta,
      .contact-hero,
      .contact-section,
      .contact-cta,
      .guide-hero,
      .guide-section,
      .guide-cta,
      .usecase-hero,
      .usecase-section,
      .usecase-cta,
      .alt-hero,
      .alt-section,
      .alt-cta,
      .alt-hub-hero,
      .alt-hub-section,
      .alt-hub-cta {
        opacity: 1 !important;
        transform: none !important;
      }

      a:active,
      button:active,
      summary:active,
      .brand-card:active,
      .header-cta:active,
      .nav-link:active,
      .nav-more-button:active,
      .home-link:active,
      .mobile-menu-toggle:active,
      .mobile-menu-link:active,
      .mobile-menu-row:active {
        transform: none !important;
      }
    </style>
  </head>

  <body>
    <header class="site-header" id="top" data-site-header>
      <div class="header-shell">
        <a href="/" class="brand-card" aria-label="Accueil Chiffr">
          <div class="brand-mark" aria-hidden="true">C</div>

          <div class="brand-copy">
            <div class="brand-name">Chiffr</div>
            <div class="brand-subtitle">Devis &amp; factures<br />artisans énergie</div>
          </div>
        </a>

        <nav class="nav-card" aria-label="Navigation principale">
          <a
            href="/"
            class:list={['home-link', { active: isActive('/') }]}
            aria-label="Accueil"
          >
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M4 11.4 12 4l8 7.4v8.1a.9.9 0 0 1-.9.9h-4.2v-5.8H9.1v5.8H4.9a.9.9 0 0 1-.9-.9v-8.1Z" />
            </svg>
          </a>

          <div class="nav-links">
            {navItems.map((item) => (
              <a
                href={item.href}
                class:list={['nav-link', { active: isActive(item.href) }]}
              >
                {item.label}
              </a>
            ))}

            <details class:list={['nav-more', { active: isResourceActive }]} data-nav-resources>
              <summary class="nav-more-button">
                Ressources
                <span aria-hidden="true">⌄</span>
              </summary>

              <div class="nav-more-panel">
                {resourceItems.map((item) => (
                  <a
                    href={item.href}
                    class:list={['nav-more-link', { active: isActive(item.href) }]}
                  >
                    <strong>{item.label}</strong>
                    <span>→</span>
                  </a>
                ))}
              </div>
            </details>
          </div>

          <a href="/contact" class="header-cta">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M13.6 4.4c2.4-.9 4.4-.8 5.2 0s.9 2.8 0 5.2c-.8 2-2.5 4.4-5 6.9l-.7.7-4.3-4.3.7-.7c2.5-2.5 4.9-4.2 6.9-5Z" />
              <path d="M8.7 12.9 5.5 13.7 4 18l4.3-1.5.8-3.2" />
              <path d="M13.2 17.4 11.8 21l3.5-1.4 1.4-3.4" />
              <path d="M15.8 8.2h.01" />
            </svg>
            <span>Demander un accès</span>
          </a>

          <button
            type="button"
            class="mobile-menu-toggle"
            data-mobile-menu-button
            aria-label="Ouvrir le menu"
            aria-expanded="false"
            aria-controls="mobile-menu"
          >
            <span aria-hidden="true"></span>
            <span aria-hidden="true"></span>
            <span aria-hidden="true"></span>
          </button>
        </nav>
      </div>

      <a class="header-reform-strip" href="/fonctionnalites#facturation-electronique">
        <span class="header-reform-icon" aria-hidden="true">✓</span>
        <strong>Facturation électronique 2026–2027</strong>
        <span>Chiffr vous aide à préparer vos factures, données client et dossiers.</span>
      </a>

      <div class="mobile-menu-backdrop" data-mobile-menu-backdrop hidden></div>

      <aside
        id="mobile-menu"
        class="mobile-menu-panel"
        data-mobile-menu-panel
        aria-label="Menu mobile Chiffr"
        aria-hidden="true"
      >
        <div class="mobile-menu-head">
          <a href="/" class="mobile-menu-logo" aria-label="Accueil Chiffr">
            <div class="brand-mark small" aria-hidden="true">C</div>
            <div>
              <strong>Chiffr</strong>
              <span>Devis &amp; factures artisans énergie</span>
            </div>
          </a>

          <button
            type="button"
            class="mobile-menu-close"
            data-mobile-menu-close
            aria-label="Fermer le menu"
          >
            ×
          </button>
        </div>

        <div class="mobile-menu-body">
          <div class="mobile-menu-group">
            <p>Métiers</p>
            <div class="mobile-menu-grid">
              {navItems.slice(0, 7).map((item) => (
                <a href={item.href} class:list={['mobile-menu-link', { active: isActive(item.href) }]}>
                  {item.label}
                </a>
              ))}
            </div>
          </div>

          <div class="mobile-menu-group">
            <p>Ressources</p>
            <div class="mobile-menu-list">
              <a href="/tarifs" class:list={['mobile-menu-row', { active: isActive('/tarifs') }]}>
                <span>Tarifs</span>
                <strong>→</strong>
              </a>

              {resourceItems.map((item) => (
                <a href={item.href} class:list={['mobile-menu-row', { active: isActive(item.href) }]}>
                  <span>{item.label}</span>
                  <strong>→</strong>
                </a>
              ))}
            </div>
          </div>

          <a href="/contact" class="mobile-menu-cta">
            Demander un accès
            <span aria-hidden="true">→</span>
          </a>

          <a class="mobile-menu-reform" href="/fonctionnalites#facturation-electronique">
            <strong>Facturation électronique 2026–2027</strong>
            <span>Préparer vos factures, mentions et dossiers client.</span>
          </a>
        </div>
      </aside>
    </header>

    <main>
      <slot />
    </main>

    {!isLegalPath && (
      <>
        <ContextualPhotoSection currentPath={currentPath} />
        <RelatedQuoteModels currentPath={currentPath} />
        <RelatedSeoGuides currentPath={currentPath} />
        <RelatedAlternatives currentPath={currentPath} />
      </>
    )}

    <footer class="site-footer">
      <div class="footer-shell">
        <div class="footer-brand">
          <a href="/" class="footer-logo" aria-label="Accueil Chiffr">
            <div class="brand-mark small" aria-hidden="true">C</div>
            <div>
              <strong>Chiffr</strong>
              <span>Devis &amp; factures artisans énergie</span>
            </div>
          </a>

          <p>
            Logiciel de devis, factures, signature électronique et suivi client pensé pour les artisans PAC, climatisation,
            chauffage, CVC, VMC, IRVE et solaire. Chiffr aide aussi à préparer la transition vers la facturation électronique 2026–2027.
          </p>

          <a href="/contact" class="footer-cta">Demander un accès</a>
        </div>

        <div class="footer-column">
          <h2>Métiers</h2>
          {footerMetiers.map((item) => (
            <a href={item.href}>{item.label}</a>
          ))}
        </div>

        <div class="footer-column">
          <h2>Chiffr</h2>
          {footerChiffr.map((item) => (
            <a href={item.href}>{item.label}</a>
          ))}
        </div>
      </div>

      <div class="footer-bottom">
        <p>© {new Date().getFullYear()} Chiffr. Tous droits réservés.</p>
        <a href="#top">Retour en haut ↑</a>
      </div>
    </footer>

    <script is:inline>
      const siteHeader = document.querySelector('[data-site-header]');

      function updateHeaderHeight() {
        if (!siteHeader) return;

        document.documentElement.style.setProperty(
          '--chiffr-header-height',
          `${Math.ceil(siteHeader.getBoundingClientRect().height)}px`
        );
      }

      updateHeaderHeight();
      window.addEventListener('load', updateHeaderHeight);
      window.addEventListener('resize', updateHeaderHeight);

      if ('ResizeObserver' in window && siteHeader) {
        const headerObserver = new ResizeObserver(updateHeaderHeight);
        headerObserver.observe(siteHeader);
      }

      const resourcesMenu = document.querySelector('[data-nav-resources]');

      document.addEventListener('click', (event) => {
        if (!resourcesMenu || !resourcesMenu.open) return;
        if (event.target instanceof Node && resourcesMenu.contains(event.target)) return;
        resourcesMenu.open = false;
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && resourcesMenu) resourcesMenu.open = false;
      });

      resourcesMenu?.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => {
          resourcesMenu.open = false;
        });
      });

      const mobileMenuButton = document.querySelector('[data-mobile-menu-button]');
      const mobileMenuPanel = document.querySelector('[data-mobile-menu-panel]');
      const mobileMenuBackdrop = document.querySelector('[data-mobile-menu-backdrop]');
      const mobileMenuClose = document.querySelector('[data-mobile-menu-close]');

      function setMobileMenu(open) {
        if (!mobileMenuButton || !mobileMenuPanel || !mobileMenuBackdrop) return;

        document.body.classList.toggle('mobile-menu-open', open);
        mobileMenuButton.classList.toggle('is-open', open);
        mobileMenuButton.setAttribute('aria-expanded', String(open));
        mobileMenuPanel.setAttribute('aria-hidden', String(!open));

        if (open) {
          mobileMenuBackdrop.hidden = false;
          window.requestAnimationFrame(() => {
            mobileMenuBackdrop.classList.add('is-visible');
            mobileMenuPanel.classList.add('is-open');
          });
        } else {
          mobileMenuBackdrop.classList.remove('is-visible');
          mobileMenuPanel.classList.remove('is-open');
          window.setTimeout(() => {
            mobileMenuBackdrop.hidden = true;
          }, 180);
        }
      }

      mobileMenuButton?.addEventListener('click', () => {
        const isOpen = mobileMenuButton.getAttribute('aria-expanded') === 'true';
        setMobileMenu(!isOpen);
      });

      mobileMenuClose?.addEventListener('click', () => setMobileMenu(false));
      mobileMenuBackdrop?.addEventListener('click', () => setMobileMenu(false));

      mobileMenuPanel?.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => setMobileMenu(false));
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') setMobileMenu(false);
      });
    </script>
  </body>
</html>
