---
import { APP_URL, CTA_PRIMARY, CTA_TRUST_SHORT } from '../config';
import '../styles/global.css';
import '../styles/compact.css';
import '../styles/responsive.css';
import '../styles/stability.css';
import '../styles/premium.css';
import SeoHead from '../components/seo/SeoHead.astro';
import RelatedQuoteModels from '../components/RelatedQuoteModels.astro';
import RelatedSeoGuides from '../components/RelatedSeoGuides.astro';
import RelatedAlternatives from '../components/RelatedAlternatives.astro';
import ContextualPhotoSection from '../components/ContextualPhotoSection.astro';

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  ogImage?: string;
  schema?: Record<string, any> | Record<string, any>[];
}

const { title, description, canonicalPath, ogImage, schema } = Astro.props;

const currentPath = Astro.url.pathname;

const metierItems = [
  { label: 'Pompe à chaleur', detail: 'PAC air/eau & air/air', href: '/logiciel-devis-pompe-a-chaleur' },
  { label: 'Climatisation', detail: 'Monosplit & multisplit', href: '/logiciel-devis-climatisation' },
  { label: 'Chauffage', detail: 'Chaudières & radiateurs', href: '/logiciel-devis-chauffagiste' },
  { label: 'CVC / Froid', detail: 'Frigoriste & ventilation', href: '/logiciel-devis-frigoriste-cvc' },
  { label: 'VMC', detail: 'Simple & double flux', href: '/logiciel-devis-vmc' },
  { label: 'IRVE', detail: 'Bornes de recharge', href: '/logiciel-devis-irve' },
  { label: 'Solaire', detail: 'Photovoltaïque', href: '/logiciel-devis-photovoltaique' },
  { label: 'Eau chaude', detail: 'Chauffe-eau thermodynamique', href: '/logiciel-devis-chauffe-eau-thermodynamique' },
  { label: 'PAC air/air', detail: 'Clim réversible & multisplit', href: '/logiciel-devis-pac-air-air' },
  { label: 'Entretien clim', detail: 'Contrats & visites annuelles', href: '/logiciel-devis-entretien-climatisation' },
  { label: 'Rénovation énergétique', detail: 'Devis multi-postes', href: '/logiciel-devis-renovation-energetique' },
  { label: 'Plombier-chauffagiste', detail: 'Chauffage, sanitaire & PAC', href: '/logiciel-devis-plombier-chauffagiste', soon: true },
  { label: 'Électricien', detail: 'Tableau, rénovation & IRVE', href: '/logiciel-devis-electricien', soon: true },
];

const resourceItems = [
  { label: 'Modèles de devis', detail: 'Exemples concrets par métier', href: '/modeles-devis' },
  { label: 'Guides devis', detail: 'Conseils pratiques terrain', href: '/guides-devis-artisans-energie' },
  { label: 'Alternatives logiciels', detail: 'Comparatifs détaillés', href: '/alternatives-logiciels-devis-batiment' },
];

const footerMetiers = metierItems.map(({ label, href }) => ({ label, href }));

const footerChiffr = [
  { label: 'Fonctionnalités', href: '/fonctionnalites' },
  { label: 'Tarifs', href: '/tarifs' },
  { label: 'Modèles de devis', href: '/modeles-devis' },
  { label: 'Guides devis', href: '/guides-devis-artisans-energie' },
  { label: 'Alternatives logiciels', href: '/alternatives-logiciels-devis-batiment' },
  { label: 'Contact', href: '/contact' },
];

const footerLegal = [
  { label: 'Mentions légales', href: '/mentions-legales' },
  { label: 'Confidentialité', href: '/confidentialite' },
  { label: 'CGU', href: '/cgu' },
];

const isActive = (href: string) => {
  if (href === '/') return currentPath === '/';
  return currentPath === href || currentPath.startsWith(`${href}/`);
};

const isMetierActive = metierItems.some((item) => isActive(item.href));
const isResourceActive = resourceItems.some((item) => isActive(item.href));

const legalPaths = ['/mentions-legales', '/confidentialite', '/cgu'];
const isLegalPath = legalPaths.some(
  (path) => currentPath === path || currentPath.startsWith(`${path}/`)
);
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Chiffr favicon / app icons -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#0C1420" />

    <SeoHead
      title={title}
      description={description}
      canonicalPath={canonicalPath}
      ogImage={ogImage}
      schema={schema}
    />

    <script is:inline>
      // Active les reveals avant le premier paint ; sans JS rien n'est masqué.
      if (
        'IntersectionObserver' in window &&
        !window.matchMedia('(prefers-reduced-motion: reduce)').matches
      ) {
        document.documentElement.classList.add('rv');
      }
    </script>

    <style is:global>
      html {
        scroll-padding-top: 92px;
      }

      [id] {
        scroll-margin-top: 92px;
      }

      body.mobile-menu-open {
        overflow: hidden;
      }

      .ch-header,
      .ch-header *,
      .ch-footer,
      .ch-footer * {
        box-sizing: border-box;
      }

      /* ===== Header ===== */
      .ch-header {
        position: sticky;
        top: 0;
        z-index: 1000;
        background: var(--chiffr-navy);
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      }

      .ch-header-shell {
        width: min(1280px, 100% - 48px);
        margin: 0 auto;
        min-height: 72px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 28px;
      }

      .ch-brand {
        display: flex;
        align-items: center;
        gap: 12px;
        flex: none;
        color: #FFFFFF;
      }

      .ch-brand-mark {
        width: 38px;
        height: 38px;
        display: grid;
        place-items: center;
        border-radius: 11px;
        background: linear-gradient(160deg, #0A5049, #043840);
        box-shadow: inset 0 -3px 0 rgba(185, 97, 52, 0.5);
        color: #F6EFE0;
        font-family: var(--font-display);
        font-size: 21px;
        line-height: 1;
        font-weight: 600;
      }

      .ch-brand-name {
        font-family: var(--font-display);
        font-size: 23px;
        line-height: 1;
        font-weight: 600;
        letter-spacing: -0.01em;
        color: #FFFFFF;
      }

      .ch-brand-tagline {
        margin-left: 14px;
        padding-left: 16px;
        border-left: 1px solid rgba(255, 255, 255, 0.16);
        color: rgba(255, 255, 255, 0.56);
        font-size: 13px;
        line-height: 1.3;
        font-weight: 500;
        white-space: nowrap;
      }

      .ch-nav {
        display: flex;
        align-items: center;
        gap: 4px;
        min-width: 0;
      }

      .ch-nav-link,
      .ch-nav-trigger {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        min-height: 40px;
        padding: 0 14px;
        border-radius: 10px;
        color: rgba(255, 255, 255, 0.82);
        font-size: 14.5px;
        line-height: 1;
        font-weight: 550;
        white-space: nowrap;
        transition: color 160ms ease, background 160ms ease;
      }

      .ch-nav-link:hover,
      .ch-nav-link.active,
      .ch-nav-trigger:hover,
      .ch-nav-item[open] .ch-nav-trigger,
      .ch-nav-item.active .ch-nav-trigger {
        color: #FFFFFF;
        background: rgba(255, 255, 255, 0.07);
      }

      .ch-nav-item {
        position: relative;
      }

      .ch-nav-trigger {
        border: 0;
        background: transparent;
        font-family: inherit;
        cursor: pointer;
        list-style: none;
      }

      .ch-nav-trigger::-webkit-details-marker {
        display: none;
      }

      .ch-nav-trigger svg {
        width: 13px;
        height: 13px;
        fill: none;
        stroke: currentColor;
        stroke-width: 2;
        stroke-linecap: round;
        stroke-linejoin: round;
        opacity: 0.7;
        transition: transform 160ms ease;
      }

      .ch-nav-item[open] .ch-nav-trigger svg {
        transform: rotate(180deg);
      }

      .ch-nav-panel {
        position: absolute;
        top: calc(100% + 10px);
        left: 50%;
        transform: translateX(-50%);
        padding: 8px;
        border-radius: 16px;
        background: var(--chiffr-surface-warm);
        border: 1px solid var(--chiffr-border);
        box-shadow: 0 24px 64px rgba(12, 20, 32, 0.22);
      }

      .ch-nav-panel.metiers {
        width: 460px;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2px;
      }

      .ch-soon {
        display: inline-flex;
        align-items: center;
        margin-left: 7px;
        padding: 2px 7px;
        border-radius: 999px;
        background: var(--chiffr-copper);
        color: #fff;
        font-size: 9.5px;
        font-weight: 700;
        letter-spacing: 0.03em;
        text-transform: uppercase;
        vertical-align: middle;
      }

      .ch-nav-panel.ressources {
        width: 280px;
        display: grid;
        gap: 2px;
      }

      .ch-nav-panel a {
        display: grid;
        gap: 3px;
        padding: 11px 13px;
        border-radius: 11px;
        transition: background 140ms ease;
      }

      .ch-nav-panel a:hover,
      .ch-nav-panel a.active {
        background: #F1EDE5;
      }

      .ch-nav-panel strong {
        color: var(--chiffr-text);
        font-size: 14px;
        line-height: 1.2;
        font-weight: 600;
      }

      .ch-nav-panel small {
        color: var(--chiffr-text-soft);
        font-size: 12.5px;
        line-height: 1.3;
        font-weight: 450;
      }

      .ch-header-cta {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex: none;
        min-height: 44px;
        padding: 0 22px;
        border-radius: 11px;
        background: linear-gradient(160deg, #075058, var(--chiffr-teal-dark));
        color: #FFFFFF;
        font-size: 14.5px;
        font-weight: 600;
        white-space: nowrap;
        border: 1px solid rgba(255, 255, 255, 0.12);
        box-shadow: 0 10px 24px rgba(4, 56, 64, 0.35);
        transition: filter 160ms ease, box-shadow 160ms ease;
      }

      .ch-header-cta:hover {
        filter: brightness(1.12);
        box-shadow: 0 14px 30px rgba(4, 56, 64, 0.45);
      }

      /* Lien discret « Télécharger l'app » : action secondaire (téléchargement de
         l'installeur Windows .exe). Volontairement effacé — pas de bouton plein,
         pas de bordure — pour ne pas concurrencer le CTA principal. */
      .ch-header-install {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        flex: none;
        min-height: 44px;
        padding: 0 6px;
        margin-right: 6px;
        background: transparent;
        color: var(--chiffr-ink-soft, #51606e);
        font-size: 13.5px;
        font-weight: 500;
        white-space: nowrap;
        border: none;
        transition: color 160ms ease;
      }

      .ch-header-install svg {
        width: 15px;
        height: 15px;
        opacity: 0.8;
      }

      .ch-header-install:hover {
        color: var(--chiffr-teal-dark, #043840);
      }

      .ch-menu-button {
        display: none;
      }

      @media (max-width: 1180px) {
        .ch-brand-tagline {
          display: none;
        }
      }

      @media (max-width: 980px) {
        .ch-header-shell {
          width: min(1280px, 100% - 36px);
          min-height: 64px;
        }

        .ch-nav,
        .ch-header-cta,
        .ch-header-install {
          display: none;
        }

        .ch-menu-button {
          display: inline-flex;
          flex-direction: column;
          align-items: center;
          justify-content: center;
          gap: 5px;
          width: 44px;
          height: 44px;
          border: 1px solid rgba(255, 255, 255, 0.16);
          border-radius: 11px;
          background: rgba(255, 255, 255, 0.05);
          cursor: pointer;
        }

        .ch-menu-button span {
          width: 18px;
          height: 2px;
          border-radius: 999px;
          background: rgba(255, 255, 255, 0.9);
        }
      }

      /* ===== Menu mobile ===== */
      .ch-mobile-dialog {
        position: fixed;
        inset: 0 0 0 auto;
        width: min(400px, 92vw);
        height: 100dvh;
        max-width: none;
        max-height: none;
        margin: 0 0 0 auto;
        padding: 0;
        border: 0;
        background: transparent;
        color: inherit;
        overflow: visible;
      }

      .ch-mobile-dialog:not([open]) {
        display: none;
      }

      .ch-mobile-dialog::backdrop {
        background: rgba(12, 20, 32, 0.55);
        backdrop-filter: blur(2px);
        -webkit-backdrop-filter: blur(2px);
      }

      .ch-mobile-panel {
        width: 100%;
        height: 100%;
        display: flex;
        flex-direction: column;
        background: var(--chiffr-bg-warm);
        border-left: 1px solid var(--chiffr-border);
        transform: translateX(104%);
        transition: transform 220ms cubic-bezier(0.16, 1, 0.3, 1);
      }

      .ch-mobile-panel.is-open {
        transform: translateX(0);
      }

      .ch-mobile-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
        padding: 16px 18px;
        border-bottom: 1px solid var(--chiffr-border);
      }

      .ch-mobile-head .ch-brand {
        color: var(--chiffr-text);
      }

      .ch-mobile-head .ch-brand-name {
        color: var(--chiffr-text);
        font-size: 21px;
      }

      .ch-mobile-close {
        width: 42px;
        height: 42px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid var(--chiffr-border);
        border-radius: 11px;
        background: var(--chiffr-surface);
        color: var(--chiffr-text);
        font-size: 26px;
        line-height: 1;
        cursor: pointer;
      }

      .ch-mobile-body {
        display: grid;
        align-content: start;
        gap: 22px;
        padding: 20px 18px 28px;
        overflow-y: auto;
      }

      .ch-mobile-group p {
        margin: 0 0 10px;
        color: var(--chiffr-text-muted);
        font-size: 11.5px;
        line-height: 1;
        font-weight: 650;
        text-transform: uppercase;
        letter-spacing: 0.1em;
      }

      .ch-mobile-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px;
      }

      .ch-mobile-link {
        display: flex;
        align-items: center;
        gap: 7px;
        min-height: 46px;
        padding: 6px 14px;
        border-radius: 11px;
        border: 1px solid var(--chiffr-border);
        background: var(--chiffr-surface);
        color: var(--chiffr-text);
        font-size: 14px;
        font-weight: 550;
      }

      .ch-soon {
        display: inline-flex;
        align-items: center;
        margin-left: 7px;
        padding: 2px 7px;
        border-radius: 999px;
        background: var(--chiffr-copper);
        color: #fff;
        font-size: 9.5px;
        font-weight: 700;
        letter-spacing: 0.03em;
        text-transform: uppercase;
        vertical-align: middle;
      }

      .ch-mobile-link.active {
        background: var(--chiffr-teal);
        border-color: var(--chiffr-teal);
        color: #FFFFFF;
      }

      .ch-mobile-list {
        display: grid;
        gap: 8px;
      }

      .ch-mobile-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
        min-height: 50px;
        padding: 6px 15px;
        border-radius: 12px;
        border: 1px solid var(--chiffr-border);
        background: var(--chiffr-surface);
        color: var(--chiffr-text);
        font-size: 15px;
        font-weight: 550;
      }

      .ch-mobile-row span:last-child {
        color: var(--chiffr-copper);
      }

      .ch-mobile-row.active {
        background: var(--chiffr-teal);
        border-color: var(--chiffr-teal);
        color: #FFFFFF;
      }

      .ch-mobile-cta {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        min-height: 54px;
        border-radius: 12px;
        background: linear-gradient(160deg, #075058, var(--chiffr-teal-dark));
        color: #FFFFFF;
        font-size: 15px;
        font-weight: 600;
        box-shadow: 0 14px 32px rgba(4, 56, 64, 0.3);
      }

      /* ===== Footer ===== */
      .ch-footer {
        background: linear-gradient(180deg, var(--chiffr-navy), var(--chiffr-navy-soft));
        color: #FFFFFF;
      }

      .ch-footer-shell {
        width: min(1280px, 100% - 48px);
        margin: 0 auto;
        padding: 64px 0 48px;
        display: grid;
        gap: 44px;
      }

      .ch-footer-brand .ch-brand-name {
        color: #FFFFFF;
      }

      .ch-footer-brand > p {
        max-width: 460px;
        margin: 18px 0 0;
        color: rgba(255, 255, 255, 0.62);
        font-size: 14.5px;
        line-height: 1.7;
        font-weight: 450;
      }

      .ch-footer-cta {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 44px;
        margin-top: 22px;
        padding: 0 20px;
        border-radius: 11px;
        border: 1px solid rgba(255, 255, 255, 0.2);
        background: rgba(255, 255, 255, 0.06);
        color: #FFFFFF;
        font-size: 14px;
        font-weight: 600;
        transition: background 160ms ease;
      }

      .ch-footer-cta:hover {
        background: rgba(255, 255, 255, 0.12);
      }

      .ch-footer-title {
        margin: 0 0 5px;
        color: rgba(255, 255, 255, 0.45);
        font-size: 12px;
        font-weight: 650;
        text-transform: uppercase;
        letter-spacing: 0.1em;
      }

      .ch-footer-col {
        display: grid;
        align-content: start;
        justify-items: start;
        gap: 11px;
      }

      .ch-footer-col a {
        color: rgba(255, 255, 255, 0.74);
        font-size: 14px;
        font-weight: 480;
        transition: color 140ms ease;
      }

      .ch-footer-col a:hover {
        color: #FFFFFF;
      }

      .ch-footer-bottom {
        width: min(1280px, 100% - 48px);
        margin: 0 auto;
        padding: 22px 0 28px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        color: rgba(255, 255, 255, 0.45);
        font-size: 13px;
        font-weight: 450;
      }

      .ch-footer-bottom p {
        margin: 0;
      }

      .ch-footer-bottom a {
        color: rgba(255, 255, 255, 0.62);
      }

      .ch-footer-bottom a:hover {
        color: #FFFFFF;
      }

      @media (min-width: 880px) {
        .ch-footer-shell {
          grid-template-columns: 1.5fr 0.9fr 0.95fr 0.7fr;
        }
      }

      @media (max-width: 879px) {
        .ch-footer-shell {
          padding: 52px 0 40px;
          gap: 36px;
        }

        .ch-footer-bottom {
          flex-direction: column;
          align-items: flex-start;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .ch-header *,
        .ch-footer *,
        .ch-mobile-panel {
          transition-duration: 0.001ms !important;
          animation-duration: 0.001ms !important;
        }
      }

      /* Barre CTA fixe mobile (audit conversion) — geste primaire toujours à portée */
      .ch-mobile-cta-bar {
        display: none;
      }

      @media (max-width: 820px) {
        .ch-mobile-cta-bar {
          position: fixed;
          left: 0;
          right: 0;
          bottom: 0;
          z-index: 60;
          display: flex;
          flex-direction: column;
          align-items: center;
          gap: 3px;
          padding: 9px 16px calc(9px + env(safe-area-inset-bottom, 0px));
          background: rgba(255, 252, 247, 0.94);
          -webkit-backdrop-filter: blur(10px);
          backdrop-filter: blur(10px);
          border-top: 1px solid var(--chiffr-border);
          box-shadow: 0 -10px 30px -16px rgba(12, 20, 32, 0.32);
        }

        .ch-mobile-cta-bar-btn {
          display: flex;
          align-items: center;
          justify-content: center;
          width: 100%;
          min-height: 50px;
          border-radius: 12px;
          background: var(--chiffr-teal);
          color: #FFFFFF;
          font-size: 16px;
          font-weight: 650;
        }

        .ch-mobile-cta-bar-trust {
          color: var(--chiffr-text-soft);
          font-size: 11.5px;
          font-weight: 550;
        }

        body {
          padding-bottom: 88px;
        }
      }
    </style>
  </head>

  <body>
    <header class="ch-header" id="top" data-site-header>
      <div class="ch-header-shell">
        <a href="/" class="ch-brand" aria-label="Accueil Chiffr">
          <span class="ch-brand-mark" aria-hidden="true">C</span>
          <span class="ch-brand-name">Chiffr</span>
          <span class="ch-brand-tagline">Le logiciel de devis des artisans</span>
        </a>

        <nav class="ch-nav" aria-label="Navigation principale">
          <a href="/fonctionnalites" class:list={['ch-nav-link', { active: isActive('/fonctionnalites') }]}>
            Fonctionnalités
          </a>

          <details class:list={['ch-nav-item', { active: isMetierActive }]} data-nav-dropdown>
            <summary class="ch-nav-trigger">
              Métiers
              <svg viewBox="0 0 16 16" aria-hidden="true"><path d="m4 6 4 4 4-4" /></svg>
            </summary>
            <div class="ch-nav-panel metiers">
              {metierItems.map((item) => (
                <a href={item.href} class:list={[{ active: isActive(item.href) }]}>
                  <strong>{item.label}{item.soon && <span class="ch-soon">Bientôt</span>}</strong>
                  <small>{item.detail}</small>
                </a>
              ))}
            </div>
          </details>

          <a href="/tarifs" class:list={['ch-nav-link', { active: isActive('/tarifs') }]}>
            Tarifs
          </a>

          <details class:list={['ch-nav-item', { active: isResourceActive }]} data-nav-dropdown>
            <summary class="ch-nav-trigger">
              Ressources
              <svg viewBox="0 0 16 16" aria-hidden="true"><path d="m4 6 4 4 4-4" /></svg>
            </summary>
            <div class="ch-nav-panel ressources">
              {resourceItems.map((item) => (
                <a href={item.href} class:list={[{ active: isActive(item.href) }]}>
                  <strong>{item.label}</strong>
                  <small>{item.detail}</small>
                </a>
              ))}
            </div>
          </details>
        </nav>

        <a
          href="/telecharger"
          class="ch-header-install"
          aria-label="Télécharger l'application Chiffr pour Windows"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3v12" />
            <path d="m7 11 5 5 5-5" />
            <path d="M5 21h14" />
          </svg>
          Télécharger l'app
        </a>

        <a href={APP_URL} class="ch-header-cta">{CTA_PRIMARY}</a>

        <button
          type="button"
          class="ch-menu-button"
          data-mobile-menu-button
          aria-label="Ouvrir le menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <span aria-hidden="true"></span>
          <span aria-hidden="true"></span>
          <span aria-hidden="true"></span>
        </button>
      </div>
    </header>

    <dialog
      id="mobile-menu-dialog"
      class="ch-mobile-dialog"
      data-mobile-menu-dialog
      aria-label="Menu Chiffr"
    >
      <div id="mobile-menu" class="ch-mobile-panel" data-mobile-menu-panel>
        <div class="ch-mobile-head">
          <a href="/" class="ch-brand" aria-label="Accueil Chiffr">
            <span class="ch-brand-mark" aria-hidden="true">C</span>
            <span class="ch-brand-name">Chiffr</span>
          </a>

          <button
            type="button"
            class="ch-mobile-close"
            data-mobile-menu-close
            aria-label="Fermer le menu"
          >
            ×
          </button>
        </div>

        <div class="ch-mobile-body">
          <div class="ch-mobile-group">
            <p>Métiers</p>
            <div class="ch-mobile-grid">
              {metierItems.map((item) => (
                <a href={item.href} class:list={['ch-mobile-link', { active: isActive(item.href) }]}>
                  {item.label}{item.soon && <span class="ch-soon">Bientôt</span>}
                </a>
              ))}
            </div>
          </div>

          <div class="ch-mobile-group">
            <p>Chiffr</p>
            <div class="ch-mobile-list">
              <a href="/fonctionnalites" class:list={['ch-mobile-row', { active: isActive('/fonctionnalites') }]}>
                <span>Fonctionnalités</span>
                <span aria-hidden="true">→</span>
              </a>
              <a href="/tarifs" class:list={['ch-mobile-row', { active: isActive('/tarifs') }]}>
                <span>Tarifs</span>
                <span aria-hidden="true">→</span>
              </a>
              {resourceItems.map((item) => (
                <a href={item.href} class:list={['ch-mobile-row', { active: isActive(item.href) }]}>
                  <span>{item.label}</span>
                  <span aria-hidden="true">→</span>
                </a>
              ))}
            </div>
          </div>

          <a href={APP_URL} class="ch-mobile-cta">
            {CTA_PRIMARY}
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </dialog>

    <main>
      <slot />
    </main>

    {!isLegalPath && (
      <>
        <ContextualPhotoSection currentPath={currentPath} />
        <RelatedQuoteModels currentPath={currentPath} />
        <RelatedSeoGuides currentPath={currentPath} />
        <RelatedAlternatives currentPath={currentPath} />
      </>
    )}

    <footer class="ch-footer">
      <div class="ch-footer-shell">
        <div class="ch-footer-brand">
          <a href="/" class="ch-brand" aria-label="Accueil Chiffr">
            <span class="ch-brand-mark" aria-hidden="true">C</span>
            <span class="ch-brand-name">Chiffr</span>
          </a>

          <p>
            Logiciel de devis, factures, signature électronique et suivi client pensé pour les artisans PAC,
            climatisation, chauffage, CVC, VMC, IRVE et solaire. Chiffr aide aussi à préparer la transition
            vers la facturation électronique 2026–2027.
          </p>

          <a href={APP_URL} class="ch-footer-cta">{CTA_PRIMARY}</a>
        </div>

        <div class="ch-footer-col">
          <p class="ch-footer-title">Métiers</p>
          {footerMetiers.map((item) => (
            <a href={item.href}>{item.label}</a>
          ))}
        </div>

        <div class="ch-footer-col">
          <p class="ch-footer-title">Chiffr</p>
          {footerChiffr.map((item) => (
            <a href={item.href}>{item.label}</a>
          ))}
        </div>

        <div class="ch-footer-col">
          <p class="ch-footer-title">Légal</p>
          {footerLegal.map((item) => (
            <a href={item.href}>{item.label}</a>
          ))}
        </div>
      </div>

      <div class="ch-footer-bottom">
        <p>© {new Date().getFullYear()} Chiffr. Tous droits réservés.</p>
        <a href="#top">Retour en haut ↑</a>
      </div>
    </footer>

    <!-- Barre CTA fixe mobile (audit conversion) — le geste primaire toujours à portée -->
    <div class="ch-mobile-cta-bar" aria-hidden="false">
      <a href={APP_URL} class="ch-mobile-cta-bar-btn">{CTA_PRIMARY}</a>
      <span class="ch-mobile-cta-bar-trust">{CTA_TRUST_SHORT}</span>
    </div>

    <script is:inline>
      const dropdowns = Array.from(document.querySelectorAll('[data-nav-dropdown]'));

      document.addEventListener('click', (event) => {
        dropdowns.forEach((dropdown) => {
          if (!dropdown.open) return;
          if (event.target instanceof Node && dropdown.contains(event.target)) return;
          dropdown.open = false;
        });
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') dropdowns.forEach((dropdown) => (dropdown.open = false));
      });

      dropdowns.forEach((dropdown) => {
        dropdown.addEventListener('toggle', () => {
          if (!dropdown.open) return;
          dropdowns.forEach((other) => {
            if (other !== dropdown) other.open = false;
          });
        });

        dropdown.querySelectorAll('a').forEach((link) => {
          link.addEventListener('click', () => {
            dropdown.open = false;
          });
        });
      });

      const mobileMenuButton = document.querySelector('[data-mobile-menu-button]');
      const mobileMenuDialog = document.querySelector('[data-mobile-menu-dialog]');
      const mobileMenuPanel = document.querySelector('[data-mobile-menu-panel]');
      const mobileMenuClose = document.querySelector('[data-mobile-menu-close]');

      function setMobileMenu(open) {
        if (!mobileMenuButton || !mobileMenuDialog || !mobileMenuPanel) return;

        if (open) {
          document.body.classList.add('mobile-menu-open');
          mobileMenuButton.setAttribute('aria-expanded', 'true');

          if (typeof mobileMenuDialog.showModal === 'function') {
            if (!mobileMenuDialog.open) mobileMenuDialog.showModal();
          } else {
            mobileMenuDialog.setAttribute('open', '');
          }

          window.requestAnimationFrame(() => {
            mobileMenuPanel.classList.add('is-open');
          });

          return;
        }

        mobileMenuPanel.classList.remove('is-open');
        mobileMenuButton.setAttribute('aria-expanded', 'false');
        document.body.classList.remove('mobile-menu-open');

        window.setTimeout(() => {
          if (mobileMenuDialog.open && typeof mobileMenuDialog.close === 'function') {
            mobileMenuDialog.close();
          } else {
            mobileMenuDialog.removeAttribute('open');
          }
        }, 170);
      }

      mobileMenuButton?.addEventListener('click', () => {
        const isOpen = mobileMenuDialog?.open === true;
        setMobileMenu(!isOpen);
      });

      mobileMenuClose?.addEventListener('click', () => setMobileMenu(false));

      mobileMenuDialog?.addEventListener('click', (event) => {
        if (event.target === mobileMenuDialog) setMobileMenu(false);
      });

      mobileMenuDialog?.addEventListener('close', () => {
        mobileMenuPanel?.classList.remove('is-open');
        mobileMenuButton?.setAttribute('aria-expanded', 'false');
        document.body.classList.remove('mobile-menu-open');
      });

      mobileMenuPanel?.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => setMobileMenu(false));
      });

      // Observer global de reveal : couvre les pages sans observer local (ex. home).
      if (document.documentElement.classList.contains('rv')) {
        const revealObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              entry.target.classList.add(
                entry.target.matches('.pricing-reveal, .pricing-reveal-card') ? 'is-visible' : 'visible'
              );
              revealObserver.unobserve(entry.target);
            });
          },
          { threshold: 0.12, rootMargin: '0px 0px -30px 0px' }
        );

        document
          .querySelectorAll('.reveal, .reveal-card, .pricing-reveal, .pricing-reveal-card')
          .forEach((item) => revealObserver.observe(item));
      }
    </script>
  </body>
</html>
